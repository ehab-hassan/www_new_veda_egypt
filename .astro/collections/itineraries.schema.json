{
  "$ref": "#/definitions/itineraries",
  "definitions": {
    "itineraries": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "nights": {
          "type": "integer"
        },
        "days": {
          "type": "integer"
        },
        "experience": {
          "type": "string",
          "enum": [
            "Classic Cruise",
            "Dendera & Abydos",
            "Grand Journey"
          ]
        },
        "series": {
          "type": "string"
        },
        "vessels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "highlights": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "hero": {
          "type": "string"
        },
        "cardImage": {
          "type": "string"
        },
        "routeOverview": {
          "type": "string"
        },
        "facts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            },
            "required": [
              "label",
              "value"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "routes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string"
              },
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              },
              "tagline": {
                "type": "string"
              },
              "overview": {
                "type": "string"
              },
              "insights": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "timeline": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "title": {
                      "type": "string"
                    },
                    "places": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "default": []
                    },
                    "description": {
                      "type": "string"
                    },
                    "image": {
                      "type": "string"
                    },
                    "schedule": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "time": {
                            "type": "string"
                          },
                          "text": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "time",
                          "text"
                        ],
                        "additionalProperties": false
                      },
                      "default": []
                    }
                  },
                  "required": [
                    "title",
                    "description"
                  ],
                  "additionalProperties": false
                },
                "minItems": 1
              }
            },
            "required": [
              "label",
              "from",
              "to",
              "timeline"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        },
        "faq": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "q": {
                "type": "string"
              },
              "a": {
                "type": "string"
              }
            },
            "required": [
              "q",
              "a"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "tips": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "insights": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "travelNotes": {
          "type": "string"
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "comingSoon": {
          "type": "boolean",
          "default": false
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "summary",
        "nights",
        "days",
        "experience",
        "series",
        "vessels",
        "highlights",
        "hero",
        "cardImage",
        "routes"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}