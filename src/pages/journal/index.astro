---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const posts = (await getCollection('journal', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const dateFormatter = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<MainLayout
  title="Journal — VEDA Egypt"
  description="Letters from the river — stories, recipes, and notes from VEDA's dahabiyas on the Nile."
>

  <!-- Hero -->
  <div class="relative bg-void pt-40 pb-24 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/photo-2019-03-23-11.24.03-1280x800.jpg" alt="" class="w-full h-full object-cover object-center opacity-25" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-void/60 via-void/20 to-void"></div>
    <div class="relative max-w-3xl mx-auto px-6 lg:px-12 text-center">
      <div class="flex items-center justify-center gap-4 mb-6">
        <span class="h-px w-10 bg-gold/50"></span>
        <p class="font-sans text-[12px] tracking-ultra uppercase text-gold">From the River</p>
        <span class="h-px w-10 bg-gold/50"></span>
      </div>
      <h1 class="font-serif text-5xl md:text-6xl text-ivory font-light tracking-tight leading-tight mb-5">
        The <em class="italic text-gold-pale">Journal</em>
      </h1>
      <p class="font-sans text-base text-ivory/65 font-light leading-relaxed max-w-md mx-auto">
        Letters from the boats — what we cook, where we anchor, who we meet, and why we sail the way we do.
      </p>
    </div>
  </div>

  <!-- Posts list -->
  <div class="bg-warm-beige py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-6 lg:px-12">
      {posts.length === 0 ? (
        <p class="text-center font-serif text-2xl text-ink-mid italic">
          The first letter is on its way.
        </p>
      ) : (
        <ul class="space-y-12">
          {posts.map((post) => (
            <li class="border-b border-gold/15 pb-12 last:border-b-0 reveal">
              <a href={`/journal/${post.id}`} class="group block">
                <div class="grid grid-cols-1 md:grid-cols-[2fr_3fr] gap-8 items-start">
                  {post.data.cover && (
                    <div class="overflow-hidden rounded-lg aspect-[4/3] bg-soft-green">
                      <Image
                        src={post.data.cover}
                        alt={post.data.coverAlt ?? post.data.title}
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
                        widths={[400, 800]}
                        sizes="(min-width: 768px) 40vw, 100vw"
                      />
                    </div>
                  )}
                  <div class={post.data.cover ? '' : 'md:col-span-2'}>
                    <p class="font-sans text-[11px] tracking-ultra uppercase text-gold/80 mb-3">
                      {dateFormatter.format(post.data.date)} · {post.data.author}
                    </p>
                    <h2 class="font-serif text-2xl md:text-3xl text-ink font-light leading-tight tracking-tight mb-4 group-hover:text-gold transition-colors">
                      {post.data.title}
                    </h2>
                    <p class="font-sans text-base text-ink-mid font-light leading-relaxed mb-4 max-w-xl">
                      {post.data.excerpt}
                    </p>
                    <span class="font-sans text-xs tracking-ultra uppercase text-gold/80 group-hover:text-gold transition-colors">
                      Read the letter →
                    </span>
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</MainLayout>
