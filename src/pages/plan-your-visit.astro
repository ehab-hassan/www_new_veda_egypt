      }
    </style>

    <!-- Itinerary roadmap — scroll driver -->
    <script>
      const itinSec = document.getElementById('itinerary');
      if (itinSec) {
        const track    = document.getElementById('itin-track');
        const strip    = document.getElementById('itin-strip');
        const rows     = Array.from(itinSec.querySelectorAll<HTMLElement>('.itin-row'));
        const dots     = Array.from(itinSec.querySelectorAll<HTMLElement>('.itin-dot'));
        const boat     = document.getElementById('itin-boat');
        const progress = document.getElementById('itin-progress');
        const N = rows.length;
        let cur = -1;

        function place() {
          if (cur < 0 || !dots[cur]) return;
          const c = dots[cur].offsetTop + dots[cur].offsetHeight / 2;
          if (boat) boat.style.top = c + 'px';
          if (progress) progress.style.height = Math.max(0, c - 24) + 'px';
        }
        function setActive(i: number) {
          if (i === cur) return;
          cur = i;
          rows.forEach((r, k) => r.classList.toggle('is-active', k === i));
          place();
        }

        let ticking = false;
        function onScroll() {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            ticking = false;
            if (!track) return;
            const rect = track.getBoundingClientRect();
            const total = rect.height - window.innerHeight;
            let p = total > 0 ? -rect.top / total : 0;
            p = Math.max(0, Math.min(1, p));
            // Scrub the filmstrip continuously with scroll (translate % of strip's own height)
            if (strip) strip.style.transform = `translateY(${(-p * (N - 1) / N) * 100}%)`;
            setActive(Math.round(p * (N - 1)));
          });
        }

        setActive(0);
        window.addEventListener('load', place);
        window.addEventListener('resize', place);
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }
    </script>


