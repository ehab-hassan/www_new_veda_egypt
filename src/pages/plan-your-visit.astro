---
import MainLayout from '../layouts/MainLayout.astro';

const itinerary = [
  {
    day: 'Day 1',
    place: 'Luxor',
    image: '/images/karnak-1280x800.jpg',
    text: 'Luxor offers one of the most exquisite ancient treasures in the world. The Valley of Kings, the legendary temple of Queen Hatshepsut, and Karnak Temple are some of the many jewels to explore in the magic city of Luxor.',
  },
  {
    day: 'Day 2',
    place: 'Karnak · Esna',
    image: '/images/dsc-2186-1280x800.jpg',
    text: 'Esna is a busy little farming town located 55 km south of Luxor, on the west bank of the Nile. The Temple of Khnum, located 9 metres below street level, is one of the highlights. The lively market in Esna is a perfect place to immerse in real Egyptian vibes.',
  },
  {
    day: 'Day 3',
    place: 'Crossing the Lock',
    image: '/images/egypte-veda-490-van-577-2-1280x800.jpg',
    text: 'The Esna Lock connects Esna to Aswan with an elevation difference of approximately eight metres. Crossing the lock is always a very loud and joyful experience — a scenic photo spot for Nile travellers.',
  },
  {
    day: 'Day 4',
    place: 'Esna · Edfu',
    image: '/images/copy-of-egypte-veda-242-van-577-982x614.jpg',
    text: 'Catapult yourself back in time. Watch the countryside with little mud brick houses and observe the crops growing on the fertile Nile land. These paradisiacal views are ideal to relax, leave your worries behind, and become one with nature.',
  },
  {
    day: 'Day 5',
    place: 'Silsila',
    image: '/images/dsc-918-1280x800.jpg',
    text: 'During the 18th dynasty, the Egyptians started using sandstone instead of limestone — Silsila became a vital stone source for famous ancient temples. Next to its powerful energy and ancient vibes, Silsila is uniquely serene because regular boats cannot dock here.',
  },
  {
    day: 'Day 6',
    place: 'Kom Ombo',
    image: '/images/dsc1037-2-1280x800.jpg',
    text: 'Kom Ombo is a temple dedicated to Sobek (the crocodile god) and Haroeris (the winged god of medicine). Crocodiles were worshipped along the Nile and often buried with Pharaohs as protectors in the afterlife. The temple is also known for ancient surgical and dental tools depicted on its walls.',
  },
  {
    day: 'Day 7',
    place: 'Aswan',
    image: '/images/aswan-temple-1280x800.jpg',
    text: "Aswan's most sacred temple is Philae — considered the most precious of all Egypt's temples. Sitting on an island in the middle of the Nile, it is devoted to Isis, Goddess of motherhood. Philae is the last ancient temple built in classical Egyptian architectural style.",
  },
];

const treatments = [
  {
    icon: '◎',
    title: 'Meditation',
    desc: 'Deepen your awareness. Combines ancient temple healing with guided instruction.',
    image: '/images/photo-2019-04-03-08-27-18-3-436x291.jpg',
  },
  {
    icon: '⟡',
    title: 'Yoga',
    desc: 'Sunrise classes on the rooftop deck. Step fully into your body.',
    image: '/images/photo-2019-04-03-08-27-19-436x291.jpg',
  },
  {
    icon: '∿',
    title: 'Massage',
    desc: 'After visiting the ancient healing temples, your body will be grateful. Integrative and restorative.',
    image: '/images/mbr-3-436x291.jpg',
  },
  {
    icon: '❋',
    title: 'Special Diets',
    desc: 'Gluten-free, vegetarian, vegan, and detox options — all prepared with organic, local ingredients.',
    image: '/images/photo-2019-04-03-12-14-26-436x291.jpg',
  },
  {
    icon: '◈',
    title: 'Wellness',
    desc: 'Gym sessions, walks, runs, bike rides, and healing techniques tailored to your energy.',
    image: '/images/photo-2019-04-03-08-27-31-436x291.jpg',
  },
];
---

<MainLayout
  title="Plan Your Visit — VEDA Egypt"
  description="Plan your private Nile journey with VEDA. 7-day itinerary from Luxor to Aswan, wellness treatments, and everything included."
>

  <!-- Hero -->
  <div class="relative bg-void pt-40 pb-28 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/dsc-1797-pano-1280x800.jpg" alt="" class="w-full h-full object-cover object-center opacity-35"/>
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-void/60 via-void/30 to-void"></div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-12 text-center">
      <div class="flex items-center justify-center gap-4 mb-6">
        <span class="h-px w-10 bg-gold/50"></span>
        <p class="font-sans text-[10px] tracking-[0.32em] uppercase text-gold">Your Journey Awaits</p>
        <span class="h-px w-10 bg-gold/50"></span>
      </div>
      <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl text-ivory font-light tracking-tight leading-tight mb-6">
        Plan Your Visit
      </h1>
      <p class="font-serif text-lg md:text-xl text-gold-pale italic font-light max-w-xl mx-auto leading-relaxed">
        "The boat, meals, and crew are included.<br class="hidden md:block"/> The rest is up to you."
      </p>
    </div>
  </div>

  <div class="bg-void">

    <!-- ── Overview cards ─────────────────────────── -->
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-20">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Length of stay -->
        <div class="border border-gold/15 p-8 reveal">
          <p class="font-sans text-[9px] tracking-[0.28em] uppercase text-gold mb-4">Length of Stay</p>
          <p class="font-serif text-4xl text-ivory font-light mb-3">5+ nights</p>
          <p class="font-sans text-sm text-warm-gray font-light leading-relaxed">
            Minimum five nights required. Longer stays are always welcome — the Nile rewards those who linger.
          </p>
        </div>

        <!-- Number of guests -->
        <div class="border border-gold/15 p-8 reveal reveal-delay-1">
          <p class="font-sans text-[9px] tracking-[0.28em] uppercase text-gold mb-4">Number of Guests</p>
          <p class="font-serif text-4xl text-ivory font-light mb-3">4 – 50</p>
          <p class="font-sans text-sm text-warm-gray font-light leading-relaxed">
            The VEDA fleet hosts all types of groups and families, from intimate couples to large retreats.
          </p>
        </div>

        <!-- Flexibility -->
        <div class="border border-gold/15 p-8 reveal reveal-delay-2">
          <p class="font-sans text-[9px] tracking-[0.28em] uppercase text-gold mb-4">Full Flexibility</p>
          <p class="font-serif text-4xl text-ivory font-light mb-3">Your pace</p>
          <p class="font-sans text-sm text-warm-gray font-light leading-relaxed">
            Where you go and what you do is completely flexible. We are happy to provide recommendations tailored to your energy.
          </p>
        </div>
      </div>
    </div>

    <!-- ── 7-Day Itinerary ────────────────────────── -->
    <div class="border-t border-gold/10 py-24">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">

        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16 gap-6">
          <div class="reveal">
            <div class="flex items-center gap-4 mb-5">
              <span class="h-px w-8 bg-gold/40"></span>
              <p class="font-sans text-[9px] tracking-[0.3em] uppercase text-gold/70">Daily Itinerary</p>
            </div>
            <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl text-ivory font-light tracking-tight leading-tight">
              Luxor to<br /><em class="italic text-gold-pale">Aswan</em>
            </h2>
          </div>
          <p class="font-sans text-sm text-warm-gray max-w-xs leading-relaxed reveal reveal-delay-1">
            The VEDA crew guides you to the most impressive and high-energy places along the Nile.
          </p>
        </div>

        <!-- Itinerary rows -->
        <div class="space-y-0">
          {itinerary.map((item, i) => (
            <div class={`group grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-0 border-t border-gold/10 reveal reveal-delay-${Math.min(i, 4)}`}>

              <!-- Image -->
              <div class="relative overflow-hidden" style="aspect-ratio:16/9;">
                <img
                  src={item.image}
                  alt={item.place}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-r from-transparent to-void/60 hidden lg:block"></div>
                <!-- Day badge -->
                <div class="absolute top-4 left-4 bg-void/70 backdrop-blur-sm border border-gold/20 px-3 py-1.5">
                  <p class="font-sans text-[8px] tracking-[0.25em] uppercase text-gold">{item.day}</p>
                </div>
              </div>

              <!-- Content -->
              <div class="bg-forest-mid p-8 lg:p-12 flex flex-col justify-center">
                <p class="font-sans text-[9px] tracking-[0.28em] uppercase text-gold mb-3">{item.day}</p>
                <h3 class="font-serif text-2xl md:text-3xl text-ivory font-light mb-4">{item.place}</h3>
                <div class="h-px w-8 bg-gold/30 mb-5"></div>
                <p class="font-sans text-sm text-warm-gray font-light leading-relaxed">{item.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ── Treatments ─────────────────────────────── -->
    <div class="border-t border-gold/10 py-24">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">

        <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16 gap-6">
          <div class="reveal">
            <div class="flex items-center gap-4 mb-5">
              <span class="h-px w-8 bg-gold/40"></span>
              <p class="font-sans text-[9px] tracking-[0.3em] uppercase text-gold/70">Energy Treatments</p>
            </div>
            <h2 class="font-serif text-4xl md:text-5xl text-ivory font-light tracking-tight leading-tight">
              Connect with<br /><em class="italic text-gold-pale">mind, body & soul</em>
            </h2>
          </div>
          <p class="font-sans text-sm text-warm-gray max-w-xs leading-relaxed reveal reveal-delay-1">
            Make your trip complete and book one of our energy-boosting treatments.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
          {treatments.map((t, i) => (
            <article class={`group relative overflow-hidden rounded-lg bg-forest-mid reveal reveal-delay-${i + 1} flex flex-col`}>
              <div class="relative overflow-hidden" style="aspect-ratio:4/3;">
                <img
                  src={t.image}
                  alt={t.title}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-forest-mid via-forest-mid/30 to-transparent"></div>
              </div>
              <div class="p-5 flex flex-col flex-1">
                <p class="font-sans text-[9px] tracking-[0.28em] uppercase text-gold mb-2">{t.title}</p>
                <p class="font-sans text-xs text-warm-gray font-light leading-relaxed flex-1">{t.desc}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>

    <!-- ── CTA / Contact ──────────────────────────── -->
    <div class="border-t border-gold/10 py-24">
      <div class="max-w-3xl mx-auto px-6 lg:px-12 text-center reveal">
        <div class="flex items-center justify-center gap-4 mb-8">
          <span class="h-px w-10 bg-gold/20"></span>
          <span class="w-1.5 h-1.5 rounded-full bg-gold/30"></span>
          <span class="h-px w-10 bg-gold/20"></span>
        </div>
        <h2 class="font-serif text-3xl md:text-4xl text-ivory font-light mb-4 leading-tight">
          Ready to plan your journey?
        </h2>
        <p class="font-sans text-sm text-warm-gray font-light leading-relaxed mb-10 max-w-md mx-auto">
          Contact us and we'll create a personalised itinerary around your group, dates, and intentions.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="mailto:reservation@veda-egypt.com"
            class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-white font-sans text-[10px] tracking-[0.22em] uppercase px-7 py-3.5 transition-all duration-300"
          >
            Request Itinerary →
          </a>
          <a
            href="/dahabiyas"
            class="inline-flex items-center gap-2 border border-gold/40 hover:border-gold text-gold/80 hover:text-gold font-sans text-[10px] tracking-[0.22em] uppercase px-7 py-3.5 transition-all duration-300 hover:bg-gold/5"
          >
            View Our Fleet →
          </a>
        </div>
        <div class="mt-10 flex flex-col items-center gap-1">
          <a href="mailto:info@veda-egypt.com" class="font-sans text-xs text-warm-gray/60 hover:text-gold transition-colors">info@veda-egypt.com</a>
          <a href="mailto:reservation@veda-egypt.com" class="font-sans text-xs text-warm-gray/60 hover:text-gold transition-colors">reservation@veda-egypt.com</a>
        </div>
      </div>
    </div>

  </div>

</MainLayout>
