---
import MainLayout from '../layouts/MainLayout.astro';

const treatments = [
  {
    icon: '◎',
    title: 'Meditation',
    desc: 'Deepen your awareness. Combines ancient temple healing with guided instruction.',
    image: '/images/photo-2019-04-03-08-27-18-3-436x291.jpg',
  },
  {
    icon: '⟡',
    title: 'Yoga',
    desc: 'Sunrise classes on the rooftop deck. Step fully into your body.',
    image: '/images/photo-2019-04-03-08-27-19-436x291.jpg',
  },
  {
    icon: '∿',
    title: 'Massage',
    desc: 'After visiting the ancient healing temples, your body will be grateful. Integrative and restorative.',
    image: '/images/mbr-3-436x291.jpg',
  },
  {
    icon: '❋',
    title: 'Special Diets',
    desc: 'Gluten-free, vegetarian, vegan, and detox options — all prepared with organic, local ingredients.',
    image: '/images/photo-2019-04-03-12-14-26-436x291.jpg',
  },
  {
    icon: '◈',
    title: 'Wellness',
    desc: 'Gym sessions, walks, runs, bike rides, and healing techniques tailored to your energy.',
    image: '/images/photo-2019-04-03-08-27-31-436x291.jpg',
  },
];

// Itinerary roadmap — the six Nile stops between Luxor and Aswan
const journey = [
  {
    day: 'Day 01',
    name: 'Luxor',
    image: '/images/aswan-temple-1280x8000.jpg',
    desc: 'Arrival into the heart of the Valley of the Kings. Luxor holds some of the world’s most exquisite ancient treasures — the Valley of the Kings, the temple of Queen Hatshepsut, and the vast Karnak Temple.',
  },
  {
    day: 'Day 02 — 03',
    name: 'Esna',
    image: '/images/egypte-veda-490-van-577-2-1280x8001.jpg',
    desc: 'A busy little farming town 55 km south of Luxor. The Temple of Khnum sits nine metres below street level, and the lively market is the perfect place to immerse in real Egyptian life.',
  },
  {
    day: 'Day 04',
    name: 'Edfu',
    image: '/images/photo-2019-03-23-11.23.56-1280x8002.jpg',
    desc: 'Sail past mud-brick villages and fertile fields between Esna and Edfu. These paradisiacal views are ideal to relax, leave your worries behind, and become one with nature.',
  },
  {
    day: 'Day 05',
    name: 'Gebel el-Silsila',
    image: '/images/dsc-918-1280x800.jpg',
    desc: 'An important sandstone source for many famous ancient temples. Beyond its powerful energy and old vibes, Silsila is wonderfully serene — regular boats cannot park there.',
  },
  {
    day: 'Day 06',
    name: 'Kom Ombo',
    image: '/images/egypte-veda-248-van-577-2-1280x8003.jpg',
    desc: 'A unique double temple dedicated to Sobek, the crocodile god, and Haroeris. Its walls famously depict ancient surgical and dental instruments.',
  },
  {
    day: 'Day 07',
    name: 'Aswan',
    image: '/images/photo-2019-03-21-12.50.06-1280x854.jpg',
    desc: 'Aswan and its most sacred temple, Philae, sit on an island in the middle of the Nile. Devoted to Isis, goddess of motherhood, it is the last temple built in classical Egyptian style.',
  },
];
---

<MainLayout
  title="Plan Your Visit — VEDA Egypt"
  description="Plan your private Nile journey with VEDA. 7-day itinerary from Luxor to Aswan, wellness treatments, and everything included."
>

  <!-- Hero — dark image banner (matches home & dahabiyas) -->
  <div class="relative flex items-center min-h-[72vh] pt-40 pb-28 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/dsc-1797-pano-1280x800.jpg" alt="" width="1280" height="800" class="w-full h-full object-cover object-center" loading="eager"/>
    </div>
    <!-- Dark overlays for legibility -->
    <div class="absolute inset-0 bg-void/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-void/50 via-transparent to-void/75"></div>
    <div class="relative w-full max-w-7xl mx-auto px-6 lg:px-12 text-center">
      <div class="flex items-center justify-center gap-4 mb-6">
        <span class="h-px w-10 bg-gold-light/60"></span>
        <p class="font-sans text-[14px] tracking-[0.32em] uppercase text-gold-light">Your Journey Awaits</p>
        <span class="h-px w-10 bg-gold-light/60"></span>
      </div>
      <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl text-white font-light tracking-tight leading-tight mb-6"
        style="text-shadow: 0 2px 28px rgba(0,0,0,0.45);">
        Plan Your Visit
      </h1>
      <p class="font-serif text-lg md:text-xl lg:text-2xl text-gold-pale italic font-light max-w-xl mx-auto leading-relaxed">
        "The boat, meals, and crew are included.<br class="hidden md:block"/> The rest is up to you."
      </p>
    </div>
  </div>

  <!-- ── Overview cards ─────────────────────────── -->
  <section class="bg-linen py-24 lg:py-32 border-t border-bone">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Length of stay -->
        <div class="border border-bone bg-sand rounded-xl p-8 reveal">
          <p class="font-sans text-[12px] tracking-[0.28em] uppercase text-gold mb-4">Length of Stay</p>
          <p class="font-serif text-4xl text-earth font-light mb-3">5+ nights</p>
          <p class="font-sans text-base text-sandstone font-light leading-relaxed">
            Minimum five nights required. Longer stays are always welcome — the Nile rewards those who linger.
          </p>
        </div>

        <!-- Number of guests -->
        <div class="border border-bone bg-sand rounded-xl p-8 reveal reveal-delay-1">
          <p class="font-sans text-[12px] tracking-[0.28em] uppercase text-gold mb-4">Number of Guests</p>
          <p class="font-serif text-4xl text-earth font-light mb-3">4 – 50</p>
          <p class="font-sans text-base text-sandstone font-light leading-relaxed">
            The VEDA fleet hosts all types of groups and families, from intimate couples to large retreats.
          </p>
        </div>

        <!-- Flexibility -->
        <div class="border border-bone bg-sand rounded-xl p-8 reveal reveal-delay-2">
          <p class="font-sans text-[12px] tracking-[0.28em] uppercase text-gold mb-4">Full Flexibility</p>
          <p class="font-serif text-4xl text-earth font-light mb-3">Your pace</p>
          <p class="font-sans text-base text-sandstone font-light leading-relaxed">
            Where you go and what you do is completely flexible. We are happy to provide recommendations tailored to your energy.
          </p>
        </div>
      </div>
    </div>
  </section>

    <!-- ── Nile Journey: Cinematic Scroll ──────────── -->

    <!-- Section header (scrolls normally above sticky viewport) -->
    <div class="border-t border-gold/10 py-20 relative z-10" style="background:#070b07;">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
          <div class="reveal">
            <div class="flex items-center gap-4 mb-5">
              <span class="h-px w-8 bg-gold/40"></span>
              <p class="font-sans text-[12px] tracking-[0.3em] uppercase text-gold/70">Daily Itinerary</p>
            </div>
            <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl text-ivory font-light tracking-tight leading-tight">
              Luxor to<br /><em class="italic text-gold-pale">Aswan</em>
            </h2>
          </div>
          <p class="font-sans text-sm text-warm-gray max-w-xs leading-relaxed reveal reveal-delay-1">
            The VEDA crew guides you to the most impressive and high-energy places along the Nile.
          </p>
        </div>
      </div>
    </div>

    <!-- Cinematic scroll container (300vh gives smooth travel through 6 stops) -->
    <div id="nile-journey-scroll" class="relative" style="height:300vh; background:#070b07;">

      <!-- Sticky viewport — river + boat + text live here -->
      <div id="nile-sticky" class="sticky top-0 overflow-hidden" style="height:100dvh;">

        <!-- River background -->
        <img
          src="/images/top_river2.jpg"
          alt="Aerial view of the Nile river"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />

        <!-- Dark base overlay (makes river significantly darker) -->
        <div class="absolute inset-0 pointer-events-none" style="background:rgba(4,16,14,0.62);"></div>
        <!-- Gradient overlay: heavy at top for nav, heavy at bottom -->
        <div class="absolute inset-0 pointer-events-none" style="background:linear-gradient(to bottom, rgba(7,11,7,0.90) 0%, rgba(7,11,7,0.35) 15%, rgba(7,11,7,0.20) 45%, rgba(7,11,7,0.35) 85%, rgba(7,11,7,0.92) 100%);"></div>

        <!-- Solid vertical path line — CSS gradient, no SVG distortion -->
        <div class="absolute pointer-events-none" aria-hidden="true"
          style="left:50%;top:0;height:100%;width:2px;transform:translateX(-50%);z-index:11;
                 background:linear-gradient(to bottom, transparent 0%, #c9a85c 8%, #c9a85c 50%, #4ab8c8 92%, transparent 100%);
                 opacity:0.20;"></div>

        <!-- Stop nodes — div circles, always perfectly round -->
        <div class="absolute inset-0 pointer-events-none" style="z-index:12;" aria-hidden="true">
          <div class="absolute rounded-full pnode" style="left:50%;top:14%;width:9px;height:9px;transform:translate(-50%,-50%);border:1.5px solid #c9a85c;opacity:0.90;"></div>
          <div class="absolute rounded-full pnode" style="left:50%;top:28%;width:7px;height:7px;transform:translate(-50%,-50%);border:1px solid #c9a85c;opacity:0.65;"></div>
          <div class="absolute rounded-full pnode" style="left:50%;top:42%;width:7px;height:7px;transform:translate(-50%,-50%);border:1px solid #c9a85c;opacity:0.65;"></div>
          <div class="absolute rounded-full pnode" style="left:50%;top:56%;width:7px;height:7px;transform:translate(-50%,-50%);border:1px solid #4ab8c8;opacity:0.65;"></div>
          <div class="absolute rounded-full pnode" style="left:50%;top:70%;width:7px;height:7px;transform:translate(-50%,-50%);border:1px solid #4ab8c8;opacity:0.65;"></div>
          <div class="absolute rounded-full pnode" style="left:50%;top:84%;width:9px;height:9px;transform:translate(-50%,-50%);border:1.5px solid #4ab8c8;opacity:0.90;"></div>
        </div>

        <!-- Boat (top-view PNG), positioned + animated by JS -->
        <div id="journey-boat-wrap"
          class="absolute z-20 pointer-events-none"
          style="width:72px; left:50%; top:15%; filter:drop-shadow(0 10px 22px rgba(0,0,0,0.75));">
          <img src="/images/boat2.png" alt="" aria-hidden="true" class="w-full h-auto" />
        </div>

        <!-- ── Content blocks: guide-image layout — day+name LEFT · description RIGHT ── -->
        <!-- Each block is full-width and positioned at the same y as its path node.     -->
        <!-- JS sets opacity:0 on init; graceful fallback shows all if GSAP fails.       -->

        <!-- Block 1 — Luxor at 14% -->
        <div class="journey-block absolute z-30 pointer-events-none" style="left:0;right:0;top:30%;transform:translateY(-50%);" data-stop="0">
          <div style="display:flex;align-items:center;padding:0 4%;">
            <div style="flex:1;text-align:right;padding-right:36px;">
              <p class="font-sans text-[12px] tracking-[0.35em] uppercase text-gold" style="margin-bottom:4px;">Day 01</p>
              <h3 class="font-serif text-ivory font-light leading-tight" style="font-size:clamp(1.4rem,3vw,2.2rem);">Luxor</h3>
            </div>
            <div style="width:60px;flex-shrink:0;"></div>
            <div style="flex:1;padding-left:36px;">
              <img src="/images/aswan-temple-1280x8000.jpg" alt="Luxor" class="journey-thumb rounded-md" />
              <p class="font-sans text-ivory/90 font-light leading-relaxed" style="font-size:14px;margin-top:8px;">Arrival into the heart of the Valley of the Kings.</p>
              <p class="max-w-xl font-sans text-ivory/90 font-light leading-relaxed" style="font-size:14px;margin-top:8px;">Luxor offers one of the most exquisite ancient treasures in the world.
                The Valley of Kings, the legend temple of Queen Hatshepsut, and Karnak Temple are some of the many jewels to explore in the magic city of Luxor..</p>
            </div>
          </div>
        </div>

        <!-- Block 2 — Esna at 28% -->
        <div class="journey-block absolute z-30 pointer-events-none" style="left:0;right:0;top:28%;transform:translateY(-50%);" data-stop="1">
          <div style="display:flex;align-items:center;padding:0 4%;">
            <div style="flex:1;text-align:right;padding-right:36px;">
              <p class="font-sans text-[12px] tracking-[0.35em] uppercase text-gold" style="margin-bottom:4px;">Day 02 — 03</p>
              <h3 class="font-serif text-ivory font-light leading-tight" style="font-size:clamp(1.4rem,3vw,2.2rem);">Esna</h3>
            </div>
            <div style="width:60px;flex-shrink:0;"></div>
            <div style="flex:1;padding-left:36px;">
              <img src="/images/egypte-veda-490-van-577-2-1280x8001.jpg" alt="Esna" class="journey-thumb rounded-md" />
              <p class="max-w-xl font-sans text-ivory/90 font-light leading-relaxed" style="font-size:14px;margin-top:8px;">Esna is a busy little farming town located 55 km south of Luxor, on the west bank of the Nile.
              <br>
                The Temple of Khnum, located 9 meter below street level, is one of the highlights in Esna. The lively tourist-oriented market in Esna is a perfect place to immerse in real Egyptian vibes.</p>
            </div>
          </div>
        </div>

        <!-- Block 3 — Edfu at 42% -->
        <div class="journey-block absolute z-30 pointer-events-none" style="left:0;right:0;top:42%;transform:translateY(-50%);" data-stop="2">
          <div style="display:flex;align-items:center;padding:0 4%;">
            <div style="flex:1;text-align:right;padding-right:36px;">
              <p class="font-sans text-[12px] tracking-[0.35em] uppercase text-gold" style="margin-bottom:4px;">Day 04</p>
              <h3 class="font-serif text-ivory font-light leading-tight" style="font-size:clamp(1.4rem,3vw,2.2rem);">Edfu</h3>
            </div>
            <div style="width:60px;flex-shrink:0;"></div>
            <div style="flex:1;padding-left:36px;">
              <img src="/images/photo-2019-03-23-11.23.56-1280x8002.jpg" alt="Edfu" class="journey-thumb rounded-md" />
              <p class="max-w-xl font-sans text-ivory/90 font-light leading-relaxed" style="font-size:14px;margin-top:8px;">Catapult yourself back in time. Watch the countryside with little mud brick houses and observe the crops growing on the fertile land of the Nile while sailing between Edfu and Esna.
                <br>
                These paradisiacal views are ideal to relax, leave your worries behind, and become one with nature.</p>
            </div>
          </div>
        </div>

        <!-- Block 4 — Silsila at 56% -->
        <div class="journey-block absolute z-30 pointer-events-none" style="left:0;right:0;top:56%;transform:translateY(-50%);" data-stop="3">
          <div style="display:flex;align-items:center;padding:0 4%;">
            <div style="flex:1;text-align:right;padding-right:36px;">
              <p class="font-sans text-[12px] tracking-[0.35em] uppercase text-gold" style="margin-bottom:4px;">Day 05</p>
              <h3 class="font-serif text-ivory font-light leading-tight" style="font-size:clamp(1.4rem,3vw,2.2rem);">Silsila</h3>
            </div>
            <div style="width:60px;flex-shrink:0;"></div>
            <div style="flex:1;padding-left:36px;">
              <img src="/images/dsc-918-1280x800.jpg" alt="Silsila" class="journey-thumb rounded-md" />
              <p class="max-w-xl font-sans text-ivory/90 font-light leading-relaxed" style="font-size:14px;margin-top:8px;">During the 18th dynasty, the Egyptians started using sandstone instead of limestones. Gebel el-Silsila became an important stone source for several famous ancient Egyptians temples.
                <br>
                Next to the extremely powerful energy and old vibes,
                Silsila is a very serene spot because regular boats can not park there.</p>
            </div>
          </div>
        </div>

        <!-- Block 5 — Kom Ombo at 70% -->
        <div class="journey-block absolute z-30 pointer-events-none" style="left:0;right:0;top:70%;transform:translateY(-50%);" data-stop="4">
          <div style="display:flex;align-items:center;padding:0 4%;">
            <div style="flex:1;text-align:right;padding-right:36px;">
              <p class="font-sans text-[12px] tracking-[0.35em] uppercase text-gold" style="margin-bottom:4px;">Day 06</p>
              <h3 class="font-serif text-ivory font-light leading-tight" style="font-size:clamp(1.4rem,3vw,2.2rem);">Kom Ombo</h3>
            </div>
            <div style="width:60px;flex-shrink:0;"></div>
            <div style="flex:1;padding-left:36px;">
              <img src="/images/egypte-veda-248-van-577-2-1280x8003.jpg" alt="Kom Ombo" class="journey-thumb rounded-md" />
              <p class="max-w-xl font-sans text-ivory/90 font-light leading-relaxed" style="font-size:14px;margin-top:8px;">Kom Ombo is a temple dedicated to the god Sobek (the crocodile god)
                and Haroeris (the winged god of medicine and one of the oldest incarnations of Horus).
                <br>
                Crocodiles were worshipped at many cult-sites,  from Qasr Qaroun in the Fayoum to Kom Ombo,  and were often buried with Pharaohs as it was believed that they would protect them in the afterlife.
                <br>
                Kom Ombo temple is also known for its wall relieves showing ancient surgical and dental tools. </p>
            </div>
          </div>
        </div>

        <!-- Block 6 — Aswan at 84% -->
        <div class="journey-block absolute z-30 pointer-events-none" style="left:0;right:0;top:68%;transform:translateY(-50%);" data-stop="5">
          <div style="display:flex;align-items:center;padding:0 4%;">
            <div style="flex:1;text-align:right;padding-right:36px;">
              <p class="font-sans text-[12px] tracking-[0.35em] uppercase text-gold" style="margin-bottom:4px;">Day 07</p>
              <h3 class="font-serif text-ivory font-light leading-tight" style="font-size:clamp(1.4rem,3vw,2.2rem);">Aswan</h3>
            </div>
            <div style="width:60px;flex-shrink:0;"></div>
            <div style="flex:1;padding-left:36px;">
              <img src="/images/photo-2019-03-21-12.50.06-1280x854.jpg" alt="Aswan" class="journey-thumb rounded-md" />
              <p class="max-w-xl font-sans text-ivory/90 font-light leading-relaxed" style="font-size:14px;margin-top:8px;">Aswan’s most sacred temple is Philae. It is considered the most precious of all Egypt’s temples. She sits on an island plopped in the middle of the Nile, only reachable by small motorboat.
               <br>
                The Ptolemaic (Graeco-Roman) era temple is devoted to Isis, the Goddess of motherhood. Philae is the last ancient temple built in classical Egyptian architectural style.
                <br>
                The temple was moved from its original location on Philae Island to its new location on Agilkia Island after the flooding of Lake Nasser.</p>
            </div>
          </div>
        </div>

        <!-- Scroll hint (fades out once scrolling begins) -->
        <div id="nile-scroll-hint" class="absolute bottom-8 left-1/2 -translate-x-1/2 z-30 flex flex-col items-center gap-2 pointer-events-none">
          <p class="font-sans text-[9px] tracking-[0.3em] uppercase text-ivory/28">Scroll</p>
          <div class="w-px h-8 relative overflow-hidden">
            <div class="nile-hint-drop absolute top-0 left-0 w-full bg-gold/45" style="height:50%;"></div>
          </div>
        </div>

      </div><!-- /sticky -->
    </div><!-- /cinematic scroll -->

    <!-- Cinematic Nile Journey — styles ──────────────────── -->
    <style>
      /* Scroll hint drop line */
      .nile-hint-drop {
        animation: hintDrop 1.8s ease-in-out infinite;
      }
      @keyframes hintDrop {
        0%   { top: -50%; }
        100% { top: 150%; }
      }

      /* Boat wrapper: GSAP drives left/top; floating uses y transform */
      #journey-boat-wrap { will-change: left, top; }

      /* Hide blocks immediately via CSS — GSAP reveals them at the right scroll position.
         Prevents flash of content while GSAP loads from CDN. */
      .journey-block { opacity: 0; }

      /* Stop thumbnail images */
      .journey-thumb {
        display: block;
        width: clamp(160px, 26vw, 360px);
        aspect-ratio: 16 / 9;
        object-fit: cover;
        opacity: 0.80;
        border: 1px solid rgba(201,168,92,0.20);
      }

      /* Mobile: stacked centered card at bottom of viewport */
      @media (max-width: 767px) {
        .journey-block {
          left: 50% !important;
          right: auto !important;
          top: 64% !important;
          transform: translate(-50%, -50%) !important;
          width: 86vw;
          background: rgba(4, 12, 8, 0.82);
          backdrop-filter: blur(10px);
          -webkit-backdrop-filter: blur(10px);
          border: 1px solid rgba(201,168,92,0.15);
          border-radius: 8px;
          padding: 16px;
        }
        /* Inner flex → column, centered */
        .journey-block > div {
          flex-direction: column !important;
          align-items: center !important;
          padding: 0 !important;
          gap: 10px;
          text-align: center;
        }
        /* Left panel: day + name */
        .journey-block > div > div:first-child {
          text-align: center !important;
          padding-right: 0 !important;
        }
        /* Spacer div: hide */
        .journey-block > div > div:nth-child(2) {
          display: none !important;
        }
        /* Right panel: image + text */
        .journey-block > div > div:last-child {
          padding-left: 0 !important;
          width: 100%;
          text-align: center;
        }
        /* Image: full width */
        .journey-thumb {
          width: 100% !important;
          max-width: 100% !important;
        }
        /* Hide the long second paragraph — keep only short intro line */
        .journey-block .max-w-xl {
          display: none !important;
        }
        .journey-block h3 { font-size: 1.4rem !important; }
        .journey-block p  { font-size: 0.75rem !important; line-height: 1.5 !important; }
      }

      /* Reduced motion */
      @media (prefers-reduced-motion: reduce) {
        .nile-hint-drop  { animation: none !important; }
        .journey-block   { opacity: 1 !important; transform: none !important; }
      }
    </style>

    <!-- Cinematic Nile Journey: GSAP scroll animation -->
    <script is:inline>
    (function () {
      function loadScript(src) {
        return new Promise(function (resolve, reject) {
          var s = document.createElement('script');
          s.src = src; s.onload = resolve; s.onerror = reject;
          document.head.appendChild(s);
        });
      }

      loadScript('https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js')
        .then(function () { return loadScript('https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js'); })
        .then(initJourney)
        .catch(function () {
          document.querySelectorAll('.journey-block').forEach(function (b) {
            b.style.opacity = '1'; b.style.transform = 'none';
          });
        });

      function initJourney() {
        gsap.registerPlugin(ScrollTrigger);
        var isMobile = window.matchMedia('(max-width: 767px)').matches;
        var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var container = document.getElementById('nile-journey-scroll');
        var boatWrap  = document.getElementById('journey-boat-wrap');
        var blocks    = document.querySelectorAll('.journey-block');
        var hint      = document.getElementById('nile-scroll-hint');
        if (!container || !boatWrap) return;
        if (reducedMotion) {
          blocks.forEach(function (b) { b.style.opacity = '1'; b.style.transform = 'none'; });
          return;
        }
        blocks.forEach(function (b) { gsap.set(b, { opacity: 0 }); });

        var waypoints = [
          { p: 0.00, x: 0, y: 14 },  // start — boat visible at Luxor
          { p: 0.06, x: 0, y: 14 },  // short dwell — boat rests briefly then moves
          { p: 0.26, x: 0, y: 28 },  // → Esna
          { p: 0.38, x: 0, y: 42 },  // → Edfu
          { p: 0.52, x: 0, y: 56 },  // → Silsila
          { p: 0.65, x: 0, y: 70 },  // → Kom Ombo
          { p: 0.78, x: 0, y: 84 },  // → Aswan
          { p: 1.00, x: 0, y: 93 },  // drift off
        ];
        var stopRanges = [
          { show: 0.15, hide: 0.23 },  // Luxor
          { show: 0.26, hide: 0.36 },  // Esna
          { show: 0.38, hide: 0.50 },  // Edfu
          { show: 0.52, hide: 0.63 },  // Silsila
          { show: 0.65, hide: 0.76 },  // Kom Ombo
          { show: 0.78, hide: 1.00 },  // Aswan
        ];
        // Set centering once — never touch xPercent/yPercent again in the scroll loop
        gsap.set(boatWrap, { xPercent: -50, yPercent: -50 });
        if (!isMobile) {
          gsap.to(boatWrap, { y: -9, duration: 2.8, ease: 'sine.inOut', yoyo: true, repeat: -1 });
        }
        var hintFaded = false;

        function updateScene(progress) {
          if (!hintFaded && progress > 0.01 && hint) {
            gsap.to(hint, { opacity: 0, duration: 0.6, ease: 'power2.out' });
            hintFaded = true;
          }
          var segIdx = 0;
          for (var i = 0; i < waypoints.length - 1; i++) {
            if (progress <= waypoints[i + 1].p) { segIdx = i; break; }
            segIdx = waypoints.length - 2;
          }
          var from = waypoints[segIdx];
          var to   = waypoints[Math.min(segIdx + 1, waypoints.length - 1)];
          var span = to.p - from.p;
          var t    = span === 0 ? 0 : Math.max(0, Math.min(1, (progress - from.p) / span));
          var ease = t * t * (3 - 2 * t);
          var x = from.x + (to.x - from.x) * ease;
          var y = from.y + (to.y - from.y) * ease;
          // Update position via DOM — keeps GSAP's transform state (xPercent/yPercent/y float) untouched
          boatWrap.style.left = isMobile ? '50%' : 'calc(50% + ' + x.toFixed(1) + 'px)';
          boatWrap.style.top  = y.toFixed(2) + '%';
          blocks.forEach(function (block, i) {
            if (i >= stopRanges.length) return;
            var r = stopRanges[i];
            var fadeIn = 0.02, fadeOut = 0.02, op;
            if (progress < r.show) { op = 0; }
            else if (progress < r.show + fadeIn) { op = (progress - r.show) / fadeIn; }
            else if (progress < r.hide - fadeOut) { op = 1; }
            else if (progress <= r.hide) { op = 1 - (progress - (r.hide - fadeOut)) / fadeOut; }
            else { op = 0; }
            gsap.set(block, { opacity: op });
          });
        }

        ScrollTrigger.create({
          trigger: container,
          start: 'top top',
          end: 'bottom bottom',
          onUpdate: function (self) { updateScene(self.progress); },
          // Fires when ScrollTrigger recalculates positions (e.g. after browser scroll restore on refresh)
          onRefresh: function (self) { updateScene(self.progress); },
        });

        // After full page load, refresh ScrollTrigger so it recalculates bounds after
        // the browser has restored scroll position from a page refresh, then immediately
        // sync the scene to the correct progress.
        window.addEventListener('load', function () {
          ScrollTrigger.refresh();
        });
      }
    })();
    </script>


