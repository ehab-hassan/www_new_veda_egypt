            <article class={`group relative overflow-hidden rounded-lg bg-forest reveal reveal-delay-${i + 1} flex flex-col`}>
              <div class="relative overflow-hidden" style="aspect-ratio:4/3;">
                <img
                  src={t.image}
                  alt={t.title}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-forest via-forest/30 to-transparent"></div>
              </div>
              <div class="p-5 flex flex-col flex-1">
                <p class="font-sans text-[12px] tracking-[0.28em] uppercase text-gold mb-2">{t.title}</p>
                <p class="font-sans text-base text-white/70 font-light leading-5 flex-1">{t.desc}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>

