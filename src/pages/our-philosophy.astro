---
import MainLayout from '../layouts/MainLayout.astro';

const beliefs = [
  'Privacy creates connection.',
  'Authenticity is more meaningful than excess.',
  "Time is one of life's greatest luxuries — not because it is expensive, but because it is precious.",
  'Genuine hospitality is expressed through thoughtfulness rather than formality, through anticipation rather than reaction, and through sincere human connection rather than scripted service.',
];

const confidence = [
  'That every client entrusted to us will be welcomed with genuine care.',
  'That every journey will reflect the quality of your own brand.',
  'That you are working with a partner who believes lasting relationships are built on trust, consistency, and shared values.',
];
---

<MainLayout
  title="Our Philosophy — VEDA Egypt"
  description="Hospitality with intention. Back to Gaia is a boutique, owner-operated Dahabeya company on the Nile — crafting private charters remembered for all the right reasons, and a dependable B2B partner for travel operators."
>

  <!-- Hero -->
  <div class="relative flex items-center min-h-[62vh] pt-40 pb-24 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/who_we.jpg" alt="" width="1280" height="800" class="w-full h-full object-cover object-center" loading="eager" />
    </div>
    <div class="absolute inset-0 bg-void/55"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-void/55 via-transparent to-void/80"></div>
    <div class="relative w-full max-w-3xl mx-auto px-6 lg:px-12 text-center">
      <div class="flex items-center justify-center gap-4 mb-6">
        <span class="h-px w-10 bg-gold-light/60"></span>
        <p class="font-sans text-[14px] tracking-[0.32em] uppercase text-gold-light">Back to Gaia</p>
        <span class="h-px w-10 bg-gold-light/60"></span>
      </div>
      <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl text-white font-light tracking-tight leading-tight mb-5"
        style="text-shadow: 0 2px 28px rgba(0,0,0,0.45);">
        Our Philosophy
      </h1>
      <p class="font-serif text-xl md:text-2xl text-gold-pale italic font-light max-w-xl mx-auto leading-relaxed">
        Hospitality with intention.
      </p>
    </div>
  </div>

  <!-- ── A Different Way to Experience the Nile ─────────────────── -->
  <section class="bg-linen border-t border-bone py-20 lg:py-28">
    <div class="max-w-3xl mx-auto px-6 lg:px-12">
      <div class="text-center mb-12 reveal">
        <div class="flex items-center justify-center gap-4 mb-5">
          <span class="h-px w-8 bg-gold/50"></span>
          <p class="font-sans text-[12px] tracking-[0.3em] uppercase text-gold">Your Boutique B2B Nile Charter Partner</p>
          <span class="h-px w-8 bg-gold/50"></span>
        </div>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl text-earth font-light tracking-tight leading-tight">
          A Different Way to Experience the Nile
        </h2>
      </div>

      <div class="space-y-6 font-sans text-[17px] text-earth-mid font-light leading-[1.85] reveal reveal-delay-1">
        <p>
          At Back to Gaia, we believe that the most memorable journeys are not defined by extravagance, but by
          intention. A thoughtfully prepared meal. A quiet sunrise over the Nile. An unexpected stop at a riverside
          village. A crew who remembers every guest by name. These are the moments that transform a journey into a
          lasting memory.
        </p>
        <p>
          Back to Gaia is a boutique Egyptian company based in Cairo, supported by Belgian ownership and dedicated
          exclusively to private Dahabeya charters. As the owners and operators of our fleet — VEDA 1, VEDA 2, VEDA 3,
          and VEDA 4 — we personally oversee every aspect of the guest experience, from the condition of our vessels
          and the professionalism of our crew to the quality of every meal served on board.
        </p>
        <p>
          Today's discerning traveler is seeking something different — privacy over crowds, authenticity over excess,
          and meaningful experiences over hurried sightseeing. Our private Dahabeya charters offer exactly that: guests
          travel at the gentle rhythm of the Nile, sailing beyond the busy cruise routes to discover ancient temples,
          timeless landscapes, and authentic encounters that larger vessels simply cannot offer.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Hospitality with Intention (the philosophy) ───────────── -->
  <section class="bg-sand border-t border-bone py-20 lg:py-28">
    <div class="max-w-3xl mx-auto px-6 lg:px-12">
      <div class="text-center mb-12 reveal">
        <div class="flex items-center justify-center gap-4 mb-5">
          <span class="h-px w-8 bg-gold/50"></span>
          <p class="font-sans text-[12px] tracking-[0.3em] uppercase text-gold">What We Believe</p>
          <span class="h-px w-8 bg-gold/50"></span>
        </div>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl text-earth font-light tracking-tight leading-tight">
          Hospitality with Intention
        </h2>
      </div>

      <div class="space-y-6 font-sans text-[17px] text-earth-mid font-light leading-[1.85] reveal reveal-delay-1">
        <p>
          At Back to Gaia, we believe that exceptional hospitality is never accidental. It is created through intention.
          Every decision we make, every detail we consider, and every experience we design has a purpose: to create
          meaningful journeys that remain with our guests long after they have returned home.
        </p>
      </div>
    </div>

    <!-- Pull-quote -->
    <div class="max-w-4xl mx-auto px-6 lg:px-12 my-14 reveal">
      <blockquote class="relative text-center border-y border-gold/25 py-12">
        <p class="font-serif text-2xl md:text-3xl lg:text-[2.1rem] text-earth font-light italic leading-[1.4]">
          True hospitality is not measured by the size of a building, the elegance of a vessel, or the extravagance of
          its surroundings. It is measured by the feeling a guest carries with them when they leave.
        </p>
      </blockquote>
    </div>

    <div class="max-w-3xl mx-auto px-6 lg:px-12">
      <p class="font-sans text-[17px] text-earth-mid font-light leading-[1.85] mb-10 reveal">
        That simple belief guides everything we do. It shapes the way we welcome our guests, the way our crew cares for
        them, the meals our chefs prepare, the places we choose to visit, and the pace at which we explore the Nile.
      </p>

      <!-- Beliefs -->
      <ul class="space-y-4 mb-10">
        {beliefs.map((b, i) => (
          <li class={`flex items-start gap-4 border border-bone bg-linen rounded-2xl px-6 py-5 reveal reveal-delay-${(i % 3) + 1}`}>
            <span class="font-serif text-2xl text-gold font-light leading-none flex-shrink-0 mt-0.5">We believe</span>
            <span class="font-sans text-[16px] text-earth-mid font-light leading-relaxed">{b}</span>
          </li>
        ))}
      </ul>

      <div class="space-y-6 font-sans text-[17px] text-earth-mid font-light leading-[1.85] reveal">
        <p>
          As owners and operators of our Dahabeya fleet, we have the privilege and the responsibility of shaping every
          aspect of the guest experience. There are no intermediaries between our promise and its delivery. Every
          journey reflects our own standards, our own values, and our personal commitment to excellence.
        </p>
        <p>
          Our guests do not simply travel between Luxor and Aswan. They experience the Nile at its natural rhythm. They
          share conversations with our crew, discover places that larger vessels often pass by, enjoy meals prepared
          with care, and sail through landscapes that have changed little for centuries. These are not simply moments
          within an itinerary — they become memories.
        </p>
      </div>
    </div>
  </section>

  <!-- ── For Our Travel Partners (B2B) ─────────────────────────── -->
  <section id="partners" class="relative overflow-hidden border-t border-gold/10 scroll-mt-24" style="background:#0e1a0e;">
    <div class="max-w-5xl mx-auto px-6 lg:px-12 py-20 lg:py-28">
      <div class="text-center mb-12 reveal">
        <div class="flex items-center justify-center gap-4 mb-5">
          <span class="h-px w-8 bg-gold/50"></span>
          <p class="font-sans text-[12px] tracking-[0.3em] uppercase text-gold-light">For Our Travel Partners</p>
          <span class="h-px w-8 bg-gold/50"></span>
        </div>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl text-ivory font-light tracking-tight leading-tight mb-4">
          A partnership built on confidence
        </h2>
        <p class="font-sans text-base text-warm-gray font-light max-w-2xl mx-auto leading-relaxed">
          For our travel partners, this philosophy offers something equally valuable: confidence.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-14">
        {confidence.map((c, i) => (
          <div class={`border border-white/10 rounded-2xl p-7 reveal reveal-delay-${i + 1}`}>
            <p class="font-serif text-xl text-gold-light font-light mb-3">Confidence</p>
            <p class="font-sans text-[15px] text-ivory/80 font-light leading-relaxed">{c}</p>
          </div>
        ))}
      </div>

      <div class="max-w-3xl mx-auto space-y-6 font-sans text-[17px] text-ivory/80 font-light leading-[1.85] text-center reveal">
        <p>
          For tour operators, Back to Gaia is more than a supplier. We are a dedicated B2B partner, committed to helping
          you differentiate your portfolio with an experience that is authentic, dependable, and intentionally designed.
          Because we own and manage every aspect of our operation, we offer the operational confidence, flexibility, and
          personal attention that today's travelers — and the professionals who serve them — expect.
        </p>
        <p class="font-serif text-xl md:text-2xl text-gold-pale italic leading-relaxed">
          We do not aspire to offer the largest vessels or the most extravagant experiences. We aspire to create
          journeys that are remembered for all the right reasons.
        </p>
        <p>
          Because when your clients return home carrying unforgettable memories, we know we have fulfilled our purpose.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/more_than_plan.jpg" alt="Nile at sunset" class="w-full h-full object-cover" loading="lazy" />
      <div class="absolute inset-0 bg-gradient-to-b from-void/60 via-forest/85 to-void/95"></div>
    </div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 lg:px-12 py-24 lg:py-32 text-center">
      <p class="font-sans text-[14px] tracking-[0.3em] uppercase text-gold-light mb-6 reveal">Sail With Us</p>
      <h2 class="font-serif text-4xl md:text-5xl text-white font-light tracking-tight leading-[1.1] mb-6 reveal reveal-delay-1"
        style="text-shadow: 0 2px 40px rgba(0,0,0,0.4);">
        Journeys remembered for<br />all the right reasons
      </h2>
      <p class="font-sans text-base text-ivory/60 max-w-md mx-auto leading-relaxed mb-12 reveal reveal-delay-2">
        Whether you're planning your own voyage or partnering with us as a tour operator, we'd love to talk.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center reveal reveal-delay-3">
        <a href="/dahabiyas" class="group inline-flex items-center justify-center gap-3 bg-gold hover:bg-gold-light text-white font-sans text-xs tracking-ultra uppercase px-8 py-4 rounded-full transition-all duration-300">
          Meet Our Fleet
          <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
        </a>
        <a href="/contact" class="group inline-flex items-center justify-center gap-3 border border-white/25 hover:border-gold text-white/80 hover:text-gold font-sans text-xs tracking-ultra uppercase px-8 py-4 rounded-full transition-all duration-300 hover:bg-gold/10 backdrop-blur-sm">
          Partner With Us
          <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
        </a>
      </div>
    </div>
  </section>

</MainLayout>
