// ── Thin line-icons for the spec grid (stroke = currentColor, inherits gold) ──
const S = 'viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"';
const ICONS: Record<string, string> = {
  ruler:    `<svg ${S}><rect x="2.5" y="8.5" width="19" height="7" rx="1"/><path d="M6.5 8.5v2.5M10.5 8.5v3.5M14.5 8.5v2.5M18.5 8.5v3.5"/></svg>`,
  people:   `<svg ${S}><circle cx="12" cy="8" r="2.5"/><circle cx="5.5" cy="9.5" r="1.9"/><circle cx="18.5" cy="9.5" r="1.9"/><path d="M8 18c0-2.4 1.8-4 4-4s4 1.6 4 4"/><path d="M2.5 17c0-1.9 1.2-3.2 3-3.3"/><path d="M21.5 17c0-1.9-1.2-3.2-3-3.3"/></svg>`,
  bed:      `<svg ${S}><path d="M2.5 17v-4a2 2 0 0 1 2-2h15a2 2 0 0 1 2 2v4"/><path d="M2.5 17h19"/><path d="M2.5 17v2.5M21.5 17v2.5"/><path d="M6.5 11V9.3a1 1 0 0 1 1-1h3a1 1 0 0 1 1 1V11M12.5 11V9.3a1 1 0 0 1 1-1h3a1 1 0 0 1 1 1V11"/></svg>`,
  window:   `<svg ${S}><rect x="3" y="5" width="18" height="14" rx="1"/><circle cx="8" cy="9.5" r="1.3"/><path d="M3 16l4.5-4 3.5 3 4-3.5 6 4.5"/></svg>`,
  layers:   `<svg ${S}><path d="M12 3l8.5 4.5L12 12 3.5 7.5 12 3z"/><path d="M4 12l8 4.5 8-4.5"/><path d="M4 16.5l8 4.5 8-4.5"/></svg>`,
  bath:     `<svg ${S}><path d="M4 11V6.5A2.5 2.5 0 0 1 9 5.8"/><path d="M3 11h18v2.5A4.5 4.5 0 0 1 16.5 18h-9A4.5 4.5 0 0 1 3 13.5V11z"/><path d="M7 18l-1 2M18 18l1 2"/></svg>`,
  sun:      `<svg ${S}><circle cx="12" cy="12" r="3.5"/><path d="M12 2.5V5M12 19v2.5M2.5 12H5M19 12h2.5M5.2 5.2l1.7 1.7M17.1 17.1l1.7 1.7M18.8 5.2l-1.7 1.7M6.9 17.1l-1.7 1.7"/></svg>`,
  heart:    `<svg ${S}><path d="M12 20s-6.5-4.2-6.5-9A3.5 3.5 0 0 1 12 8.2 3.5 3.5 0 0 1 18.5 11c0 4.8-6.5 9-6.5 9z"/></svg>`,
  umbrella: `<svg ${S}><path d="M12 4v16"/><path d="M4 11a8 8 0 0 1 16 0z"/><path d="M12 20a2 2 0 0 0 2-2"/></svg>`,
  anchor:   `<svg ${S}><circle cx="12" cy="5" r="2.2"/><path d="M12 7.2V20"/><path d="M5 12a7 7 0 0 0 14 0"/><path d="M3.5 12H6M18 12h2.5"/></svg>`,
};

function iconFor(label: string): string {
  const k = label.toLowerCase();
  if (/length|dimension|size/.test(k))            return ICONS.ruler;
  if (/capacity|guest|passenger|meeting/.test(k)) return ICONS.people;
  if (/panoram|window|view/.test(k))              return ICONS.window;
  if (/bath|ensuite/.test(k))                     return ICONS.bath;
  if (/energy|solar|power|green/.test(k))         return ICONS.sun;
  if (/upper|sundeck|deck/.test(k))               return ICONS.umbrella;
  if (/structure|mast|layer/.test(k))             return ICONS.layers;
  if (/ideal|atmosphere|retreat/.test(k))         return ICONS.heart;
  if (/suite|cabin|room|bed|layout/.test(k))      return ICONS.bed;
  return ICONS.anchor;
}

const fleetSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    ...boats.map((b) => ({
      '@type': 'Product',
      '@id': `${SITE}/dahabiyas#${b.id}`,
      name: b.name,
      description: b.desc,
      image: `${SITE}${b.hero}`,
      url: `${SITE}/dahabiyas#${b.id}`,
      category: 'Private Nile Dahabiya Charter',
      brand: { '@type': 'Brand', name: 'VEDA Egypt' },
      additionalProperty: [
        { '@type': 'PropertyValue', name: 'Tagline', value: b.tagline },
        { '@type': 'PropertyValue', name: 'Length', value: b.length },
        { '@type': 'PropertyValue', name: 'Capacity', value: b.capacity },
        ...b.specs.map((s) => ({ '@type': 'PropertyValue', name: s.label, value: s.value })),
      ],
      offers: {
        '@type': 'Offer',
        availability: 'https://schema.org/InStock',
        priceCurrency: 'EUR',
        priceSpecification: {
          '@type': 'PriceSpecification',
          description: 'On request — private charters quoted per group, season and length of stay.',
        },
        url: `${SITE}/contact`,
      },
    })),
    {
      '@type': 'TouristTrip',
      '@id': `${SITE}/dahabiyas#luxor-aswan-journey`,
      name: 'Luxor → Aswan Private Nile Dahabiya Journey',
      description:
        'Seven-day, six-night private charter between Luxor and Aswan aboard a VEDA dahabiya. Stops at Esna, Edfu, Silsila, and Kom Ombo, with optional excursions to Karnak, Philae, and the Valley of the Kings.',
      touristType: ['Private charter', 'Retreat groups', 'Families', 'Couples'],
      itinerary: [
        { '@type': 'TouristDestination', name: 'Luxor', address: { '@type': 'PostalAddress', addressCountry: 'EG' } },
        { '@type': 'TouristDestination', name: 'Esna', address: { '@type': 'PostalAddress', addressCountry: 'EG' } },
        { '@type': 'TouristDestination', name: 'Edfu', address: { '@type': 'PostalAddress', addressCountry: 'EG' } },
        { '@type': 'TouristDestination', name: 'Gebel el-Silsila', address: { '@type': 'PostalAddress', addressCountry: 'EG' } },
        { '@type': 'TouristDestination', name: 'Kom Ombo', address: { '@type': 'PostalAddress', addressCountry: 'EG' } },
        { '@type': 'TouristDestination', name: 'Aswan', address: { '@type': 'PostalAddress', addressCountry: 'EG' } },
      ],
      provider: {
        '@type': 'TravelAgency',
        name: 'VEDA Egypt',
        url: SITE,
      },
      offers: {
        '@type': 'Offer',
        availability: 'https://schema.org/InStock',
        url: `${SITE}/contact`,
        priceSpecification: {
          '@type': 'PriceSpecification',
          description: 'On request — quoted per group and season.',
        },
      },
    },
    {
      '@type': 'ItemList',
      '@id': `${SITE}/dahabiyas#fleet`,
      name: 'VEDA Egypt Dahabiya Fleet',
      itemListOrder: 'https://schema.org/ItemListUnordered',
      numberOfItems: boats.length,
      itemListElement: boats.map((b, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: `${SITE}/dahabiyas#${b.id}`,
        name: b.name,
      })),
    },
  ],
});
---

<MainLayout
  title="Our Dahabiyas — VEDA Egypt"
  description="Four private dahabiyas on the Nile — from intimate retreats to grand flagships. Fully equipped, sustainably built, and entirely yours."
  extraSchema={fleetSchema}
>

  <!-- Page Hero — dark image banner (matches home hero) -->
  <div class="relative flex items-center min-h-[78vh] pt-40 pb-28 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/egypte-veda-214-van-577-2000x709.jpg" alt="" width="2000" height="709" class="w-full h-full object-cover object-center" loading="eager"/>
    </div>
    <!-- Dark overlays for legibility -->
    <div class="absolute inset-0 bg-void/45"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-void/45 via-transparent to-void/70"></div>
    <div class="relative w-full max-w-7xl mx-auto px-6 lg:px-12 text-center">
      <div class="flex items-center justify-center gap-4 mb-6">
        <span class="h-px w-10 bg-gold-light/60"></span>
        <p class="font-sans text-[14px] tracking-[0.32em] uppercase text-gold-light">Our Fleet</p>
        <span class="h-px w-10 bg-gold-light/60"></span>
      </div>
      <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl text-white font-light tracking-tight leading-tight mb-6"
        style="text-shadow: 0 2px 28px rgba(0,0,0,0.45);">
        Our Dahabiyas
      </h1>
      <p class="font-sans text-base text-white/75 font-light max-w-md mx-auto leading-relaxed mb-6">
        Dahabiyas are traditional sailing boats of the Nile — peaceful, private, and entirely yours.
      </p>

      <!-- Licensing & safety certification -->
      <div class="flex items-start justify-center gap-2.5 max-w-xl mx-auto mb-10">
        <span class="flex-shrink-0 text-gold-light mt-0.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg>
        </span>
        <p class="font-sans text-[13px] md:text-sm text-white/70 font-light leading-relaxed">
          Our four dahabeyas are licensed by both the <span class="text-white">Ministry of Tourism</span> and the
          <span class="text-white">Ministry of Transport</span>, and hold fire-safety certification from
          <span class="text-white">Civil Defense</span>.
        </p>
      </div>

      <!-- Quick-jump buttons -->
      <div class="flex flex-wrap items-center justify-center gap-3">
        {boats.map((boat) => (
          <a
            href={`#${boat.id}`}
            class="group flex items-center gap-2.5 border border-white/25 hover:border-gold bg-white/5 hover:bg-gold/10 rounded-full px-5 py-2.5 transition-all duration-300 backdrop-blur-sm"
          >
            <span class="font-sans text-[12px] tracking-[0.25em] uppercase text-white/80 group-hover:text-gold transition-colors duration-300">
              {boat.name}
            </span>
            {/* <span class="font-sans text-[9px] text-gold/50 group-hover:text-gold/80 transition-colors duration-300 hidden sm:inline">
              {boat.tagline}
            </span> */}
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Boats — alternating light / dark sections -->
  {boats.map((boat, bi) => (
    <div id={boat.id} class={`${boat.bg} relative`}>

      <!-- Divider line top -->
      <div class="h-px w-full bg-gradient-to-r from-transparent via-gold/20 to-transparent"></div>

      <!-- Hero: large image + text (alternating sides) -->
      <div class="container grid grid-cols-1 lg:grid-cols-2 items-center mx-auto px-4 sm:px-6 lg:px-12 pt-8 lg:pt-12">

        <!-- Hero collage — guide-style mosaic: big photo + stacked right + bottom row -->
        <div
          class={`grid grid-cols-4 grid-rows-[1.4fr_1.4fr_1fr] gap-2 aspect-[7/5] reveal-right ${bi % 2 === 1 ? 'lg:order-1' : 'lg:order-2'}`}
          data-gallery={boat.gallery.join('||')}
        >

          <!-- Main image — big, left, spans 3 cols × 2 rows -->
          <button
            type="button"
            class="gallery-open group relative col-span-3 row-span-2 overflow-hidden cursor-zoom-in"
            data-boat={boat.name}
            data-src={boat.gallery[0]}
            aria-label={`Open ${boat.name} gallery`}
          >
            <img
              src={boat.hero}
              alt={`${boat.name} — ${boat.tagline}`}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1200ms] group-hover:scale-105"
              loading={bi === 0 ? 'eager' : 'lazy'}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-void/45 via-transparent to-transparent"></div>
            <!-- Boat badge -->
            <div class="absolute top-6 left-6 bg-void/70 backdrop-blur-sm border border-gold/20 px-3 py-1.5">
              <p class="font-sans text-[8px] tracking-[0.25em] uppercase text-white">{boat.name}</p>
            </div>
          </button>

          <!-- Right column — two stacked images -->
          {[boat.gallery[1], boat.gallery[2]].map((img, ti) => (
            <button
              type="button"
              class="gallery-open group relative col-span-1 row-span-1 overflow-hidden cursor-zoom-in"
              data-boat={boat.name}
              data-src={img}
              aria-label={`Open ${boat.name} gallery`}
            >
              <img
                src={img}
                alt={`${boat.name} — photo ${ti + 2}`}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                loading="lazy"
              />
            </button>
          ))}

          <!-- Bottom row — four thumbnails (last tile = "+N photos") -->
          {[boat.gallery[3], boat.gallery[4], boat.gallery[5], boat.gallery[6]].map((img, ti) => (
            <button
              type="button"
              class="gallery-open group relative col-span-1 overflow-hidden cursor-zoom-in"
              data-boat={boat.name}
              data-src={img}
              aria-label={`Open ${boat.name} gallery`}
            >
              <img
                src={img}
                alt={`${boat.name} — photo ${ti + 4}`}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                loading="lazy"
              />
              {ti === 3 && (
                <div class="absolute inset-0 bg-void/55 group-hover:bg-void/65 transition-colors duration-300 flex flex-col items-center justify-center">
                  <span class="font-serif text-2xl lg:text-3xl text-white font-light leading-none">+{boat.gallery.length}</span>
                  <span class="font-sans text-[9px] tracking-[0.25em] uppercase text-white/80 mt-1">Photos</span>
                </div>
              )}
            </button>
          ))}
        </div>

        <!-- Text column -->
        <div class={`flex items-center px-2 sm:px-4 lg:px-12 py-16 lg:py-20 reveal ${bi % 2 === 1 ? 'lg:order-2' : 'lg:order-1'}`}>
          <div class="w-full max-w-xl">
           
            <h2 class={`font-serif text-5xl md:text-6xl uppercase font-light tracking-tight leading-none mb-3 ${boat.headingColor}`}>
              {boat.name}
            </h2>
            <p class={`font-serif text-2xl md:text-3xl italic font-light leading-snug mb-8 ${boat.taglineColor}`}>
              {boat.tagline}
            </p>
            <p class={`font-sans text-base leading-relaxed max-w-lg mb-10 ${boat.bodyColor}`}>
              {boat.desc}
            </p>

            <!-- Specs — amenity chips (icon left, text right) -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2.5">
              {boat.specs.map((spec) => (
                <div class={`flex items-center gap-3 rounded-xl border ${boat.specBorder} px-4 py-3 [&_svg]:w-[22px] [&_svg]:h-[22px]`}>
                  <span class={`flex-shrink-0 ${boat.specLabel}`} set:html={iconFor(spec.label)}></span>
                  <div class="min-w-0">
                    <p class={`font-sans text-[10px] tracking-[0.18em] uppercase ${boat.bodyColor}`}>{spec.label}</p>
                    <p class={`font-sans text-sm font-light leading-snug ${boat.specValue}`}>{spec.value}</p>
                  </div>
                </div>
              ))}
            </div>

            <div class="mt-8">
              <a
                href={`/contact?subject=${encodeURIComponent('Enquiry about ' + boat.name)}`}
                class="inline-flex items-center gap-3 font-sans text-[12px] tracking-[0.22em] uppercase px-6 py-3.5 rounded-full bg-gold hover:bg-gold-light text-white transition-all duration-300 group"
              >
                Enquire about {boat.name}
                <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Onboard facilities + Technical data (only for boats that provide them) -->
      {(boat.facilities || boat.tech) && (
        <div class="max-w-7xl mx-auto px-6 lg:px-12 pb-16 lg:pb-24">

          <!-- Section header -->
          <div class="flex items-center gap-4 mb-10 lg:mb-12 reveal">
            <p class={`font-sans text-[12px] tracking-[0.3em] uppercase ${boat.taglineColor}`}>Specifications &amp; Onboard</p>
            <span class="flex-1 h-px bg-gradient-to-r from-gold/30 to-transparent"></span>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
            {boat.facilities && (
              <div class="reveal">
                <p class={`font-sans text-[11px] tracking-[0.28em] uppercase mb-6 ${boat.specLabel}`}>Onboard</p>
                <ul class="space-y-4">
                  {boat.facilities.map((f) => (
                    <li class={`flex items-start gap-3 font-sans text-base font-light ${boat.bodyColor}`}>
                      <span class="mt-[0.55rem] h-1.5 w-1.5 rounded-full bg-gold flex-shrink-0"></span>
                      <span>{f}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
            {boat.tech && (
              <div class="reveal reveal-delay-1">
                <p class={`font-sans text-[11px] tracking-[0.28em] uppercase mb-6 ${boat.specLabel}`}>Technical Data</p>
                <dl class={`border-t ${boat.specBorder}`}>
                  {boat.tech.map((t) => (
                    <div class={`flex justify-between items-baseline gap-6 border-b ${boat.specBorder} py-3`}>
                      <dt class={`font-sans text-[11px] tracking-[0.18em] uppercase flex-shrink-0 ${boat.specLabel}`}>{t.label}</dt>
                      <dd class={`font-sans text-sm font-light text-right ${boat.specValue}`}>{t.value}</dd>
                    </div>
                  ))}
                </dl>
              </div>
            )}
          </div>
        </div>
      )}

      <!-- Divider line bottom -->
      <div class="h-px w-full bg-gradient-to-r from-transparent via-gold/20 to-transparent"></div>
    </div>
  ))}

  <!-- Comparison table — at the end, to help decide between the fleet -->
  <FleetCompare />

  <!-- CTA band -->
  <div class="relative py-24 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/dsc-1797-pano-1280x800.jpg" alt="" width="1280" height="800" class="w-full h-full object-cover object-center"/>
    </div>
    <!-- Dark overlays for legibility (matches page hero) -->
    <div class="absolute inset-0 bg-void/45"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-void/45 via-transparent to-void/70"></div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-12 text-center">
      <p class="font-sans text-[14px] tracking-[0.3em] uppercase text-gold-light mb-5">Ready to Sail?</p>
      <h2 class="font-serif text-4xl md:text-5xl text-white font-light mb-4 leading-tight" style="text-shadow: 0 2px 28px rgba(0,0,0,0.45);">
        Enjoy the River Nile,<br /><em class="italic text-gold-light">its sacred places and healing energies.</em>
      </h2>
      <p class="font-sans text-base text-white/75 font-light max-w-sm mx-auto mb-10">
        Every itinerary is tailored around you. Choose your vessel and we'll create the rest.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/gallery" class="inline-flex items-center gap-2 border border-white/25 hover:border-gold text-white/80 hover:text-gold font-sans text-xs tracking-ultra uppercase px-7 py-4 rounded-full transition-all duration-300 hover:bg-gold/10 backdrop-blur-sm">
          View Gallery →
        </a>
        <a href="/contact" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-white font-sans text-[12px] tracking-[0.22em] uppercase px-6 py-3.5 rounded-full transition-all duration-300">
          Reserve Your Journey →
        </a>
      </div>
    </div>
  </div>

  <!-- Lightbox -->
  <div id="lb" class="fixed inset-0 z-[100] bg-void/97 backdrop-blur-sm items-center justify-center hidden" role="dialog" aria-modal="true" aria-label="Image viewer">
    <button id="lb-close" aria-label="Close image viewer" class="absolute top-6 right-8 text-ivory/50 hover:text-ivory font-sans text-xs tracking-ultra uppercase flex items-center gap-2 transition-colors">Close ×</button>
    <button id="lb-prev" aria-label="Previous image" class="absolute left-4 lg:left-10 top-1/2 -translate-y-1/2 w-11 h-11 border border-white/15 hover:border-gold/60 text-ivory/50 hover:text-gold flex items-center justify-center transition-all">←</button>
    <button id="lb-next" aria-label="Next image" class="absolute right-4 lg:right-10 top-1/2 -translate-y-1/2 w-11 h-11 border border-white/15 hover:border-gold/60 text-ivory/50 hover:text-gold flex items-center justify-center transition-all">→</button>
    <div class="flex flex-col items-center max-w-5xl w-full px-16">
      <div class="relative inline-block max-w-full">
        <img id="lb-img" src="" alt="" class="block max-h-[82vh] max-w-full object-contain lb-img"/>
        <div id="lb-caption" class="absolute inset-x-0 bottom-0 px-6 pt-12 pb-5 bg-gradient-to-t from-void/95 via-void/55 to-transparent pointer-events-none">
          <p id="lb-caption-text" class="font-sans text-sm md:text-base tracking-[0.2em] uppercase text-gold-pale text-center"></p>
        </div>
      </div>
    </div>
  </div>

</MainLayout>

<style>
  .lb-img { animation: lbIn 0.3s ease both; }
  @keyframes lbIn {
    from { opacity: 0; transform: scale(0.97); }
    to   { opacity: 1; transform: scale(1); }
  }
  #lb.open { display: flex; }
</style>

<script>
  const lb     = document.getElementById('lb')!;
  const lbImg  = document.getElementById('lb-img') as HTMLImageElement;
  const lbCaption = document.getElementById('lb-caption');
  const lbCaptionText = document.getElementById('lb-caption-text');

  let pool: string[] = [];
  let cur = 0;

  // Derive a caption from descriptive filenames like "veda_1_Indoor Lounge.jpg".
  function captionFor(src: string): string {
    const name = (src.split('/').pop() || '').replace(/\.[^.]+$/, '');
    const m = name.match(/^veda[_ ]?(\d+)[_ ](.+)$/i);
    if (!m) return '';
    const words = m[2].replace(/_+/g, ' ').replace(/\s+\d+$/, '').trim();
    const titled = words.split(/\s+/).map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
    return 'Veda ' + m[1] + ' — ' + titled;
  }

  function open(src: string, srcs: string[]) {
    pool = srcs;
    cur  = srcs.indexOf(src);
    show(cur);
    lb.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function show(i: number) {
    cur = (i + pool.length) % pool.length;
    lbImg.src = pool[cur];
    const cap = captionFor(pool[cur]);
    lbImg.alt = cap;
    if (lbCaptionText) lbCaptionText.textContent = cap;
    if (lbCaption) lbCaption.style.display = cap ? '' : 'none';
    lbImg.classList.remove('lb-img');
    void lbImg.offsetWidth;
    lbImg.classList.add('lb-img');
  }

  function close() {
    lb.classList.remove('open');
    document.body.style.overflow = '';
  }

  // The full image pool lives on the nearest [data-gallery] ancestor (the collage).
  function poolFor(el: HTMLElement): string[] {
    const host = el.closest<HTMLElement>('[data-gallery]');
    const raw  = host?.dataset.gallery;
    return raw ? raw.split('||') : [];
  }

  // Collage hero images (main photo + thumbnail row + "+N photos" tile)
  document.querySelectorAll<HTMLElement>('.gallery-open').forEach(el => {
    el.addEventListener('click', () => {
      const srcs = poolFor(el);
      if (!srcs.length) return;
      const src = el.dataset.src!;
      open(srcs.includes(src) ? src : srcs[0], srcs);
    });
  });

  document.getElementById('lb-close')?.addEventListener('click', close);
  document.getElementById('lb-prev')?.addEventListener('click',  () => show(cur - 1));
  document.getElementById('lb-next')?.addEventListener('click',  () => show(cur + 1));
  lb.addEventListener('click', e => { if (e.target === lb) close(); });

  // Touch swipe — left/right to navigate, with a deliberate threshold so taps don't trigger.
  let touchX = 0, touchY = 0;
  lb.addEventListener('touchstart', e => {
    touchX = e.changedTouches[0].clientX;
    touchY = e.changedTouches[0].clientY;
  }, { passive: true });
  lb.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - touchX;
    const dy = e.changedTouches[0].clientY - touchY;
    // Horizontal swipe only: ignore mostly-vertical gestures (scroll/dismiss intent).
    if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
      show(dx < 0 ? cur + 1 : cur - 1);
    }
  }, { passive: true });
  document.addEventListener('keydown', e => {
    if (lb.classList.contains('open')) {
      if (e.key === 'Escape')     close();
      if (e.key === 'ArrowLeft')  show(cur - 1);
      if (e.key === 'ArrowRight') show(cur + 1);
    }
  });
</script>
