---

<MainLayout
  title="Our Dahabiyas — VEDA Egypt"
  description="Four private dahabiyas on the Nile — from intimate retreats to grand flagships. Fully equipped, sustainably built, and entirely yours."
>

  <!-- Page Hero -->
  <div class="relative bg-void pt-40 pb-28 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/egypte-veda-214-van-577-2000x709.jpg" alt="" class="w-full h-full object-cover object-center opacity-30"/>
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-void/60 via-void/20 to-void"></div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-12 text-center">
      <div class="flex items-center justify-center gap-4 mb-6">
        <span class="h-px w-10 bg-gold/50"></span>
        <p class="font-sans text-[10px] tracking-[0.32em] uppercase text-gold">Our Fleet</p>
        <span class="h-px w-10 bg-gold/50"></span>
      </div>
      <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl text-ivory font-light tracking-tight leading-tight mb-6">
        Our Dahabiyas
      </h1>
      <p class="font-sans text-sm text-warm-gray font-light max-w-md mx-auto leading-relaxed">
        Dahabiyas are traditional sailing boats of the Nile — peaceful, private, and entirely yours.
      </p>
    </div>
  </div>

  <!-- Boats -->
  <div class="bg-void">
    {boats.map((boat, bi) => (
      <div id={boat.id} class="relative ">

        <!-- Boat Section -->
        <div class="max-w-7xl mx-auto px-6 lg:px-12 py-24 lg:py-32">

          <!-- Header row -->
          <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 items-end mb-16 ${bi % 2 === 1 ? 'lg:flex lg:flex-row-reverse' : ''}`}>

            <!-- Text -->
            <div class="reveal">
              <div class="flex items-center gap-4 mb-6">
                <span class="h-px w-8 bg-gold/40"></span>
                <p class="font-sans text-[9px] tracking-[0.3em] uppercase text-gold/70">{boat.length} · {boat.capacity}</p>
              </div>
              <h2 class="font-serif text-5xl md:text-6xl lg:text-7xl text-ivory font-light tracking-tight leading-none mb-3">
                {boat.name}
              </h2>
              <p class="font-sans text-[10px] tracking-[0.28em] uppercase text-gold mb-8">{boat.tagline}</p>
              <p class="font-sans text-sm text-warm-gray font-light leading-relaxed max-w-lg mb-10">
                {boat.desc}
              </p>

              <!-- Specs grid -->
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-0 border-t border-gold/10">
                {boat.specs.map((spec) => (
                  <div class="border-b border-r border-gold/10 px-4 py-4 last:border-r-0">
                    <p class="font-sans text-[8px] tracking-[0.22em] uppercase text-gold/60 mb-1">{spec.label}</p>
                    <p class="font-sans text-xs text-ivory/80 font-light">{spec.value}</p>
                  </div>
                ))}
              </div>

              <div class="mt-8">
                <a
                  href="#contact"
                  class="inline-flex items-center gap-3 bg-gold hover:bg-gold-light text-white font-sans text-[10px] tracking-[0.22em] uppercase px-6 py-3.5 transition-all duration-300 group"
                >
                  Enquire about {boat.name}
                  <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
                </a>
              </div>
            </div>

            <!-- Hero image -->
            <div class="relative overflow-hidden rounded-lg reveal-right" style="aspect-ratio:4/3;">
              <img
                src={boat.hero}
                alt={boat.name}
                class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
                loading={bi === 0 ? 'eager' : 'lazy'}
              />
              <div class={`absolute inset-0 bg-gradient-to-t ${boat.color} to-transparent opacity-40`}></div>
              <!-- Boat badge -->
              <div class="absolute top-4 left-4 bg-void/70 backdrop-blur-sm border border-gold/20 px-3 py-1.5">
                <p class="font-sans text-[8px] tracking-[0.25em] uppercase text-gold">{boat.name}</p>
              </div>
            </div>
          </div>

          <!-- Gallery strip -->
          <div class="reveal reveal-delay-2">
            <p class="font-sans text-[9px] tracking-[0.28em] uppercase text-warm-gray/50 mb-4">Gallery</p>
            <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-2">
              {boat.gallery.map((img, gi) => (
                <div
                  class="gallery-thumb relative overflow-hidden rounded cursor-zoom-in group"
                  style="aspect-ratio:1;"
                  data-src={img}
                  data-boat={boat.name}
                  data-index={gi}
                >
                  <img
                    src={img}
                    alt={`${boat.name} — photo ${gi + 1}`}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-void/0 group-hover:bg-void/30 transition-colors duration-300 flex items-center justify-center">
                    <span class="text-white/0 group-hover:text-white/80 transition-colors duration-300 text-lg">⊕</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- CTA band -->
  <div class="relative bg-forest-mid border-t border-gold/10 py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <img src="/images/dsc-1797-pano-1280x800.jpg" alt="" class="w-full h-full object-cover"/>
    </div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-12 text-center">
      <p class="font-sans text-[10px] tracking-[0.3em] uppercase text-gold mb-5">Ready to Sail?</p>
      <h2 class="font-serif text-4xl md:text-5xl text-ivory font-light mb-4 leading-tight">
        Enjoy the River Nile,<br /><em class="italic text-gold-pale">its sacred places and healing energies.</em>
      </h2>
      <p class="font-sans text-sm text-warm-gray font-light max-w-sm mx-auto mb-10">
        Every itinerary is tailored around you. Choose your vessel and we'll create the rest.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/gallery" class="inline-flex items-center gap-2 border border-gold/40 hover:border-gold text-gold/80 hover:text-gold font-sans text-[10px] tracking-[0.22em] uppercase px-6 py-3.5 transition-all duration-300 hover:bg-gold/5">
          View Gallery →
        </a>
        <a href="#contact" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-white font-sans text-[10px] tracking-[0.22em] uppercase px-6 py-3.5 transition-all duration-300">
          Plan Your Journey →
        </a>
      </div>
    </div>
  </div>

  <!-- Lightbox -->
  <div id="lb" class="fixed inset-0 z-[100] bg-void/97 backdrop-blur-sm items-center justify-center hidden" aria-modal="true">
    <button id="lb-close" class="absolute top-6 right-8 text-ivory/50 hover:text-ivory font-sans text-xs tracking-ultra uppercase flex items-center gap-2 transition-colors">Close ×</button>
    <button id="lb-prev" class="absolute left-4 lg:left-10 top-1/2 -translate-y-1/2 w-11 h-11 border border-white/15 hover:border-gold/60 text-ivory/50 hover:text-gold flex items-center justify-center transition-all">←</button>
    <button id="lb-next" class="absolute right-4 lg:right-10 top-1/2 -translate-y-1/2 w-11 h-11 border border-white/15 hover:border-gold/60 text-ivory/50 hover:text-gold flex items-center justify-center transition-all">→</button>
    <div class="flex flex-col items-center max-w-5xl w-full px-16">
      <img id="lb-img" src="" alt="" class="max-h-[80vh] max-w-full object-contain lb-img"/>
    </div>
  </div>

</MainLayout>

<style>
  .lb-img { animation: lbIn 0.3s ease both; }
  @keyframes lbIn {
    from { opacity: 0; transform: scale(0.97); }
    to   { opacity: 1; transform: scale(1); }
  }
  #lb.open { display: flex; }
</style>

<script>
  // Collect all thumbnails per boat section
  const thumbs = document.querySelectorAll<HTMLElement>('.gallery-thumb');
  const lb     = document.getElementById('lb')!;
  const lbImg  = document.getElementById('lb-img') as HTMLImageElement;

  let pool: string[] = [];
  let cur = 0;

  function open(src: string, srcs: string[]) {
    pool = srcs;
    cur  = srcs.indexOf(src);
    show(cur);
    lb.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function show(i: number) {
    cur = (i + pool.length) % pool.length;
    lbImg.src = pool[cur];
    lbImg.classList.remove('lb-img');
    void lbImg.offsetWidth;
    lbImg.classList.add('lb-img');
  }

  function close() {
    lb.classList.remove('open');
    document.body.style.overflow = '';
  }

  thumbs.forEach(thumb => {
    thumb.addEventListener('click', () => {
      const boat = thumb.dataset.boat!;
      const src  = thumb.dataset.src!;
      const boatSrcs = Array.from(document.querySelectorAll<HTMLElement>(`.gallery-thumb[data-boat="${boat}"]`))
        .map(t => t.dataset.src!);
      open(src, boatSrcs);
    });
  });

  document.getElementById('lb-close')?.addEventListener('click', close);
  document.getElementById('lb-prev')?.addEventListener('click', () => show(cur - 1));
  document.getElementById('lb-next')?.addEventListener('click', () => show(cur + 1));
  lb.addEventListener('click', e => { if (e.target === lb) close(); });
  document.addEventListener('keydown', e => {
    if (lb.classList.contains('open')) {
      if (e.key === 'Escape')     close();
      if (e.key === 'ArrowLeft')  show(cur - 1);
      if (e.key === 'ArrowRight') show(cur + 1);
    }
  });
</script>
