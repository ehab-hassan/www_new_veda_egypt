---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

// WhatsApp number for the success CTA — replace with VEDA's real number (digits only, incl. country code).
const WHATSAPP_NUMBER = '201000000000';

// Every itinerary, so the client can pre-select the journey from
// ?tour=<id>&route=<index> (set by the detail-page CTA) or via the chooser.
const tours = (await getCollection('itineraries', ({ data }) => !data.draft))
  .map((it) => ({
    id: it.id,
    title: it.data.title,
    nights: it.data.nights,
    days: it.data.days,
    experience: it.data.experience,
    image: it.data.cardImage,
    routes: it.data.routes.map((r) => r.label),
  }))
  .sort((a, b) => a.nights - b.nights);
const toursJson = JSON.stringify(Object.fromEntries(tours.map((t) => [t.id, t])));

// Flat list of every direction, for the fallback chooser dropdown.
const journeyOptions = tours.flatMap((t) =>
  t.routes.map((label, i) => ({
    value: `${t.id}::${i}`,
    text: `${t.nights} Nights / ${t.days} Days — ${label}`,
  })),
);

const TRAVEL_STYLES = [
  'Culture & History',
  'Relaxation & Slow Travel',
  'Photography',
  'Family Adventure',
  'Honeymoon',
  'Celebration',
  'Mixed Experience',
];
---

<MainLayout
  title="Plan Your Journey — VEDA Egypt"
  description="Share your travel preferences and our specialists will prepare a personalized itinerary, availability, and quotation within 24 hours."
>

  <!-- Hero -->
  <div class="relative flex items-center min-h-[48vh] pt-40 pb-20 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/dsc-1797-pano-1280x800.jpg" alt="" width="1280" height="800" class="w-full h-full object-cover object-center" loading="eager" />
    </div>
    <div class="absolute inset-0 bg-void/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-void/50 via-transparent to-void/75"></div>
    <div class="relative w-full max-w-3xl mx-auto px-6 lg:px-12 text-center">
      <div class="flex items-center justify-center gap-4 mb-6">
        <span class="h-px w-10 bg-gold-light/60"></span>
        <p class="font-sans text-[12px] tracking-[0.32em] uppercase text-gold-light">Personalized Planning</p>
        <span class="h-px w-10 bg-gold-light/60"></span>
      </div>
      <h1 class="font-serif text-5xl md:text-6xl text-white font-light tracking-tight leading-tight mb-5"
        style="text-shadow: 0 2px 28px rgba(0,0,0,0.45);">
        Plan Your <em class="italic text-gold-pale">Journey</em>
      </h1>
      <p class="font-sans text-md text-white/80 font-light leading-relaxed max-w-lg mx-auto">
        Share your travel preferences and our specialists will prepare a personalized itinerary, availability, and quotation within 24 hours.
      </p>
    </div>
  </div>

  <!-- Itinerary lookup for the client -->
  <script type="application/json" id="tours-data" is:inline set:html={toursJson}></script>

  <!-- Form container -->
  <div class="bg-linen min-h-screen border-t border-bone">
    <div class="max-w-3xl mx-auto px-6 lg:px-12 py-16">

      <!-- Step indicator -->
      <div class="flex items-center justify-center gap-0 mb-14" id="step-indicator" aria-label="Form progress">
        <div class="step-marker flex flex-col items-center" data-step="1">
          <div class="step-dot w-8 h-8 rounded-full border border-gold flex items-center justify-center font-sans text-xs text-gold bg-gold/10 transition-all duration-300">1</div>
          <p class="font-sans text-[12px] tracking-[0.2em] uppercase text-gold mt-2">Your Trip</p>
        </div>
        <div class="step-line h-px w-12 md:w-24 bg-gold/20 mx-2 mb-5 transition-colors duration-300" id="line-1-2"></div>
        <div class="step-marker flex flex-col items-center" data-step="2">
          <div class="step-dot w-8 h-8 rounded-full border border-bone flex items-center justify-center font-sans text-xs text-sandstone/50 transition-all duration-300">2</div>
          <p class="font-sans text-[12px] tracking-[0.2em] uppercase text-sandstone/50 mt-2">Your Details</p>
        </div>
        <div class="step-line h-px w-12 md:w-24 bg-gold/20 mx-2 mb-5 transition-colors duration-300" id="line-2-3"></div>
        <div class="step-marker flex flex-col items-center" data-step="3">
          <div class="step-dot w-8 h-8 rounded-full border border-bone flex items-center justify-center font-sans text-xs text-sandstone/50 transition-all duration-300">3</div>
          <p class="font-sans text-[12px] tracking-[0.2em] uppercase text-sandstone/50 mt-2">Confirmation</p>
        </div>
      </div>

      <form id="reserve-form" action="https://formspree.io/f/YOUR_FORM_ID" method="POST" novalidate>
        <input type="hidden" name="_subject" value="New VEDA Journey Request" />
        <input type="hidden" name="program" id="f-program" />
        <input type="hidden" name="route" id="f-route" />
        <input type="hidden" name="travelStyle" id="f-travelStyle" />

        <!-- ── STEP 1: Your Trip ──────────────────────────── -->
        <div id="step-1" class="form-step">

          <!-- Journey summary -->
          <div class="mb-10">
            <label class="block font-sans text-[10px] tracking-[0.28em] uppercase text-gold mb-4">Your Journey</label>

            <!-- Selected state -->
            <div id="journey-selected" class="hidden">
              <div class="relative flex items-stretch gap-4 sm:gap-5 border border-gold/40 bg-sand rounded-2xl overflow-hidden">
                <div class="w-28 sm:w-44 flex-shrink-0 overflow-hidden">
                  <img id="sj-image" src="" alt="" class="w-full h-full object-cover" style="min-height:140px;" />
                </div>
                <div class="flex-1 min-w-0 py-4 pr-4">
                  <p id="sj-exp" class="font-sans text-[10px] tracking-[0.22em] uppercase text-gold mb-1.5"></p>
                  <p id="sj-title" class="font-serif text-xl sm:text-2xl text-earth font-light leading-tight mb-3"></p>
                  <div class="flex flex-wrap gap-x-6 gap-y-2">
                    <div>
                      <p class="font-sans text-[9px] tracking-[0.2em] uppercase text-sandstone mb-0.5">Program</p>
                      <p id="sj-program" class="font-sans text-sm text-earth"></p>
                    </div>
                    <div>
                      <p class="font-sans text-[9px] tracking-[0.2em] uppercase text-sandstone mb-0.5">Route</p>
                      <p id="sj-route" class="font-sans text-sm text-earth"></p>
                    </div>
                  </div>
                  <button type="button" id="change-journey" class="mt-3 font-sans text-[11px] tracking-[0.18em] uppercase text-gold hover:text-gold-light transition-colors">
                    Change Journey
                  </button>
                </div>
              </div>
            </div>

            <!-- Chooser state -->
            <div id="journey-chooser">
              <div class="relative">
                <select id="journey-select" class="field w-full appearance-none bg-white border border-bone text-earth text-sm pl-4 pr-10 py-3.5 focus:outline-none focus:border-gold/60 transition-colors rounded">
                  <option value="" selected disabled>Select a journey…</option>
                  <option value="custom">Not sure yet — recommend an itinerary</option>
                  {journeyOptions.map((o) => <option value={o.value}>{o.text}</option>)}
                </select>
                <span class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-gold">▾</span>
              </div>
              <a href="/itineraries" class="inline-block mt-3 font-sans text-[11px] tracking-[0.18em] uppercase text-sandstone hover:text-gold transition-colors">
                Browse all itineraries →
              </a>
            </div>
            <p class="journey-error font-sans text-xs text-red-400/80 mt-2 hidden">Please choose a journey to continue.</p>
          </div>

          <!-- Preferred date + guests -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <div>
              <label for="preferredDate" class="block font-sans text-[10px] tracking-[0.28em] uppercase text-gold mb-2">Preferred Travel Date</label>
              <input type="text" id="preferredDate" name="preferredDate"
                class="field w-full bg-white border border-bone text-earth text-sm px-4 py-3 placeholder:text-sandstone/50 focus:outline-none focus:border-gold/60 transition-colors"
                placeholder="e.g. July 2026 — no need to be exact" />
            </div>
            <div>
              <label class="block font-sans text-[10px] tracking-[0.28em] uppercase text-gold mb-2">Guests</label>
              <div class="grid grid-cols-2 gap-3">
                <div class="flex items-center justify-between border border-bone bg-white px-3">
                  <span class="font-sans text-xs text-sandstone">Adults</span>
                  <div class="flex items-center">
                    <button type="button" data-step-btn="adults" data-dir="-1" class="w-9 h-11 flex items-center justify-center text-sandstone hover:text-gold transition-colors text-lg" aria-label="Fewer adults">−</button>
                    <input type="number" id="adults" name="adults" value="2" min="1" max="50" class="w-8 bg-transparent text-earth text-sm text-center focus:outline-none" />
                    <button type="button" data-step-btn="adults" data-dir="1" class="w-9 h-11 flex items-center justify-center text-sandstone hover:text-gold transition-colors text-lg" aria-label="More adults">+</button>
                  </div>
                </div>
                <div class="flex items-center justify-between border border-bone bg-white px-3">
                  <span class="font-sans text-xs text-sandstone">Children</span>
                  <div class="flex items-center">
                    <button type="button" data-step-btn="children" data-dir="-1" class="w-9 h-11 flex items-center justify-center text-sandstone hover:text-gold transition-colors text-lg" aria-label="Fewer children">−</button>
                    <input type="number" id="children" name="children" value="0" min="0" max="50" class="w-8 bg-transparent text-earth text-sm text-center focus:outline-none" />
                    <button type="button" data-step-btn="children" data-dir="1" class="w-9 h-11 flex items-center justify-center text-sandstone hover:text-gold transition-colors text-lg" aria-label="More children">+</button>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Boat preference -->
          <div class="mb-8">
            <label for="boatPreference" class="block font-sans text-[10px] tracking-[0.28em] uppercase text-gold mb-2">
              Boat Preference <span class="text-sandstone/70 normal-case tracking-normal text-xs ml-1">(optional)</span>
            </label>
            <div class="relative">
              <select id="boatPreference" name="boatPreference"
                class="field w-full appearance-none bg-white border border-bone text-earth text-sm pl-4 pr-10 py-3 focus:outline-none focus:border-gold/60 transition-colors">
                <option value="Recommend the best available boat" selected>Recommend the best available boat</option>
                <option value="Veda 1">Veda 1 · up to 20 guests</option>
                <option value="Veda 2">Veda 2 · up to 20 guests</option>
                <option value="Veda 3">Veda 3 · up to 10 guests</option>
                <option value="Veda 4">Veda 4 · up to 28 guests</option>
              </select>
              <span class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-gold">▾</span>
            </div>
          </div>

          <!-- Travel style (multi-select) -->
          <div class="mb-8">
            <label class="block font-sans text-[10px] tracking-[0.28em] uppercase text-gold mb-3">
              Travel Style <span class="text-sandstone/70 normal-case tracking-normal text-xs ml-1">(select any)</span>
            </label>
            <div class="flex flex-wrap gap-2.5" id="style-group">
              {TRAVEL_STYLES.map((s) => (
                <button type="button" class="style-chip" data-value={s}>{s}</button>
              ))}
            </div>
          </div>

          <!-- Notes -->
          <div class="mb-10">
            <label for="notes" class="block font-sans text-[10px] tracking-[0.28em] uppercase text-gold mb-2">Tell us about your dream Nile journey</label>
            <textarea id="notes" name="notes" rows="4"
              class="field w-full bg-white border border-bone text-earth text-sm px-4 py-3 placeholder:text-sandstone/50 focus:outline-none focus:border-gold/60 transition-colors resize-none leading-relaxed"
              placeholder="e.g. “Honeymoon in October” · “Family trip for 6 adults” · “Interested in bird watching”"></textarea>
          </div>

          <div class="flex justify-end">
            <button type="button" id="next-1"
              class="group inline-flex items-center gap-3 bg-gold hover:bg-gold-light text-white font-sans text-xs tracking-ultra uppercase px-8 py-4 rounded-full transition-all duration-300">
              Continue
              <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
            </button>
          </div>
        </div>

        <!-- ── STEP 2: Your Details ───────────────────────── -->
        <div id="step-2" class="form-step hidden">

          <div class="mb-4">
            <label for="fullName" class="block font-sans text-[10px] tracking-[0.28em] uppercase text-gold mb-2">Full Name</label>
            <input type="text" id="fullName" name="fullName" autocomplete="name" required
              class="field w-full bg-white border border-bone text-earth text-sm px-4 py-3 placeholder:text-sandstone/50 focus:outline-none focus:border-gold/60 transition-colors"
              placeholder="Your full name" />
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div>
              <label for="email" class="block font-sans text-[10px] tracking-[0.28em] uppercase text-gold mb-2">Email Address</label>
              <input type="email" id="email" name="email" autocomplete="email" required
                class="field w-full bg-white border border-bone text-earth text-sm px-4 py-3 placeholder:text-sandstone/50 focus:outline-none focus:border-gold/60 transition-colors"
                placeholder="you@example.com" />
            </div>
            <div>
              <label for="whatsapp" class="block font-sans text-[10px] tracking-[0.28em] uppercase text-gold mb-2">WhatsApp Number</label>
              <input type="tel" id="whatsapp" name="whatsapp" autocomplete="tel" required
                class="field w-full bg-white border border-bone text-earth text-sm px-4 py-3 placeholder:text-sandstone/50 focus:outline-none focus:border-gold/60 transition-colors"
                placeholder="+49 123 456 789" />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div>
              <label for="country" class="block font-sans text-[10px] tracking-[0.28em] uppercase text-gold mb-2">Country</label>
              <input type="text" id="country" name="country" autocomplete="country-name" required
                class="field w-full bg-white border border-bone text-earth text-sm px-4 py-3 placeholder:text-sandstone/50 focus:outline-none focus:border-gold/60 transition-colors"
                placeholder="Where are you travelling from?" />
            </div>
            <div>
              <label for="contactMethod" class="block font-sans text-[10px] tracking-[0.28em] uppercase text-gold mb-2">
                Preferred Contact <span class="text-sandstone/70 normal-case tracking-normal text-xs ml-1">(optional)</span>
              </label>
              <div class="relative">
                <select id="contactMethod" name="contactMethod"
                  class="field w-full appearance-none bg-white border border-bone text-earth text-sm pl-4 pr-10 py-3 focus:outline-none focus:border-gold/60 transition-colors">
                  <option value="WhatsApp" selected>WhatsApp</option>
                  <option value="Email">Email</option>
                  <option value="Phone Call">Phone Call</option>
                </select>
                <span class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-gold">▾</span>
              </div>
            </div>
          </div>

          <div class="mb-10">
            <label for="marketingSource" class="block font-sans text-[10px] tracking-[0.28em] uppercase text-gold mb-2">How did you hear about us?</label>
            <div class="relative">
              <select id="marketingSource" name="marketingSource"
                class="field w-full appearance-none bg-white border border-bone text-earth text-sm pl-4 pr-10 py-3 focus:outline-none focus:border-gold/60 transition-colors">
                <option value="" disabled selected>Select…</option>
                <option value="Google Search">Google Search</option>
                <option value="Instagram">Instagram</option>
                <option value="Facebook">Facebook</option>
                <option value="Recommendation">Recommendation</option>
                <option value="Travel Agent">Travel Agent</option>
                <option value="Previous Guest">Previous Guest</option>
                <option value="Other">Other</option>
              </select>
              <span class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-gold">▾</span>
            </div>
          </div>

          <p class="font-sans text-xs text-sandstone mb-8 leading-relaxed">
            Your details are used only to prepare your personalized proposal. We never share or sell your information.
          </p>

          <div class="flex items-center justify-between">
            <button type="button" id="back-2" class="font-sans text-xs tracking-ultra uppercase text-sandstone hover:text-gold transition-colors">← Back</button>
            <button type="button" id="next-2"
              class="group inline-flex items-center gap-3 bg-gold hover:bg-gold-light text-white font-sans text-xs tracking-ultra uppercase px-8 py-4 rounded-full transition-all duration-300">
              Review
              <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
            </button>
          </div>
        </div>

        <!-- ── STEP 3: Confirmation ───────────────────────── -->
        <div id="step-3" class="form-step hidden">

          <div class="border border-bone bg-sand rounded-2xl p-6 md:p-8 mb-8">
            <p class="font-sans text-[10px] tracking-[0.28em] uppercase text-gold mb-6">Journey Summary</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-12 gap-y-5">
              <div class="sm:col-span-2">
                <p class="font-sans text-[9px] tracking-[0.2em] uppercase text-sandstone mb-1">Program</p>
                <p id="r-program" class="font-serif text-earth text-xl font-light">—</p>
                <p id="r-route" class="font-sans text-sandstone text-sm mt-0.5">—</p>
              </div>
              <div>
                <p class="font-sans text-[9px] tracking-[0.2em] uppercase text-sandstone mb-1">Travel Date</p>
                <p id="r-date" class="font-serif text-earth text-lg font-light">—</p>
              </div>
              <div>
                <p class="font-sans text-[9px] tracking-[0.2em] uppercase text-sandstone mb-1">Guests</p>
                <p id="r-guests" class="font-serif text-earth text-lg font-light">—</p>
              </div>
              <div>
                <p class="font-sans text-[9px] tracking-[0.2em] uppercase text-sandstone mb-1">Boat Preference</p>
                <p id="r-boat" class="font-serif text-earth text-lg font-light">—</p>
              </div>
              <div>
                <p class="font-sans text-[9px] tracking-[0.2em] uppercase text-sandstone mb-1">Travel Style</p>
                <p id="r-style" class="font-serif text-earth text-lg font-light">—</p>
              </div>
              <div class="sm:col-span-2 border-t border-bone pt-4">
                <p class="font-sans text-[9px] tracking-[0.2em] uppercase text-sandstone mb-1">Contact</p>
                <p id="r-name" class="font-serif text-earth text-lg font-light">—</p>
                <p id="r-contact" class="font-sans text-sandstone text-sm">—</p>
              </div>
            </div>
          </div>

          <div class="border-t border-gold/10 pt-6 mb-8">
            <p class="font-sans text-[10px] tracking-[0.28em] uppercase text-gold/60 mb-4">What happens next</p>
            <div class="space-y-3">
              {[
                'Our specialists review your request and check availability.',
                'Within 24 hours you receive a personalized itinerary, options, and quotation.',
                'We refine every detail together — by WhatsApp, email, or a call.',
              ].map((step, i) => (
                <div class="flex items-start gap-4">
                  <span class="font-sans text-[10px] text-gold/60 mt-0.5 flex-shrink-0">{String(i + 1).padStart(2, '0')}</span>
                  <p class="font-sans text-sm text-sandstone font-light leading-relaxed">{step}</p>
                </div>
              ))}
            </div>
          </div>

          <p id="form-error" class="font-sans text-sm text-red-400/80 mb-4 hidden">
            Something went wrong. Please message us on WhatsApp or email reservation@veda-egypt.com
          </p>

          <div class="flex items-center justify-between">
            <button type="button" id="back-3" class="font-sans text-xs tracking-ultra uppercase text-sandstone hover:text-gold transition-colors">← Edit</button>
            <button type="submit" id="submit-btn"
              class="group inline-flex items-center gap-3 bg-gold hover:bg-gold-light text-white font-sans text-xs tracking-ultra uppercase px-8 py-4 rounded-full transition-all duration-300 disabled:opacity-60 disabled:cursor-not-allowed">
              <span id="submit-label">Submit Journey Request</span>
              <span class="group-hover:translate-x-1 transition-transform duration-300" id="submit-arrow">→</span>
              <span id="submit-spinner" class="hidden w-4 h-4 border border-white/40 border-t-white rounded-full animate-spin"></span>
            </button>
          </div>
        </div>

      </form>

      <!-- ── SUCCESS state ──────────────────────────────── -->
      <div id="success-state" class="hidden text-center py-12">
        <div class="flex items-center justify-center mb-8">
          <div class="w-16 h-16 rounded-full border border-gold/40 flex items-center justify-center">
            <svg width="24" height="20" viewBox="0 0 24 20" fill="none">
              <path d="M2 10l7 7L22 2" stroke="#a07c3a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
        <p class="font-sans text-[10px] tracking-[0.3em] uppercase text-gold mb-4">Request Received</p>
        <h2 class="font-serif text-4xl md:text-5xl text-earth font-light mb-5 leading-tight">
          Your journey request<br /><em class="italic text-gold">has been received.</em>
        </h2>
        <p class="font-sans text-sm text-sandstone font-light leading-relaxed max-w-md mx-auto mb-10">
          Our travel specialists are preparing the best options for your selected itinerary. You'll receive a personalized response within 24 hours.
        </p>

        <!-- Submitted summary -->
        <div class="border border-bone bg-sand rounded-2xl p-6 max-w-md mx-auto text-left mb-10">
          <div class="grid grid-cols-2 gap-x-8 gap-y-4">
            <div class="col-span-2">
              <p class="font-sans text-[9px] tracking-[0.2em] uppercase text-sandstone mb-1">Program</p>
              <p id="s-program" class="font-serif text-earth text-lg font-light">—</p>
              <p id="s-route" class="font-sans text-sandstone text-sm">—</p>
            </div>
            <div>
              <p class="font-sans text-[9px] tracking-[0.2em] uppercase text-sandstone mb-1">Guests</p>
              <p id="s-guests" class="font-serif text-earth text-base font-light">—</p>
            </div>
            <div>
              <p class="font-sans text-[9px] tracking-[0.2em] uppercase text-sandstone mb-1">Preferred Date</p>
              <p id="s-date" class="font-serif text-earth text-base font-light">—</p>
            </div>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a id="wa-link" href={`https://wa.me/${WHATSAPP_NUMBER}`} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2.5 bg-gold hover:bg-gold-light text-white font-sans text-xs tracking-ultra uppercase px-7 py-4 rounded-full transition-all duration-300">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.607zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
            Chat With Us on WhatsApp
