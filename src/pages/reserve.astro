</MainLayout>

<style>
  .field { color-scheme: light; }
  .field option { background: #FEFCF7; color: #2C2016; }

  .style-chip {
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    color: var(--earth);
    background: #fff;
    border: 1px solid var(--bone);
    border-radius: 9999px;
    padding: 0.55rem 1.1rem;
    transition: all 0.2s ease;
    cursor: pointer;
  }
  .style-chip:hover { border-color: rgba(var(--gold-rgb) / 0.5); }
  .style-chip.is-active { background: var(--gold); border-color: var(--gold); color: #fff; }

  .form-step { animation: stepIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both; }
  @keyframes stepIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes spin { to { transform: rotate(360deg); } }
  .animate-spin { animation: spin 0.7s linear infinite; }

  /* Hide number input spinners */
  input[type="number"]::-webkit-outer-spin-button,
  input[type="number"]::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  input[type="number"] { -moz-appearance: textfield; }
</style>

<script is:inline>
(function () {
  function $(id) { return document.getElementById(id); }

  var TOURS = {};
  try { TOURS = JSON.parse($('tours-data').textContent || '{}'); } catch (_) {}

  var selected = { program: '', route: '', styles: [] };

  /* ── Journey selection ─────────────────────── */
  function showSelected(t, idx) {
    var dir = t.routes[idx] || t.routes[0];
    var dur = t.nights + ' Nights / ' + t.days + ' Days';
    $('sj-image').src = t.image; $('sj-image').alt = t.title;
    $('sj-exp').textContent = t.experience;
    $('sj-title').textContent = t.title;
    $('sj-program').textContent = dur;
    $('sj-route').textContent = dir;
    $('journey-selected').classList.remove('hidden');
    $('journey-chooser').classList.add('hidden');
    selected.program = dur; selected.route = dir;
    $('f-program').value = dur; $('f-route').value = dir;
  }
  function showCustom() {
    $('journey-selected').classList.add('hidden');
    $('journey-chooser').classList.remove('hidden');
    selected.program = 'Custom — recommend an itinerary'; selected.route = 'To be advised';
    $('f-program').value = selected.program; $('f-route').value = selected.route;
  }

  // From the chooser dropdown
  $('journey-select').addEventListener('change', function () {
    var v = this.value;
    if (!v) return;
    if (v === 'custom') { showCustom(); return; }
    var parts = v.split('::');
    var t = TOURS[parts[0]];
    if (t) showSelected(t, parseInt(parts[1], 10) || 0);
  });

  // Change Journey → back to chooser
  $('change-journey').addEventListener('click', function () {
    $('journey-selected').classList.add('hidden');
    $('journey-chooser').classList.remove('hidden');
    $('journey-select').value = '';
    selected.program = ''; selected.route = '';
    $('f-program').value = ''; $('f-route').value = '';
  });

  // Pre-select from ?tour=&route=
  (function () {
    var params = new URLSearchParams(location.search);
    var id = params.get('tour');
    if (id && TOURS[id]) {
      var idx = parseInt(params.get('route') || '0', 10);
      if (isNaN(idx) || idx < 0 || idx >= TOURS[id].routes.length) idx = 0;
      showSelected(TOURS[id], idx);
    }
  })();

  /* ── Guest steppers ────────────────────────── */
  document.querySelectorAll('[data-step-btn]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var inp = $(btn.dataset.stepBtn);
      var min = parseInt(inp.min) || 0, max = parseInt(inp.max) || 50;
      var v = (parseInt(inp.value) || min) + parseInt(btn.dataset.dir);
      inp.value = Math.max(min, Math.min(max, v));
    });
  });

  /* ── Travel style chips ────────────────────── */
  document.querySelectorAll('.style-chip').forEach(function (chip) {
    chip.addEventListener('click', function () {
      chip.classList.toggle('is-active');
      selected.styles = Array.prototype.slice.call(document.querySelectorAll('.style-chip.is-active')).map(function (c) { return c.dataset.value; });
      $('f-travelStyle').value = selected.styles.join(', ');
    });
  });

  /* ── Step indicator ────────────────────────── */
  function updateIndicator(step) {
    document.querySelectorAll('.step-marker').forEach(function (marker) {
      var s = parseInt(marker.dataset.step);
      var dot = marker.querySelector('.step-dot');
      var label = marker.querySelector('p');
      if (s < step) {
        dot.className = 'step-dot w-8 h-8 rounded-full border border-gold bg-gold flex items-center justify-center font-sans text-xs text-white transition-all duration-300';
        dot.innerHTML = '<svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4l3 3 5-6" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
        label.className = 'font-sans text-[12px] tracking-[0.2em] uppercase text-gold mt-2';
      } else if (s === step) {
        dot.className = 'step-dot w-8 h-8 rounded-full border border-gold flex items-center justify-center font-sans text-xs text-gold bg-gold/10 transition-all duration-300';
        dot.textContent = s;
        label.className = 'font-sans text-[12px] tracking-[0.2em] uppercase text-gold mt-2';
      } else {
        dot.className = 'step-dot w-8 h-8 rounded-full border border-bone flex items-center justify-center font-sans text-xs text-sandstone/50 transition-all duration-300';
        dot.textContent = s;
        label.className = 'font-sans text-[12px] tracking-[0.2em] uppercase text-sandstone/50 mt-2';
      }
    });
    $('line-1-2').style.background = step > 1 ? 'rgba(160,124,58,0.60)' : 'rgba(160,124,58,0.20)';
    $('line-2-3').style.background = step > 2 ? 'rgba(160,124,58,0.60)' : 'rgba(160,124,58,0.20)';
  }

  function showStep(n) {
    [1, 2, 3].forEach(function (s) { $('step-' + s).classList.toggle('hidden', s !== n); });
    updateIndicator(n);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  /* ── Validation ────────────────────────────── */
  function validateStep1() {
    if (!selected.program) {
      document.querySelector('.journey-error').classList.remove('hidden');
      return false;
    }
    document.querySelector('.journey-error').classList.add('hidden');
    if (!$('preferredDate').value.trim()) {
      $('preferredDate').style.borderColor = 'rgba(248,113,113,0.5)';
      return false;
    }
    return true;
  }
  function validateStep2() {
    var ok = true;
    [$('fullName'), $('email'), $('whatsapp'), $('country')].forEach(function (f) {
      if (!f.value.trim()) { f.style.borderColor = 'rgba(248,113,113,0.5)'; ok = false; }
      else f.style.borderColor = '';
    });
    var email = $('email').value;
    if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { $('email').style.borderColor = 'rgba(248,113,113,0.5)'; ok = false; }
    return ok;
  }

  /* ── Summaries ─────────────────────────────── */
  function guestsText() {
    var a = parseInt($('adults').value) || 0, c = parseInt($('children').value) || 0;
    var out = a + (a === 1 ? ' Adult' : ' Adults');
    if (c > 0) out += ', ' + c + (c === 1 ? ' Child' : ' Children');
    return out;
  }
  function populateReview() {
    $('r-program').textContent = selected.program || '—';
    $('r-route').textContent   = selected.route || '—';
    $('r-date').textContent    = $('preferredDate').value || '—';
    $('r-guests').textContent  = guestsText();
    $('r-boat').textContent    = $('boatPreference').value;
    $('r-style').textContent   = selected.styles.length ? selected.styles.join(', ') : '—';
    $('r-name').textContent    = $('fullName').value || '—';
    $('r-contact').textContent = [$('email').value, $('whatsapp').value].filter(Boolean).join('  ·  ') || '—';
  }
  function populateSuccess() {
    $('s-program').textContent = selected.program || '—';
    $('s-route').textContent   = selected.route || '—';
    $('s-guests').textContent  = guestsText();
    $('s-date').textContent    = $('preferredDate').value || '—';
  }

  /* ── Navigation ────────────────────────────── */
  $('next-1').addEventListener('click', function () { if (validateStep1()) showStep(2); });
  $('back-2').addEventListener('click', function () { showStep(1); });
  $('next-2').addEventListener('click', function () { if (validateStep2()) { populateReview(); showStep(3); } });
  $('back-3').addEventListener('click', function () { showStep(2); });

  /* ── Submit ────────────────────────────────── */
  $('reserve-form').addEventListener('submit', async function (e) {
    e.preventDefault();
    var btn = $('submit-btn'), label = $('submit-label'), arrow = $('submit-arrow'), spinner = $('submit-spinner'), errMsg = $('form-error');
    btn.disabled = true; label.textContent = 'Sending…'; arrow.classList.add('hidden'); spinner.classList.remove('hidden'); errMsg.classList.add('hidden');
    try {
      var res = await fetch(e.target.action, { method: 'POST', body: new FormData(e.target), headers: { Accept: 'application/json' } });
      if (!res.ok) throw new Error('err');
      populateSuccess();
      $('reserve-form').classList.add('hidden');
      $('step-indicator').classList.add('hidden');
      $('success-state').classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    } catch (_) {
      errMsg.classList.remove('hidden');
      btn.disabled = false; label.textContent = 'Submit Journey Request'; arrow.classList.remove('hidden'); spinner.classList.add('hidden');
    }
  });

  document.querySelectorAll('.field').forEach(function (f) { f.addEventListener('focus', function () { this.style.borderColor = ''; }); });

  updateIndicator(1);
})();
</script>
