---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('itineraries', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const SITE = 'https://www.veda-egypt.com';
const { entry } = Astro.props;
const it = entry.data;

// Quick facts for a given route — duration + route-derived, then shared extras.
function factsFor(route: (typeof it.routes)[number]) {
  return [
    { label: 'Duration', value: `${it.nights} Nights · ${it.days} Days` },
    { label: 'Route', value: route.label },
    { label: 'Embark', value: route.from },
    { label: 'Disembark', value: route.to },
    ...it.facts,
  ];
}

const multiRoute = it.routes.length > 1;

// ── "Good to Know" — shared defaults, overridable per itinerary ──
const DEFAULT_TIPS = [
  'This itinerary involves significant walking at archaeological sites, often on uneven ground.',
  'Comfortable shoes, sun protection, and water are essential for daily excursions.',
  'The sailing schedule and overnight mooring locations are subject to change based on river and lock conditions.',
];
const DEFAULT_NOTES =
  'This itinerary provides a general framework; the order of visits on specific days may be arranged by your guide to ensure the best possible experience based on conditions.';
const tips = it.tips.length > 0 ? it.tips : DEFAULT_TIPS;
const insights = it.insights;
const travelNotes = it.travelNotes ?? DEFAULT_NOTES;

const faqSchema =
  it.faq.length > 0
    ? JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        '@id': `${SITE}/itineraries/${entry.id}#faq`,
        mainEntity: it.faq.map((f) => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a },
        })),
      })
    : undefined;

const tripSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'TouristTrip',
  '@id': `${SITE}/itineraries/${entry.id}#trip`,
  name: `${it.nights} Nights — ${it.title}`,
  description: it.summary,
  image: `${SITE}${it.hero}`,
  url: `${SITE}/itineraries/${entry.id}`,
  touristType: ['Private charter', 'Families', 'Couples', 'Retreat groups'],
  itinerary: it.routes[0].timeline.map((d, i) => ({
    '@type': 'TouristDestination',
    name: d.title,
    description: d.description,
    position: i + 1,
  })),
  provider: { '@type': 'TravelAgency', name: 'VEDA Egypt', url: SITE },
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    url: `${SITE}/contact`,
    priceSpecification: {
      '@type': 'PriceSpecification',
      description: 'On request — quoted per group, season and length of stay.',
    },
  },
});

const extraSchema = [tripSchema, faqSchema].filter(Boolean).join('\n');
---

<MainLayout
  title={`${it.title} — ${it.nights} Nights · VEDA Egypt`}
  description={it.summary}
  ogImage={it.hero}
  extraSchema={extraSchema}
>

  <!-- 1 ── Hero ──────────────────────────────────── -->
  <div class="relative flex items-end min-h-[78vh] pt-40 pb-20 overflow-hidden">
    <div class="absolute inset-0">
      <img src={it.hero} alt={it.title} class="w-full h-full object-cover object-center" loading="eager"/>
    </div>
    <div class="absolute inset-0 bg-void/45"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-void/50 via-transparent to-void/85"></div>
    <div class="relative w-full max-w-7xl mx-auto px-6 lg:px-12">
      <a href="/itineraries" class="inline-flex items-center gap-2 font-sans text-[11px] tracking-[0.25em] uppercase text-white/70 hover:text-gold-light transition-colors mb-6">
        <span>←</span> All Itineraries
      </a>
      <div class="flex items-center gap-3 mb-4">
        <span class="font-sans text-[11px] tracking-[0.25em] uppercase text-gold-light bg-void/50 border border-gold/25 px-3 py-1.5">
          {it.experience}
        </span>
        <span class="font-sans text-[11px] tracking-[0.25em] uppercase text-white/85 bg-void/50 border border-white/15 px-3 py-1.5">
          {it.nights} Nights · {it.days} Days
        </span>
      </div>
      <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl text-white font-light tracking-tight leading-[1.05] mb-5 max-w-3xl"
        style="text-shadow: 0 2px 28px rgba(0,0,0,0.45);">
        {it.title}
      </h1>
      <p class="font-sans text-base md:text-lg text-white/80 font-light max-w-xl leading-relaxed">
        {it.summary}
      </p>
    </div>
  </div>

  <!-- 2 ── Quick Facts (swap with direction) ─────── -->
  <section class="bg-forest border-y border-gold/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      {it.routes.map((route, ri) => (
        <dl class="route-facts grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 divide-x divide-gold/10" data-route={ri} hidden={ri !== 0}>
          {factsFor(route).map((f) => (
            <div class="px-5 py-7 lg:py-9">
              <dt class="font-sans text-[10px] tracking-[0.24em] uppercase text-gold mb-2">{f.label}</dt>
              <dd class="font-serif text-lg lg:text-xl text-ivory font-light leading-tight">{f.value}</dd>
            </div>
          ))}
        </dl>
      ))}
    </div>
  </section>

  <!-- 3 ── Route Overview + Direction selection ──── -->
  <section class="bg-linen py-20 lg:py-28 border-b border-bone">
    <div class={`max-w-7xl mx-auto px-6 lg:px-12 grid grid-cols-1 ${multiRoute ? 'lg:grid-cols-[3fr_2fr]' : ''} gap-12 lg:gap-20 items-start`}>
      <div class="reveal">
        <div class="flex items-center gap-4 mb-6">
          <span class="h-px w-8 bg-gold/50"></span>
          <p class="font-sans text-[12px] tracking-[0.3em] uppercase text-gold">Route Overview</p>
        </div>
        {it.routes.map((route, ri) => (
          <div class="route-overview" data-route={ri} hidden={ri !== 0}>
            <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl text-earth font-light tracking-tight leading-tight mb-6">
              {route.tagline ?? 'The voyage, end to end'}
            </h2>
            <p class="font-sans text-base lg:text-lg text-sandstone font-light leading-relaxed max-w-xl">
              {route.overview ?? it.routeOverview ?? it.description ?? it.summary}
            </p>
          </div>
        ))}
      </div>

      {multiRoute && (
        <div class="reveal reveal-delay-1 bg-sand border border-bone rounded-2xl p-7 lg:p-8">
          <p class="font-sans text-[11px] tracking-[0.24em] uppercase text-gold mb-5">Available Routes</p>
          <div id="route-toggle" class="flex flex-col gap-3">
            {it.routes.map((r, i) => (
              <button
                type="button"
                class={`route-opt group flex items-center justify-between gap-4 rounded-xl border px-5 py-4 text-left transition-all duration-300 ${i === 0 ? 'is-active border-gold bg-gold/5' : 'border-bone hover:border-gold/40'}`}
                data-route={i}
                aria-pressed={i === 0 ? 'true' : 'false'}
              >
                <span class="font-serif text-xl text-earth font-light">{r.label}</span>
                <span class="route-check font-sans text-gold text-lg">{i === 0 ? '✓' : '→'}</span>
              </button>
            ))}
          </div>
          <p class="font-sans text-sm text-sandstone/80 font-light leading-relaxed mt-5">
            The same temples and experiences, with the order tailored to your arrival city. Select a direction
            and the day-by-day below will follow.
          </p>
        </div>
      )}
    </div>
  </section>

  <!-- 4 ── Highlights ────────────────────────────── -->
  <section class="bg-sand py-20 lg:py-28 border-b border-bone">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="flex items-center gap-4 mb-10 reveal">
        <span class="h-px w-8 bg-gold/50"></span>
        <p class="font-sans text-[12px] tracking-[0.3em] uppercase text-gold">Highlights</p>
      </div>
      <ul class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
        {it.highlights.map((h, i) => (
          <li class={`flex items-center gap-3 bg-linen border border-bone rounded-xl px-4 py-5 reveal reveal-delay-${Math.min(i + 1, 6)}`}>
            <span class="h-1.5 w-1.5 rounded-full bg-gold flex-shrink-0"></span>
            <span class="font-sans text-sm text-earth font-light leading-snug">{h}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 5 ── Day-by-Day (one timeline per direction) ─ -->
  <section class="bg-void py-20 lg:py-28">
    <div class="max-w-5xl mx-auto px-6 lg:px-12">
      <div class="text-center mb-16 reveal">
        <div class="flex items-center justify-center gap-4 mb-5">
          <span class="h-px w-8 bg-gold/50"></span>
          <p class="font-sans text-[12px] tracking-[0.3em] uppercase text-gold">Day by Day</p>
          <span class="h-px w-8 bg-gold/50"></span>
        </div>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl text-ivory font-light tracking-tight leading-tight">
          Your journey, <em class="italic text-gold-pale">unhurried</em>
        </h2>
        {multiRoute && !it.comingSoon && (
          <p class="font-sans text-sm text-warm-gray mt-4">
            Showing <span id="active-route-label" class="text-gold-pale">{it.routes[0].label}</span>
          </p>
        )}
      </div>

      {it.comingSoon ? (
        <div class="max-w-xl mx-auto text-center border border-gold/20 rounded-2xl px-8 py-12 bg-forest/40">
          <p class="font-sans text-[12px] tracking-[0.3em] uppercase text-gold mb-4">In Preparation</p>
          <p class="font-serif text-2xl md:text-3xl text-ivory font-light leading-snug mb-5">
            The full day-by-day for this voyage is being finalised.
          </p>
          <p class="font-sans text-base text-warm-gray font-light leading-relaxed mb-8">
            Tell us your dates and we'll share the complete itinerary, tailored to your group and chosen direction.
          </p>
          <a href="/contact" class="book-cta group inline-flex items-center justify-center gap-3 bg-gold hover:bg-gold-light text-white font-sans text-xs tracking-ultra uppercase px-7 py-3.5 rounded-full transition-all duration-300">
            Request the Full Itinerary
            <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
          </a>
        </div>
      ) : it.routes.map((route, ri) => (
        <ol class="route-timeline relative" data-route={ri} hidden={ri !== 0}>
          <!-- vertical line -->
          <div class="absolute left-[15px] md:left-1/2 md:-translate-x-1/2 top-2 bottom-2 w-px bg-gold/20" aria-hidden="true"></div>

          {route.timeline.map((d, i) => (
            <li class="relative pl-12 md:pl-0 mb-12 last:mb-0">
              <div class="md:grid md:grid-cols-2 md:gap-12 items-center">
                <span class="absolute left-[9px] md:left-1/2 md:-translate-x-1/2 top-2 w-3.5 h-3.5 rounded-full bg-gold border-2 border-void z-10" aria-hidden="true"></span>

                <div class={`${i % 2 === 0 ? 'md:order-1 md:text-right md:pr-6' : 'md:order-2 md:pl-6'}`}>
                  <p class="font-sans text-[11px] tracking-[0.3em] uppercase text-gold mb-2">Day {i + 1}</p>
                  <h3 class="font-serif text-2xl md:text-3xl text-ivory font-light leading-tight mb-3">{d.title}</h3>
                  {d.places.length > 0 && (
                    <ul class={`flex flex-wrap gap-2 mb-4 ${i % 2 === 0 ? 'md:justify-end' : ''}`}>
                      {d.places.map((p) => (
                        <li class="font-sans text-[11px] tracking-wide text-gold-pale/80 border border-gold/20 rounded-full px-3 py-1">{p}</li>
                      ))}
                    </ul>
                  )}
                  <p class="font-sans text-base text-warm-gray font-light leading-relaxed">{d.description}</p>

                  {d.schedule.length > 0 && (
                    <ul class={`day-prog mt-5 w-full max-w-md text-left ${i % 2 === 0 ? 'md:ml-auto' : ''}`}>
                      {d.schedule.map((s) => (
                        <li class="day-prog-row flex gap-4">
                          <span class="font-sans text-[10px] tracking-[0.16em] uppercase text-gold/90 w-24 flex-shrink-0 leading-relaxed pt-px">{s.time}</span>
                          <span class="font-sans text-[13px] text-ivory/85 font-light leading-snug">{s.text}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>

                <div class={`mt-5 md:mt-0 ${i % 2 === 0 ? 'md:order-2' : 'md:order-1'}`}>
                  {d.image && (
                    <div class="overflow-hidden rounded-xl border border-gold/10" style="aspect-ratio:16/10;">
                      <img src={d.image} alt={d.title} class="w-full h-full object-cover" loading="lazy" />
                    </div>
                  )}
                </div>
              </div>
            </li>
          ))}
        </ol>
      ))}
    </div>
  </section>

  <!-- 5b ── Good to Know (Tips · Insight · Notes) ── -->
  {!it.comingSoon && (
    <section class="bg-sand py-20 lg:py-28 border-t border-bone">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="flex items-center gap-4 mb-10 lg:mb-12 reveal">
          <span class="h-px w-8 bg-gold/50"></span>
          <p class="font-sans text-[12px] tracking-[0.3em] uppercase text-gold">Good to Know</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 items-start">
          {it.routes.some((r) => (r.insights.length > 0 ? r.insights : insights).length > 0) && (
            <div class="reveal bg-linen border border-bone rounded-2xl p-7 lg:p-9 lg:row-span-2">
              <p class="font-sans text-[11px] tracking-[0.28em] uppercase text-gold mb-6">Travel Insight</p>
              {it.routes.map((route, ri) => {
                const list = route.insights.length > 0 ? route.insights : insights;
                return list.length > 0 ? (
                  <ul class="route-insight space-y-5" data-route={ri} hidden={ri !== 0}>
                    {list.map((t) => (
                      <li class="flex items-start gap-3 font-sans text-base text-sandstone font-light leading-relaxed">
                        <span class="mt-[0.55rem] h-1.5 w-1.5 rounded-full bg-gold flex-shrink-0"></span>
                        <span>{t}</span>
                      </li>
                    ))}
                  </ul>
                ) : null;
              })}
            </div>
          )}

          <div class="reveal reveal-delay-1 bg-linen border border-bone rounded-2xl p-7 lg:p-9">
            <p class="font-sans text-[11px] tracking-[0.28em] uppercase text-gold mb-6">Tips for Your Trip</p>
            <ul class="space-y-4">
              {tips.map((t) => (
                <li class="flex items-start gap-3 font-sans text-base text-sandstone font-light leading-relaxed">
                  <span class="mt-[0.55rem] h-1.5 w-1.5 rounded-full bg-gold flex-shrink-0"></span>
                  <span>{t}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="reveal reveal-delay-2 bg-linen border border-bone rounded-2xl p-7 lg:p-9">
            <p class="font-sans text-[11px] tracking-[0.28em] uppercase text-gold mb-4">Travel Notes</p>
            <p class="font-sans text-base text-sandstone font-light leading-relaxed">{travelNotes}</p>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- 7 ── FAQ ───────────────────────────────────── -->
  {it.faq.length > 0 && (
    <section class="bg-sand py-20 lg:py-28 border-b border-bone">
      <div class="max-w-3xl mx-auto px-6 lg:px-12">
        <div class="flex items-center gap-4 mb-10 reveal">
          <span class="h-px w-8 bg-gold/50"></span>
          <p class="font-sans text-[12px] tracking-[0.3em] uppercase text-gold">Questions</p>
        </div>
        <div class="divide-y divide-bone border-t border-bone">
          {it.faq.map((f) => (
            <details class="group py-5">
              <summary class="flex items-center justify-between gap-6 cursor-pointer list-none">
                <span class="font-serif text-xl md:text-2xl text-earth font-light leading-snug">{f.q}</span>
                <span class="font-sans text-gold text-xl flex-shrink-0 transition-transform duration-300 group-open:rotate-45">+</span>
              </summary>
              <p class="font-sans text-base text-sandstone font-light leading-relaxed mt-4 max-w-2xl">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 7b ── What's Included — all-inclusive charter ─────────── -->
  <section class="bg-linen py-20 lg:py-28 border-t border-bone">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">

      <div class="text-center max-w-2xl mx-auto mb-12 reveal">
        <div class="flex items-center justify-center gap-4 mb-5">
          <span class="h-px w-8 bg-gold/50"></span>
          <p class="font-sans text-[12px] tracking-[0.3em] uppercase text-gold">All-Inclusive Charter</p>
          <span class="h-px w-8 bg-gold/50"></span>
        </div>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl text-earth font-light tracking-tight leading-tight mb-4">What's Included</h2>
        <p class="font-sans text-base text-earth-mid leading-relaxed">
          Your charter rate is full-board — a complete luxury sailing experience, with no hidden fees.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            title: 'Gourmet Dining',
            items: [
              'Breakfast — extensive open buffet with hot & cold selections',
              'Lunch — open buffet with a live outdoor barbecue station',
              'Dinner — generous open buffet',
              'Daily sunset tea service on deck, with premium teas & snacks',
            ],
          },
          {
            title: 'Beverages, All Day',
            items: [
              '24-hour service: bottled mineral water, fresh juices (orange, lemonade, hibiscus), soft drinks & daily smoothies',
              'Specialty coffees — espresso, macchiato, American, Egyptian — and a premium tea selection',
              'Complimentary local premium beer & wine',
            ],
          },
          {
            title: 'No Hidden Fees',
            items: [
              'All onboard meals & beverages included',
              '14% VAT (Value Added Tax) included',
              '12% service charges included',
            ],
          },
        ].map((col, ci) => (
          <div class={`border border-bone bg-sand rounded-2xl p-8 reveal reveal-delay-${ci + 1}`}>
            <p class="font-sans text-[11px] tracking-[0.22em] uppercase text-gold mb-5">{col.title}</p>
            <ul class="space-y-3.5">
              {col.items.map((inc) => (
                <li class="flex items-start gap-3 font-sans text-[15px] font-light leading-relaxed text-earth-mid">
                  <span class="mt-[0.5rem] h-1.5 w-1.5 rounded-full bg-gold flex-shrink-0"></span>
                  <span>{inc}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Gratuity note -->
      <div class="mt-6 border border-bone rounded-2xl bg-sand/60 px-6 py-5 flex items-start gap-3.5 reveal">
        <span class="flex-shrink-0 text-gold mt-0.5">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8h.01M11 12h1v4h1"/></svg>
        </span>
        <p class="font-sans text-sm text-earth-mid font-light leading-relaxed">
          <span class="text-earth font-normal">Crew gratuity is not included.</span> It is customary for guests to contribute
          US $6 per person per night, handed to the dahabiya's manager and shared equally among the crew.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-5 sm:gap-10 mt-10 reveal">
        <a href="/dining" class="group inline-flex items-center gap-2.5 font-sans text-[12px] tracking-[0.22em] uppercase text-earth hover:text-gold transition-colors">
          View the full meal plan
          <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
        </a>
        <a href="/charter-terms" class="group inline-flex items-center gap-2.5 font-sans text-[12px] tracking-[0.22em] uppercase text-earth hover:text-gold transition-colors">
          View full charter terms
          <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 8 ── Booking CTA ───────────────────────────── -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img src={it.hero} alt="" class="w-full h-full object-cover" loading="lazy" />
      <div class="absolute inset-0 bg-gradient-to-b from-void/70 via-forest/88 to-void/96"></div>
    </div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 lg:px-12 py-28 lg:py-40 text-center">
      <p class="font-sans text-[14px] tracking-[0.3em] uppercase text-gold-light mb-6 reveal">Begin Here</p>
      <h2 class="font-serif text-4xl md:text-6xl text-white font-light tracking-tight leading-[1.05] mb-6 reveal reveal-delay-1"
        style="text-shadow: 0 2px 40px rgba(0,0,0,0.4);">
        Reserve this<br />journey
      </h2>
      <p class="font-sans text-base text-ivory/60 max-w-md mx-auto leading-relaxed mb-12 reveal reveal-delay-2">
        {it.nights} nights on the Nile, entirely private and tailored to your group. Tell us your dates and we'll do the rest.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center reveal reveal-delay-3">
        <a href="/contact" class="book-cta group inline-flex items-center justify-center gap-3 bg-gold hover:bg-gold-light text-white font-sans text-xs tracking-ultra uppercase px-8 py-4 rounded-full transition-all duration-300">
          Request This Itinerary
          <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
        </a>
        <a href="/itineraries" class="group inline-flex items-center justify-center gap-3 border border-white/25 hover:border-gold text-white/80 hover:text-gold font-sans text-xs tracking-ultra uppercase px-8 py-4 rounded-full transition-all duration-300 hover:bg-gold/10 backdrop-blur-sm">
          Browse All Itineraries
          <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
        </a>
      </div>
    </div>
  </section>

</MainLayout>

<style>
  details > summary::-webkit-details-marker { display: none; }
  /* The `hidden` attribute must win over Tailwind display utilities
     (e.g. `grid` on the quick-facts <dl>), otherwise inactive routes leak. */
  [hidden] { display: none !important; }

  /* Day-by-day program — striped, PDF-style itemised list */
  .day-prog { border: 1px solid rgba(201, 168, 92, 0.14); border-radius: 12px; overflow: hidden; }
  .day-prog-row { padding: 0.6rem 0.9rem; align-items: flex-start; }
  .day-prog-row:nth-child(odd) { background: rgba(255, 255, 255, 0.035); }
</style>

<script>
  // ── Direction toggle: swap quick facts + day-by-day timeline ──
  const toggle = document.getElementById('route-toggle');
  if (toggle) {
    const opts = Array.from(toggle.querySelectorAll<HTMLButtonElement>('.route-opt'));
    const facts = Array.from(document.querySelectorAll<HTMLElement>('.route-facts'));
    const timelines = Array.from(document.querySelectorAll<HTMLElement>('.route-timeline'));
    const overviews = Array.from(document.querySelectorAll<HTMLElement>('.route-overview'));
    const routeInsights = Array.from(document.querySelectorAll<HTMLElement>('.route-insight'));
    const bookCtas = Array.from(document.querySelectorAll<HTMLAnchorElement>('.book-cta'));
    const label = document.getElementById('active-route-label');

    function activate(index: number) {
      opts.forEach((o) => {
        const on = Number(o.dataset.route) === index;
        o.classList.toggle('is-active', on);
        o.classList.toggle('border-gold', on);
        o.classList.toggle('bg-gold/5', on);
        o.classList.toggle('border-bone', !on);
        o.setAttribute('aria-pressed', on ? 'true' : 'false');
        const chk = o.querySelector('.route-check');
        if (chk) chk.textContent = on ? '✓' : '→';
        if (on && label) label.textContent = o.querySelector('span')?.textContent ?? '';
      });
      facts.forEach((el) => (el.hidden = Number(el.dataset.route) !== index));
      timelines.forEach((el) => (el.hidden = Number(el.dataset.route) !== index));
      overviews.forEach((el) => (el.hidden = Number(el.dataset.route) !== index));
      routeInsights.forEach((el) => (el.hidden = Number(el.dataset.route) !== index));
      bookCtas.forEach((a) => (a.href = a.href.replace(/([?&]route=)\d+/, '$1' + index)));
    }

    opts.forEach((opt) =>
      opt.addEventListener('click', () => activate(Number(opt.dataset.route))),
    );

    // Deep-link: /itineraries/<slug>?route=<index> opens that direction.
    const wanted = Number(new URLSearchParams(location.search).get('route'));
    if (Number.isInteger(wanted) && wanted > 0 && wanted < opts.length) activate(wanted);
  }
</script>
