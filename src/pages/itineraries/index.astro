---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const SITE = 'https://www.veda-egypt.com';
const all = await getCollection('itineraries', ({ data }) => !data.draft);

// ── Helpers ───────────────────────────────────────────────────────────────
const slug = (s: string) => s.toLowerCase().replace(/\s+/g, '-');
const expValue = (e: string) =>
  e === 'Classic Cruise' ? 'classic' : e === 'Dendera & Abydos' ? 'dendera' : 'grand';
const expLabel = (e: string) => (e === 'Classic Cruise' ? 'Classic Nile Cruise' : e);

// ── Explode each itinerary into one card per direction ────────────────────
type Card = {
  id: string; routeIndex: number; nights: number; days: number;
  durationId: string; label: string; experience: string; expValue: string;
  expLabel: string; highlights: string[]; vesselIds: string[];
  image: string; comingSoon: boolean; routeIds: string[]; href: string;
};
const cards: Card[] = [];
for (const it of all) {
  it.data.routes.forEach((route, i) => {
    const f = slug(route.from);
    const t = slug(route.to);
    const routeIds =
      f === t
        ? [`${f}-roundtrip`]
        : it.data.experience === 'Dendera & Abydos'
          ? [`${f}-${t}`, `${f}-dendera-${t}`]
          : [`${f}-${t}`];
    cards.push({
      id: it.id,
      routeIndex: i,
      nights: it.data.nights,
      days: it.data.days,
      durationId: `${it.data.nights}n${it.data.days}d`,
      label: route.label,
      experience: it.data.experience,
      expValue: expValue(it.data.experience),
      expLabel: expLabel(it.data.experience),
      highlights: it.data.highlights,
      vesselIds: it.data.vessels.map(slug),
      image: it.data.cardImage,
      comingSoon: it.data.comingSoon,
      routeIds,
      href: it.data.routes.length > 1 ? `/itineraries/${it.id}?route=${i}` : `/itineraries/${it.id}`,
    });
  });
}
cards.sort((a, b) => a.nights - b.nights || a.label.localeCompare(b.label));

// ── Filter option lists ───────────────────────────────────────────────────
const DURATIONS = [
  { v: '3n4d', l: '3 Nights / 4 Days' },
  { v: '4n5d', l: '4 Nights / 5 Days' },
  { v: '5n6d', l: '5 Nights / 6 Days' },
  { v: '6n7d', l: '6 Nights / 7 Days' },
  { v: '7n8d', l: '7 Nights / 8 Days' },
  { v: '12n13d', l: '12 Nights / 13 Days' },
  { v: '13n14d', l: '13 Nights / 14 Days' },
];
const ROUTES = [
  { v: 'aswan-luxor', l: 'Aswan → Luxor' },
  { v: 'luxor-aswan', l: 'Luxor → Aswan' },
  { v: 'aswan-dendera-luxor', l: 'Aswan → Dendera → Luxor' },
  { v: 'luxor-dendera-aswan', l: 'Luxor → Dendera → Aswan' },
  { v: 'cairo-luxor', l: 'Cairo → Luxor' },
  { v: 'luxor-cairo', l: 'Luxor → Cairo' },
  { v: 'cairo-aswan', l: 'Cairo → Aswan' },
  { v: 'aswan-cairo', l: 'Aswan → Cairo' },
  { v: 'luxor-roundtrip', l: 'Luxor Roundtrip' },
];
const EXPERIENCES = [
  { v: 'classic', l: 'Classic Nile Cruise' },
  { v: 'dendera', l: 'Dendera & Abydos' },
  { v: 'grand', l: 'Grand Journey' },
];
const VESSELS = [
  { v: 'veda-i', l: 'Veda I' },
  { v: 'veda-ii', l: 'Veda II' },
  { v: 'veda-iii', l: 'Veda III' },
  { v: 'veda-iv', l: 'Veda IV' },
];

const FILTERS = [
  { key: 'duration', label: 'Duration', options: DURATIONS },
  { key: 'route', label: 'Route', options: ROUTES },
  { key: 'experience', label: 'Experience', options: EXPERIENCES },
  { key: 'vessel', label: 'Vessel', options: VESSELS },
];

const itinerarySchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  '@id': `${SITE}/itineraries#list`,
  name: 'VEDA Egypt Nile Cruise Itineraries',
  numberOfItems: cards.length,
  itemListElement: cards.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${SITE}${c.href}`,
    name: `${c.nights} Nights — ${c.label}`,
  })),
});
---

<MainLayout
  title="Itineraries — VEDA Egypt"
  description="Explore VEDA's collection of handcrafted Nile cruise itineraries, from classic voyages to extended journeys through Egypt's most remarkable landscapes and monuments."
  extraSchema={itinerarySchema}
>

  <!-- ── Hero ─────────────────────────────────────── -->
  <div class="relative flex items-center min-h-[58vh] pt-40 pb-24 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/dsc-1797-pano-1280x800.jpg" alt="" width="1280" height="800" class="w-full h-full object-cover object-center" loading="eager"/>
    </div>
    <div class="absolute inset-0 bg-void/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-void/55 via-transparent to-void/80"></div>
    <div class="relative w-full max-w-7xl mx-auto px-6 lg:px-12 text-center">
      <div class="flex items-center justify-center gap-4 mb-6">
        <span class="h-px w-10 bg-gold-light/60"></span>
        <p class="font-sans text-[14px] tracking-[0.32em] uppercase text-gold-light">Nile Voyages</p>
        <span class="h-px w-10 bg-gold-light/60"></span>
      </div>
      <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl text-white font-light tracking-tight leading-tight mb-7"
        style="text-shadow: 0 2px 28px rgba(0,0,0,0.45);">
        Itineraries
      </h1>
      <p class="font-sans text-base md:text-lg text-white/80 font-light max-w-2xl mx-auto leading-relaxed">
        Explore our collection of handcrafted Nile cruise itineraries, from classic voyages to
        extended journeys through Egypt's most remarkable landscapes and monuments.
      </p>
    </div>
  </div>

  <!-- ── Filter bar (sticky) ──────────────────────── -->
  <div class="sticky top-20 z-40 bg-linen/95 backdrop-blur-md border-y border-bone">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-4">
      <div class="flex items-center justify-between gap-4">
        <!-- Mobile trigger -->
        <button id="filter-open" type="button"
          class="md:hidden inline-flex items-center gap-2 border border-bone rounded-full px-5 py-2.5 font-sans text-[12px] tracking-[0.18em] uppercase text-earth">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 5h18M6 12h12M10 19h4"/></svg>
          Filters <span id="filter-count-badge" class="text-gold"></span>
        </button>

        <!-- Desktop inline filters + mobile drawer panel -->
        <div id="filter-panel" class="filter-panel">
          <div class="filter-panel-inner flex flex-col md:flex-row md:items-end gap-4 md:gap-5 flex-1">
            <p class="md:hidden font-serif text-2xl text-earth font-light mb-2">Refine your voyage</p>
            {FILTERS.map((f) => (
              <div class="flex flex-col gap-1.5 md:flex-1 md:min-w-0">
                <label class="font-sans text-[10px] tracking-[0.24em] uppercase text-earth/55" for={`f-${f.key}`}>
                  {f.label}{f.key === 'vessel' ? ' (optional)' : ''}
                </label>
                <div class="relative">
                  <select id={`f-${f.key}`} data-filter={f.key} class="vfilter w-full appearance-none bg-linen border border-bone rounded-xl pl-4 pr-9 py-2.5 font-sans text-sm text-earth focus:outline-none focus:border-gold/60 transition-colors cursor-pointer">
                    <option value="any">Any</option>
                    {f.options.map((o) => <option value={o.v}>{o.l}</option>)}
                  </select>
                  <span class="pointer-events-none absolute right-3.5 top-1/2 -translate-y-1/2 text-gold text-xs">▾</span>
                </div>
              </div>
            ))}
          </div>
          <!-- Mobile drawer actions -->
          <div class="md:hidden flex gap-3 mt-6">
            <button id="filter-clear-m" type="button" class="flex-1 border border-bone rounded-full py-3 font-sans text-[12px] tracking-[0.18em] uppercase text-earth">Clear</button>
            <button id="filter-done" type="button" class="flex-1 bg-gold text-white rounded-full py-3 font-sans text-[12px] tracking-[0.18em] uppercase">Show results</button>
          </div>
        </div>

        <!-- Desktop clear -->
        <button id="filter-clear" type="button"
          class="hidden md:inline-flex items-center font-sans text-[11px] tracking-[0.18em] uppercase text-sandstone hover:text-gold transition-colors whitespace-nowrap">
          Clear all ×
        </button>
      </div>
    </div>
  </div>
  <div id="filter-backdrop" class="fixed inset-0 z-30 bg-void/50 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity md:hidden"></div>

  <!-- ── Results ──────────────────────────────────── -->
  <section class="bg-linen py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <p id="result-count" class="font-sans text-sm tracking-[0.05em] text-sandstone mb-8" aria-live="polite">
        {cards.length} itineraries available
      </p>

      <div id="cards-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-7">
        {cards.map((c) => (
          <article
            class="filter-card group flex flex-col bg-sand border border-bone rounded-2xl overflow-hidden hover:border-gold/40 transition-all duration-500 reveal"
            data-duration={c.durationId}
            data-routes={c.routeIds.join('|')}
            data-experience={c.expValue}
            data-vessels={c.vesselIds.join('|')}
          >
            <a href={c.href} class="relative block overflow-hidden" style="aspect-ratio:16/10;">
              <img src={c.image} alt={c.label} class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1200ms] group-hover:scale-105" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-void/80 via-void/15 to-transparent"></div>
              <div class="absolute top-4 left-4 flex flex-wrap gap-2">
                <span class="bg-void/70 backdrop-blur-sm border border-gold/25 px-3 py-1.5 font-sans text-[10px] tracking-[0.2em] uppercase text-gold-pale">
                  {c.nights} Nights / {c.days} Days
                </span>
                {c.comingSoon && (
                  <span class="bg-void/70 backdrop-blur-sm border border-white/20 px-3 py-1.5 font-sans text-[10px] tracking-[0.2em] uppercase text-white/80">Coming Soon</span>
                )}
              </div>
              <div class="absolute bottom-4 left-5 right-5">
                <p class="font-sans text-[10px] tracking-[0.25em] uppercase text-gold-light mb-1.5">{c.expLabel}</p>
                <h2 class="font-serif text-2xl lg:text-[1.7rem] text-white font-light leading-tight" style="text-shadow:0 2px 18px rgba(0,0,0,.5)">{c.label}</h2>
              </div>
            </a>

            <div class="flex flex-col flex-1 p-6">
              <ul class="flex flex-wrap gap-x-2 gap-y-2 mb-6">
                {c.highlights.map((h) => (
                  <li class="font-sans text-[11px] tracking-wide text-earth/70 border border-bone rounded-full px-2.5 py-1">{h}</li>
                ))}
              </ul>
              <div class="mt-auto pt-1">
                <a href={c.href} class="group/btn inline-flex items-center gap-3 font-sans text-[12px] tracking-[0.22em] uppercase text-earth hover:text-gold transition-colors">
                  View Itinerary
                  <span class="group-hover/btn:translate-x-1 transition-transform duration-300">→</span>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Empty state -->
      <div id="cards-empty" class="hidden text-center py-24">
        <p class="font-serif text-2xl md:text-3xl text-ink-mid italic mb-5">No itineraries match those filters.</p>
        <button type="button" id="filter-clear-empty" class="font-sans text-xs tracking-ultra uppercase text-gold hover:text-gold-light transition-colors">
          Clear filters →
        </button>
      </div>
    </div>
  </section>

  <!-- ── CTA ──────────────────────────────────────── -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/more_than_plan.jpg" alt="Nile at sunset" class="w-full h-full object-cover" loading="lazy" />
      <div class="absolute inset-0 bg-gradient-to-b from-void/60 via-forest/85 to-void/95"></div>
    </div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 lg:px-12 py-28 lg:py-40 text-center">
      <p class="font-sans text-[14px] tracking-[0.3em] uppercase text-gold-light mb-6 reveal">Tailored to You</p>
      <h2 class="font-serif text-4xl md:text-6xl text-white font-light tracking-tight leading-[1.05] mb-6 reveal reveal-delay-1"
        style="text-shadow: 0 2px 40px rgba(0,0,0,0.4);">
        Can't find the<br />perfect voyage?
      </h2>
      <p class="font-sans text-base text-ivory/60 max-w-md mx-auto leading-relaxed mb-12 reveal reveal-delay-2">
        Every VEDA journey is private and flexible. Tell us your dates and intentions, and we'll craft an itinerary around you.
      </p>
      <a href="/reserve" class="group inline-flex items-center justify-center gap-3 bg-gold hover:bg-gold-light text-white font-sans text-xs tracking-ultra uppercase px-8 py-4 rounded-full transition-all duration-300 reveal reveal-delay-3">
        Request a Custom Itinerary
        <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
      </a>
    </div>
  </section>

</MainLayout>

<style>
  .filter-card.is-hidden { display: none; }

  /* Filter panel: inline bar on desktop, bottom-sheet drawer on mobile */
  .filter-panel { flex: 1; }
  @media (max-width: 767px) {
    .filter-panel {
      position: fixed;
      left: 0; right: 0; bottom: 0;
      z-index: 50;
      background: var(--linen);
      border-top: 1px solid var(--bone);
      border-radius: 20px 20px 0 0;
      padding: 1.75rem 1.5rem 2rem;
      max-height: 85vh;
      overflow-y: auto;
      transform: translateY(110%);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      box-shadow: 0 -20px 50px rgba(0,0,0,0.18);
    }
    .filter-panel.is-open { transform: translateY(0); }
  }
</style>

<script>
  type FKey = 'duration' | 'route' | 'experience' | 'vessel';
  const PARAM: Record<FKey, string> = { duration: 'duration', route: 'route', experience: 'experience', vessel: 'vessel' };

  const selects = Array.from(document.querySelectorAll<HTMLSelectElement>('.vfilter'));
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.filter-card'));
  const countEl = document.getElementById('result-count');
  const emptyEl = document.getElementById('cards-empty');
  const gridEl = document.getElementById('cards-grid');
  const clearBtns = ['filter-clear', 'filter-clear-m', 'filter-clear-empty'].map((id) => document.getElementById(id));
  const badge = document.getElementById('filter-count-badge');

  function state(): Record<FKey, string> {
    const s = {} as Record<FKey, string>;
    selects.forEach((sel) => (s[sel.dataset.filter as FKey] = sel.value));
    return s;
  }

  function matches(card: HTMLElement, s: Record<FKey, string>): boolean {
    if (s.duration !== 'any' && card.dataset.duration !== s.duration) return false;
    if (s.route !== 'any' && !(card.dataset.routes ?? '').split('|').includes(s.route)) return false;
    if (s.experience !== 'any' && card.dataset.experience !== s.experience) return false;
    if (s.vessel !== 'any' && !(card.dataset.vessels ?? '').split('|').includes(s.vessel)) return false;
    return true;
  }

  function syncUrl(s: Record<FKey, string>) {
    const p = new URLSearchParams();
    (Object.keys(s) as FKey[]).forEach((k) => { if (s[k] !== 'any') p.set(PARAM[k], s[k]); });
    const qs = p.toString();
    history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
  }

  function apply(updateUrl = true) {
    const s = state();
    let visible = 0;
    cards.forEach((c) => {
      const show = matches(c, s);
      c.classList.toggle('is-hidden', !show);
      if (show) visible++;
    });
    const active = (Object.values(s) as string[]).filter((v) => v !== 'any').length;
    if (countEl) countEl.textContent = active
      ? `${visible} ${visible === 1 ? 'itinerary' : 'itineraries'} found`
      : `${cards.length} itineraries available`;
    emptyEl?.classList.toggle('hidden', visible !== 0);
    gridEl?.classList.toggle('hidden', visible === 0);
    if (badge) badge.textContent = active ? `(${active})` : '';
    if (updateUrl) syncUrl(s);
  }

  function clearAll() {
    selects.forEach((sel) => (sel.value = 'any'));
    apply();
  }

  // Restore from URL
  const params = new URLSearchParams(location.search);
  selects.forEach((sel) => {
    const v = params.get(PARAM[sel.dataset.filter as FKey]);
    if (v && Array.from(sel.options).some((o) => o.value === v)) sel.value = v;
  });

  selects.forEach((sel) => sel.addEventListener('change', () => apply()));
  clearBtns.forEach((b) => b?.addEventListener('click', clearAll));

  // Mobile drawer
  const panel = document.getElementById('filter-panel');
  const backdrop = document.getElementById('filter-backdrop');
  function openDrawer() {
    panel?.classList.add('is-open');
    backdrop?.classList.remove('opacity-0', 'pointer-events-none');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    panel?.classList.remove('is-open');
    backdrop?.classList.add('opacity-0', 'pointer-events-none');
    document.body.style.overflow = '';
  }
  document.getElementById('filter-open')?.addEventListener('click', openDrawer);
  document.getElementById('filter-done')?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);

  apply(false);
</script>
