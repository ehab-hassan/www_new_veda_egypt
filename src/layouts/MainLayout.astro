---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'VEDA Egypt — Sail the Nile. Experience Something Real.',
  description = 'Private, authentic, and conscious journeys along the Nile. Luxury dahbiyas, wellness retreats, and sacred Egypt.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/brand_assets/veda-logo.png" type="image/png" />
    <title>{title}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@200;300;400;500&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      :root {
        --gold: #a07c3a;
        --gold-light: #c9a85c;
        --gold-pale: #dfc99a;
        --ivory: #f0ebe0;
        --void: #070b07;
        --forest: #0e1a0e;
        --forest-mid: #162416;
        --warm-beige: #f5f3ee;
        --soft-green: #e8efe6;
        --ink: #1c2118;
        --ink-mid: #3a4035;
        --ink-light: #6b7264;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        background-color: var(--warm-beige);
        color: var(--ink);
      }

      ::selection {
        background: var(--gold);
        color: #fff;
      }

      /* Scroll reveal animations */
      .reveal {
        opacity: 0;
        transform: translateY(32px);
        transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1),
          transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }

      .reveal-left {
        opacity: 0;
        transform: translateX(-40px);
        transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1),
          transform 1s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .reveal-left.visible {
        opacity: 1;
        transform: translateX(0);
      }

      .reveal-right {
        opacity: 0;
        transform: translateX(40px);
        transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1),
          transform 1s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .reveal-right.visible {
        opacity: 1;
        transform: translateX(0);
      }

      .reveal-delay-1 { transition-delay: 0.1s; }
      .reveal-delay-2 { transition-delay: 0.22s; }
      .reveal-delay-3 { transition-delay: 0.34s; }
      .reveal-delay-4 { transition-delay: 0.46s; }

      /* Gold divider */
      .gold-line {
        display: block;
        width: 48px;
        height: 1px;
        background: var(--gold);
      }

      /* Custom scrollbar */
      ::-webkit-scrollbar { width: 4px; }
      ::-webkit-scrollbar-track { background: var(--warm-beige); }
      ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 2px; }
    </style>
  </head>

  <body class="bg-warm-beige font-sans antialiased">
    <!-- Navigation -->
    <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 flex items-center justify-between h-20">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 group">
          <img
            src="/brand_assets/veda-logo.png"
            alt="VEDA"
            class="h-10 w-10 object-contain opacity-90 group-hover:opacity-100 transition-opacity"
          />
          <span class="font-serif text-xl tracking-ultra text-ivory/90 group-hover:text-ivory transition-colors">
            VEDA
          </span>
        </a>

        <!-- Desktop Nav -->
        <ul class="hidden md:flex items-center gap-8">
          {[
            { label: 'Dahabiyas', href: '/dahabiyas' },
            { label: 'Plan Your Visit', href: '/plan-your-visit' },
            { label: 'Gallery', href: '/gallery' },
            { label: 'Our Team', href: '/our-team' },
            { label: 'Contact', href: '#contact' },
          ].map((item) => (
            <li>
              <a
                href={item.href}
                class="font-sans text-xs tracking-ultra uppercase text-ivory hover:text-gold transition-colors duration-300"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- CTA -->
        <a
          href="#contact"
          class="hidden md:inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-white text-xs tracking-ultra uppercase px-5 py-2.5 transition-all duration-300"
        >
          Plan Your Journey
        </a>

        <!-- Mobile Hamburger -->
        <button
          id="menu-toggle"
          class="md:hidden flex flex-col gap-1.5 p-2 group"
          aria-label="Menu"
        >
          <span class="block w-6 h-px bg-ivory/70 group-hover:bg-gold transition-colors duration-300"></span>
          <span class="block w-4 h-px bg-ivory/70 group-hover:bg-gold transition-colors duration-300 ml-auto"></span>
          <span class="block w-6 h-px bg-ivory/70 group-hover:bg-gold transition-colors duration-300"></span>
        </button>
      </div>

      <!-- Mobile Menu -->
      <div
        id="mobile-menu"
        class="hidden md:hidden bg-forest/95 backdrop-blur-sm border-t border-gold/10 px-6 pb-6"
      >
        <ul class="flex flex-col gap-5 pt-6">
          {[
            { label: 'Dahabiyas', href: '/dahabiyas' },
            { label: 'Plan Your Visit', href: '/plan-your-visit' },
            { label: 'Gallery', href: '/gallery' },
            { label: 'Our Team', href: '/our-team' },
            { label: 'Contact', href: '#contact' },
          ].map((item) => (
            <li>
              <a
                href={item.href}
                class="font-sans text-xs tracking-ultra uppercase text-ivory/70 hover:text-gold transition-colors duration-300"
              >
                {item.label}
              </a>
            </li>
          ))}
          <li>
            <a
              href="#contact"
              class="inline-flex border border-gold/40 text-gold text-xs tracking-ultra uppercase px-5 py-2.5"
            >
              Plan Your Journey
            </a>
          </li>
        </ul>
      </div>
    </nav>

    <!-- Main content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-void border-t border-gold/10 pt-20 pb-10">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
          <!-- Brand -->
          <div>
            <div class="flex items-center gap-3 mb-5">
              <img src="/brand_assets/veda-logo.png" alt="VEDA" class="h-10 w-10 object-contain opacity-80" />
              <span class="font-serif text-xl tracking-ultra text-ivory/80">VEDA</span>
            </div>
            <p class="font-sans text-sm text-warm-gray leading-relaxed">
              Private, authentic, conscious journeys on the Nile.
            </p>
          </div>

          <!-- Contact -->
          <div>
            <p class="font-sans text-xs tracking-ultra uppercase text-gold mb-5">Contact</p>
            <div class="space-y-2">
              <a href="mailto:info@veda-egypt.com" class="block font-sans text-sm text-warm-gray hover:text-ivory transition-colors">
                info@veda-egypt.com
              </a>
              <a href="mailto:reservation@veda-egypt.com" class="block font-sans text-sm text-warm-gray hover:text-ivory transition-colors">
                reservation@veda-egypt.com
              </a>
            </div>
          </div>

          <!-- Links -->
          <div>
            <p class="font-sans text-xs tracking-ultra uppercase text-gold mb-5">Explore</p>
            <ul class="space-y-2">
              {['Dahabiyas', 'Plan Your Visit', 'Gallery', 'Our Team', 'VEDA Kids'].map((item) => (
                <li>
                  <a
                    href="#"
                    class="font-sans text-sm text-warm-gray hover:text-ivory transition-colors"
                  >
                    {item}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Newsletter -->
          <div>
            <p class="font-sans text-xs tracking-ultra uppercase text-gold mb-5">Stay Connected</p>
            <p class="font-sans text-sm text-warm-gray mb-4 leading-relaxed">
              Receive rare updates. No noise.
            </p>
            <form class="flex gap-2">
              <input
                type="email"
                placeholder="Your email"
                class="flex-1 bg-void/60 border border-gold/20 text-ivory text-sm px-4 py-2.5 placeholder:text-warm-gray/50 focus:outline-none focus:border-gold/50 transition-colors"
              />
              <button
                type="submit"
                class="bg-gold/10 border border-gold/40 hover:bg-gold/20 text-gold text-xs tracking-ultra uppercase px-4 py-2.5 transition-all duration-300"
              >
                →
              </button>
            </form>

            <!-- Social -->
            <div class="flex gap-3 mt-6">
              <a href="http://www.instagram.com/veda_retreats" target="_blank" rel="noopener" aria-label="Instagram"
                class="w-8 h-8 flex items-center justify-center border border-gold/20 hover:border-gold/50 text-warm-gray/60 hover:text-gold transition-all duration-300 hover:bg-gold/5">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <circle cx="12" cy="12" r="4"/>
                  <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
                </svg>
              </a>
              <a href="https://www.facebook.com/vedaretreats" target="_blank" rel="noopener" aria-label="Facebook"
                class="w-8 h-8 flex items-center justify-center border border-gold/20 hover:border-gold/50 text-warm-gray/60 hover:text-gold transition-all duration-300 hover:bg-gold/5">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                </svg>
              </a>
              <a href="https://x.com" target="_blank" rel="noopener" aria-label="X (Twitter)"
                class="w-8 h-8 flex items-center justify-center border border-gold/20 hover:border-gold/50 text-warm-gray/60 hover:text-gold transition-all duration-300 hover:bg-gold/5">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Bottom bar -->
        <div class="border-t border-gold/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
          <p class="font-sans text-xs text-warm-gray/50">
            © {new Date().getFullYear()} VEDA Egypt. All rights reserved.
          </p>
          <div class="flex gap-5">
            {['Impressum', 'Privacy Policy', 'Terms & Conditions'].map((item) => (
              <a href="#" class="font-sans text-xs text-warm-gray/50 hover:text-warm-gray transition-colors">
                {item}
              </a>
            ))}
          </div>
        </div>
      </div>
    </footer>

    <script>
      // Navbar scroll effect
      const navbar = document.getElementById('navbar');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 60) {
          navbar?.classList.add('bg-void/95', 'backdrop-blur-md', 'border-b', 'border-gold/10', 'shadow-xl');
        } else {
          navbar?.classList.remove('bg-void/95', 'backdrop-blur-md', 'border-b', 'border-gold/10', 'shadow-xl');
        }
      });

      // Mobile menu
      const menuToggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      menuToggle?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });

      // Scroll reveal
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>
