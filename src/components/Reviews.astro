---
// Reviews — third-party trust strip.
//
// Each platform shows verified rating data when present; otherwise falls back
// to a plain "Read reviews on X →" outbound link. To enable a rating, set
// `rating` and `count` to the actual numbers from that platform's dashboard.

interface Platform {
  name: string;
  url: string;
  rating: number | null;   // e.g. 4.9 — leave null until verified
  count: number | null;    // total review count — leave null until verified
}

const platforms: Platform[] = [
  { name: 'TripAdvisor', url: 'https://www.tripadvisor.com',          rating: null, count: null },
  { name: 'Google',      url: 'https://www.google.com/maps',          rating: null, count: null },
  { name: 'Facebook',    url: 'https://www.facebook.com/vedaretreats', rating: null, count: null },
];

function formatRating(r: number) {
  return r.toFixed(1);
}
---

<section id="reviews" class="bg-warm-beige border-t border-b border-gold/10 py-14">
  <div class="max-w-6xl mx-auto px-6 lg:px-12">

    <!-- Header line -->
    <div class="flex items-center justify-center gap-4 mb-10 reveal">
      <span class="h-px w-10 bg-gold/40"></span>
      <p class="font-sans text-[12px] tracking-ultra uppercase text-gold">Trusted by Travellers</p>
      <span class="h-px w-10 bg-gold/40"></span>
    </div>

    <!-- Platform strip -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-3xl mx-auto">
      {platforms.map((p) => {
        const hasRating = p.rating !== null && p.count !== null;
        return (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col items-center text-center px-6 py-5 border border-gold/15 bg-white/40 hover:border-gold/40 hover:bg-white/70 transition-colors"
          >
            <p class="font-serif text-lg text-ink font-light leading-none mb-3">{p.name}</p>

            {hasRating ? (
              <>
                <div class="flex items-center gap-1.5 mb-2">
                  <span class="font-serif text-3xl text-gold leading-none">{formatRating(p.rating!)}</span>
                  <span class="font-sans text-xs text-ink-light">/ 5</span>
                </div>
                <p class="font-sans text-[11px] text-ink-light">{p.count}+ reviews</p>
              </>
            ) : (
              <p class="font-sans text-[12px] tracking-wider text-ink-light group-hover:text-gold transition-colors">
                Read reviews →
              </p>
            )}
          </a>
        );
      })}
    </div>

    <!-- Operator credentials line -->
    <p class="text-center font-sans text-[11px] tracking-ultra uppercase text-ink-light/70 mt-10">
      Sailing the Nile since 2012 · Featured by CNN · Boutique fleet of four dahabiyas
    </p>
  </div>
</section>
