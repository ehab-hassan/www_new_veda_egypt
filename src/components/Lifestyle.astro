---
// Lifestyle / Wellness — DARK section (forest bg), editorial magazine layout
---

<section id="lifestyle" class="bg-forest py-28 lg:py-44 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <!-- Section header -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-20">
      <div class="reveal">
        <div class="flex items-center gap-4 mb-6">
          <span class="gold-line"></span>
          <p class="font-sans text-sm tracking-ultra uppercase text-gold-light">Healthy Experience</p>
        </div>
        <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl text-ivory font-light tracking-tight leading-[1.1]">
          Mind.<br />Body.<br />
          <em class="italic text-gold-pale">Soul.</em>
        </h2>
      </div>
      <div class="flex flex-col justify-end reveal reveal-delay-2">
        <p class="font-sans text-base text-warm-gray leading-relaxed mb-8">
          Our mission is a healthy experience. Each journey on the Nile
          becomes an invitation to slow down, reconnect, and feel something
          deeper than the ordinary.
        </p>
        <a
          href="/plan-your-visit"
          class="group self-start inline-flex items-center gap-3 font-sans text-xs tracking-ultra uppercase text-gold border-b border-gold/30 hover:border-gold pb-1 transition-colors duration-300"
        >
          Complete Your Trip with Treatments
          <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
        </a>
      </div>
    </div>

    <!-- Editorial grid: 1 large hero image + 4 smaller -->
    <div class="grid grid-cols-2 lg:grid-cols-3 gap-3">

      <!-- MAIN large image — spans 2 rows on desktop -->
      <article class="group relative overflow-hidden col-span-2 lg:col-span-1 lg:row-span-2 reveal reveal-delay-1">
        <div class="relative h-64 lg:h-full min-h-[400px] overflow-hidden">
          <img
            src="/images/photo-2019-04-03-08-27-20-436x291.jpg"
            alt="Meditation on the Nile"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-forest via-forest/55 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-6">
            <p class="font-sans text-xs tracking-ultra uppercase text-gold mb-2">Meditation</p>
            <p class="font-serif text-xl text-ivory font-light leading-snug">Open your mind.<br /><em class="italic text-ivory/60">Enter awareness.</em></p>
          </div>
        </div>
      </article>

      <!-- Yoga -->
      <article class="group relative overflow-hidden reveal reveal-delay-2">
        <div class="relative aspect-[4/3] overflow-hidden">
          <img src="/images/photo-2019-04-03-08-27-18-4-436x291.jpg" alt="Yoga"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-forest via-forest/50 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-5">
            <p class="font-sans text-lg tracking-ultra uppercase text-gold mb-1">Yoga</p>
            <p class="font-sans text-md text-ivory/60">Step fully into your body.</p>
          </div>
        </div>
      </article>

      <!-- Organic food -->
      <article class="group relative overflow-hidden reveal reveal-delay-3">
        <div class="relative aspect-[4/3] overflow-hidden">
          <img src="/images/30-464x309.jpg" alt="Organic food"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-forest via-forest/50 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-5">
            <p class="font-sans text-lg tracking-ultra uppercase text-gold mb-1">Organic Food</p>
            <p class="font-sans text-md text-ivory/60">Nourished, inside and out.</p>
          </div>
        </div>
      </article>

      <!-- Massage -->
      <article class="group relative overflow-hidden reveal reveal-delay-2">
        <div class="relative aspect-[4/3] overflow-hidden">
          <img src="/images/mbr-4-436x291.jpg" alt="Massage"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-forest via-forest/50 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-5">
            <p class="font-sans text-lg tracking-ultra uppercase text-gold mb-1">Massage</p>
            <p class="font-sans text-md text-ivory/60">Integrate the energy of Egypt.</p>
          </div>
        </div>
      </article>

      <!-- Wellness -->
      <article class="group relative overflow-hidden reveal reveal-delay-3">
        <div class="relative aspect-[4/3] overflow-hidden">
          <img src="/images/photo-2019-04-03-12-14-27-436x291.jpg" alt="Wellness"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-forest via-forest/50 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-5">
            <p class="font-sans text-lg tracking-ultra uppercase text-gold mb-1">Wellness</p>
            <p class="font-sans text-md text-ivory/60">Sunrise walks. Healing sessions.</p>
          </div>
        </div>
      </article>
    </div>

    <!-- Sacred river callout — light card floated below -->
    <div class="mt-20 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div class="reveal">
        <span class="gold-line mb-6 block"></span>
        <h3 class="font-serif text-4xl md:text-5xl lg:text-6xl text-ivory font-light mb-5 leading-snug">
          A river full of<br /><em class="italic text-gold-pale">sacred places</em>
        </h3>
        <p class="font-sans text-sm text-warm-gray leading-relaxed mb-8">
          By following the natural flow of the Nile, you will discover
          some of the most sacred places in the world. Every itinerary is
          tailored to your energy — leading you to the temples and moments
          that are meant for you.
        </p>
        <a
          href="/plan-your-visit"
          class="group inline-flex items-center gap-3 border border-gold/30 hover:border-gold text-gold/80 hover:text-gold font-sans text-xs tracking-ultra uppercase px-6 py-3.5 transition-all duration-300 hover:bg-gold/5"
        >
          Ready to be Inspired?
          <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
        </a>
      </div>
      <!-- Cinematic Nile Route Map -->
      <div class="relative reveal-right mx-auto w-full" id="nile-map-outer">
        <!-- Atmosphere: fog layers -->
        <div class="absolute top-0 left-0 right-0 h-16 from-forest to-transparent z-10 pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 right-0 h-20 from-forest to-transparent z-10 pointer-events-none"></div>

        <!-- 3D perspective wrap -->
        <div class="nile-3d-wrap">
          <svg
            id="nile-svg"
            viewBox="0 0 630 680"
            xmlns="http://www.w3.org/2000/svg"
            class="w-full block"
            aria-label="Nile journey route from Luxor to Aswan"
          >
            <defs>
              <!-- Path glow filter -->
              <filter id="path-glow" x="-40%" y="-40%" width="180%" height="180%">
                <feGaussianBlur in="SourceGraphic" stdDeviation="5" result="blur1"/>
                <feGaussianBlur in="SourceGraphic" stdDeviation="10" result="blur2"/>
                <feMerge>
                  <feMergeNode in="blur2"/>
                  <feMergeNode in="blur1"/>
                  <feMergeNode in="SourceGraphic"/>
                </feMerge>
              </filter>
              <!-- Node glow -->
              <filter id="node-glow" x="-100%" y="-100%" width="300%" height="300%">
                <feGaussianBlur in="SourceGraphic" stdDeviation="4" result="blur"/>
                <feMerge>
                  <feMergeNode in="blur"/>
                  <feMergeNode in="SourceGraphic"/>
                </feMerge>
              </filter>
              <!-- Gradient along path top → bottom -->
              <linearGradient id="nile-grad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%"   stop-color="#a07c3a"/>
                <stop offset="55%"  stop-color="#c9a85c"/>
                <stop offset="100%" stop-color="#a07c3a"/>
              </linearGradient>
              <!-- Dark background gradient -->
              <radialGradient id="bg-grad" cx="50%" cy="50%" r="60%">
                <stop offset="0%"   stop-color="#162416"/>
                <stop offset="100%" stop-color="#070b07"/>
              </radialGradient>
              <!-- Boat marker -->
              <g id="boat">
                <polygon points="0,-10 -5,3 5,3" fill="white" opacity="0.92"/>
                <path d="M-6,4 Q0,8 6,4" stroke="rgba(255,255,255,0.8)" stroke-width="1.5" fill="none"/>
                <line x1="0" y1="-10" x2="0" y2="4" stroke="rgba(255,255,255,0.5)" stroke-width="0.8"/>
              </g>
            </defs>

            <!-- Background -->
            <rect width="630" height="680" fill="url(#bg-grad)" rx="12"/>
            <!-- Subtle noise texture via feTurbulence -->
            <rect width="630" height="680" fill="rgba(160,124,58,0.012)" rx="12"/>

            <!-- Scatter dots (star-like atmosphere) -->
            {[
              [50,90],[560,130],[80,210],[580,260],[30,340],[590,400],
              [60,470],[570,520],[90,590],[540,610],[100,100],[520,580],
              [150,430],[480,310],[200,555],[430,170]
            ].map(([x,y]) => (
              <circle cx={x} cy={y} r="1" fill="rgba(255,255,255,0.18)" class="atm-dot"/>
            ))}

            <!-- ─── THE NILE ─── organic S-curve -->
            <!-- Path definition (shared by both strokes + animateMotion) -->

            <!-- Wide glow halo -->
            <path
              d="M 340,88 C 390,123 240,151 265,193 C 290,235 380,261 340,303 C 300,345 240,363 268,407 C 296,451 390,471 352,513 C 314,555 305,581 322,613"
              fill="none"
              stroke="rgba(160,124,58,0.10)"
              stroke-width="18"
              stroke-linecap="round"
              filter="url(#path-glow)"
            />

            <!-- Mid glow -->
            <path
              d="M 340,88 C 390,123 240,151 265,193 C 290,235 380,261 340,303 C 300,345 240,363 268,407 C 296,451 390,471 352,513 C 314,555 305,581 322,613"
              fill="none"
              stroke="rgba(201,168,92,0.18)"
              stroke-width="8"
              stroke-linecap="round"
            />

            <!-- Main glowing line (animated draw-on) -->
            <path
              id="nile-path"
              d="M 340,88 C 390,123 240,151 265,193 C 290,235 380,261 340,303 C 300,345 240,363 268,407 C 296,451 390,471 352,513 C 314,555 305,581 322,613"
              fill="none"
              stroke="url(#nile-grad)"
              stroke-width="2.5"
              stroke-linecap="round"
              filter="url(#path-glow)"
              class="nile-draw"
            />

            <!-- ─── NODES ─── -->
            <!-- Luxor (340,88) — label RIGHT -->
            <g class="nile-node">
              <circle cx="340" cy="88" r="10" fill="none" stroke="rgba(160,124,58,0.25)" stroke-width="1" class="pulse-ring pr1"/>
              <circle cx="340" cy="88" r="18" fill="none" stroke="rgba(160,124,58,0.10)" stroke-width="1" class="pulse-ring pr2"/>
              <circle cx="340" cy="88" r="5"  fill="#a07c3a" opacity="0.95" filter="url(#node-glow)"/>
              <circle cx="340" cy="88" r="2.5" fill="white" opacity="0.95"/>
              <line x1="346" y1="88" x2="374" y2="88" stroke="rgba(160,124,58,0.35)" stroke-width="0.8"/>
              <text x="378" y="81" class="label-day">DAY 1</text>
              <text x="378" y="97" class="label-city">Luxor</text>
              <text x="378" y="111" class="label-desc">Begin where pharaohs ruled.</text>
            </g>

            <!-- Esna (265,193) — label LEFT -->
            <g class="nile-node">
              <circle cx="265" cy="193" r="10" fill="none" stroke="rgba(160,124,58,0.25)" stroke-width="1" class="pulse-ring pr1" style="animation-delay:0.6s"/>
              <circle cx="265" cy="193" r="18" fill="none" stroke="rgba(160,124,58,0.10)" stroke-width="1" class="pulse-ring pr2" style="animation-delay:1.4s"/>
              <circle cx="265" cy="193" r="5"  fill="#a07c3a" opacity="0.95" filter="url(#node-glow)"/>
              <circle cx="265" cy="193" r="2.5" fill="white" opacity="0.95"/>
              <line x1="259" y1="193" x2="231" y2="193" stroke="rgba(160,124,58,0.35)" stroke-width="0.8"/>
              <text x="227" y="186" class="label-day" text-anchor="end">DAY 2</text>
              <text x="227" y="202" class="label-city" text-anchor="end">Esna</text>
              <text x="227" y="216" class="label-desc" text-anchor="end">Sail through the ancient lock.</text>
            </g>

            <!-- Crossing the Lock (330,248) — label LEFT -->
            <g class="nile-node">
              <circle cx="330" cy="248" r="10" fill="none" stroke="rgba(160,124,58,0.25)" stroke-width="1" class="pulse-ring pr1" style="animation-delay:0.9s"/>
              <circle cx="330" cy="248" r="18" fill="none" stroke="rgba(160,124,58,0.10)" stroke-width="1" class="pulse-ring pr2" style="animation-delay:1.7s"/>
              <circle cx="330" cy="248" r="5"  fill="#a07c3a" opacity="0.95" filter="url(#node-glow)"/>
              <circle cx="330" cy="248" r="2.5" fill="white" opacity="0.95"/>
              <line x1="324" y1="248" x2="296" y2="248" stroke="rgba(160,124,58,0.35)" stroke-width="0.8"/>
              <text x="292" y="241" class="label-day" text-anchor="end">DAY 3</text>
              <text x="292" y="257" class="label-city" text-anchor="end">The Lock</text>
              <text x="292" y="271" class="label-desc" text-anchor="end">Crossing the Esna lock.</text>
            </g>

            <!-- Edfu (340,303) — label RIGHT -->
            <g class="nile-node">
              <circle cx="340" cy="303" r="10" fill="none" stroke="rgba(160,124,58,0.25)" stroke-width="1" class="pulse-ring pr1" style="animation-delay:1.1s"/>
              <circle cx="340" cy="303" r="18" fill="none" stroke="rgba(160,124,58,0.10)" stroke-width="1" class="pulse-ring pr2" style="animation-delay:1.9s"/>
              <circle cx="340" cy="303" r="5"  fill="#a07c3a" opacity="0.95" filter="url(#node-glow)"/>
              <circle cx="340" cy="303" r="2.5" fill="white" opacity="0.95"/>
              <line x1="346" y1="303" x2="374" y2="303" stroke="rgba(160,124,58,0.35)" stroke-width="0.8"/>
              <text x="378" y="296" class="label-day">DAY 4</text>
              <text x="378" y="312" class="label-city">Edfu</text>
              <text x="378" y="326" class="label-desc">Egypt's most complete temple.</text>
            </g>

            <!-- Silsila (268,407) — label LEFT -->
            <g class="nile-node">
              <circle cx="268" cy="407" r="10" fill="none" stroke="rgba(160,124,58,0.25)" stroke-width="1" class="pulse-ring pr1" style="animation-delay:0.3s"/>
              <circle cx="268" cy="407" r="18" fill="none" stroke="rgba(160,124,58,0.10)" stroke-width="1" class="pulse-ring pr2" style="animation-delay:1.1s"/>
              <circle cx="268" cy="407" r="5"  fill="#a07c3a" opacity="0.95" filter="url(#node-glow)"/>
              <circle cx="268" cy="407" r="2.5" fill="white" opacity="0.95"/>
              <line x1="262" y1="407" x2="234" y2="407" stroke="rgba(160,124,58,0.35)" stroke-width="0.8"/>
              <text x="230" y="400" class="label-day" text-anchor="end">DAY 5</text>
              <text x="230" y="416" class="label-city" text-anchor="end">Silsila</text>
              <text x="230" y="430" class="label-desc" text-anchor="end">Ancient quarries &amp; rock shrines.</text>
            </g>

            <!-- Kom Ombo (352,513) — label RIGHT -->
            <g class="nile-node">
              <circle cx="352" cy="513" r="10" fill="none" stroke="rgba(201,168,92,0.25)" stroke-width="1" class="pulse-ring pr1" style="animation-delay:0.8s"/>
              <circle cx="352" cy="513" r="18" fill="none" stroke="rgba(201,168,92,0.10)" stroke-width="1" class="pulse-ring pr2" style="animation-delay:1.6s"/>
              <circle cx="352" cy="513" r="5"  fill="#c9a85c" opacity="0.95" filter="url(#node-glow)"/>
              <circle cx="352" cy="513" r="2.5" fill="white" opacity="0.95"/>
              <line x1="358" y1="513" x2="386" y2="513" stroke="rgba(201,168,92,0.35)" stroke-width="0.8"/>
              <text x="390" y="506" class="label-day" style="fill:rgba(201,168,92,0.8)">DAY 6</text>
              <text x="390" y="522" class="label-city">Kom Ombo</text>
              <text x="390" y="536" class="label-desc">Double temple of Sobek.</text>
            </g>

            <!-- Aswan (322,613) — label LEFT -->
            <g class="nile-node">
              <circle cx="322" cy="613" r="12" fill="none" stroke="rgba(201,168,92,0.35)" stroke-width="1.5" class="pulse-ring pr1" style="animation-delay:0.4s"/>
              <circle cx="322" cy="613" r="22" fill="none" stroke="rgba(201,168,92,0.12)" stroke-width="1" class="pulse-ring pr2" style="animation-delay:1.2s"/>
              <circle cx="322" cy="613" r="6"  fill="#c9a85c" opacity="0.95" filter="url(#node-glow)"/>
              <circle cx="322" cy="613" r="3"  fill="white" opacity="0.95"/>
              <line x1="316" y1="613" x2="288" y2="613" stroke="rgba(201,168,92,0.45)" stroke-width="0.8"/>
              <text x="284" y="606" class="label-day" text-anchor="end" style="fill:rgba(201,168,92,0.9)">DAY 7</text>
              <text x="284" y="622" class="label-city label-aswan" text-anchor="end">Aswan</text>
              <text x="284" y="637" class="label-desc" text-anchor="end">Where the Nile meets Nubia.</text>
            </g>

            <!-- Top title -->
            <text x="315" y="38" class="title-main" text-anchor="middle">LUXOR / ASWAN</text>
            <text x="315" y="54" class="title-sub" text-anchor="middle">7 DAYS · 6 NIGHTS</text>
            <!-- Divider line below title -->
            <line x1="215" y1="64" x2="415" y2="64" stroke="rgba(160,124,58,0.2)" stroke-width="0.8"/>

            <!-- Boat moving along path -->
            <g id="nile-boat" opacity="0.9">
              <use href="#boat"/>
              <animateMotion
                dur="20s"
                repeatCount="indefinite"
                rotate="auto"
                calcMode="spline"
                keyTimes="0;1"
                keySplines="0.4 0 0.6 1"
              >
                <mpath href="#nile-path"/>
              </animateMotion>
            </g>

          </svg>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  /* ── Flat map wrap ── */
  .nile-3d-wrap {
    border-radius: 12px;
    overflow: hidden;
    box-shadow:
      0 12px 40px rgba(0,0,0,0.4),
      0 0 0 1px rgba(160,124,58,0.08);
  }

  /* ── Path draw-on ── */
  .nile-draw {
    stroke-dasharray: 2000;
    stroke-dashoffset: 2000;
    transition: stroke-dashoffset 3.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .nile-draw.drawn {
    stroke-dashoffset: 0;
  }

  /* ── Node pulse rings ── */
  @keyframes pulseRing {
    0%   { transform: scale(0.8); opacity: 0.6; }
    60%  { transform: scale(1.5); opacity: 0; }
    100% { transform: scale(1.5); opacity: 0; }
  }
  .pulse-ring {
    animation: pulseRing 2.8s ease-out infinite;
    transform-origin: center;
    transform-box: fill-box;
  }
  .pr2 { animation-duration: 2.8s; animation-delay: 0.9s; }

  /* ── Atmosphere dots twinkle ── */
  @keyframes twinkle {
    0%, 100% { opacity: 0.15; }
    50% { opacity: 0.4; }
  }
  .atm-dot {
    animation: twinkle 3s ease-in-out infinite;
  }
  .atm-dot:nth-child(odd)  { animation-duration: 4.2s; animation-delay: 0.8s; }
  .atm-dot:nth-child(3n)   { animation-duration: 5.5s; animation-delay: 1.5s; }

  /* ── SVG Text styles ── */
  .label-day {
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    letter-spacing: 0.16em;
    fill: rgba(160,124,58,0.92);
    text-transform: uppercase;
  }
  .label-city {
    text-transform: uppercase;
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    fill: rgba(240,235,224,0.97);
    letter-spacing: 0.05em;
  }
  .label-aswan {
    font-size: 20px;
    fill: rgba(240,235,224,1);
    font-weight: 500;
  }
  .title-main {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    fill: rgba(240,235,224,0.92);
    letter-spacing: 0.2em;
    font-weight: 300;
  }
  .title-sub {
    font-family: 'Jost', sans-serif;
    font-size: 14px;
    fill: rgba(223, 189, 126, 0.8);
    letter-spacing: 0.26em;
  }
  .label-desc {
    font-family: 'Jost', sans-serif;
    font-size: 14px;
    fill: rgba(138,130,120,0.75);
    letter-spacing: 0.04em;
  }
</style>

<script>
  // ── Path draw-on when section enters viewport ──
  const nilePath = document.getElementById('nile-path') as SVGPathElement | null;
  if (nilePath) {
    const len = nilePath.getTotalLength();
    nilePath.style.strokeDasharray = String(len);
    nilePath.style.strokeDashoffset = String(len);

    const drawObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            setTimeout(() => nilePath.classList.add('drawn'), 200);
            drawObserver.unobserve(e.target);
          }
        });
      },
      { threshold: 0.2 }
    );
    const svg = document.getElementById('nile-svg');
    if (svg) drawObserver.observe(svg);
  }

</script>
