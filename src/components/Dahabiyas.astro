---
// Dahabiyas — homepage "Our Fleet" band.
// Full-bleed background image with centered text + CTA. The detailed
// boat-by-boat content lives on the /dahabiyas page.
import { Image } from 'astro:assets';
import fleetBg from '../images/photo-2019-03-21-12.49.08-1280x854_2.jpg';
---

<section id="dahabiyas" class="relative min-h-[78vh] flex items-center justify-center overflow-hidden">

  <!-- Background image -->
  <Image
    src={fleetBg}
    alt="The VEDA dahabiyas sailing the Nile"
    class="absolute inset-0 w-full h-full object-cover object-center"
    loading="lazy"
    widths={[768, 1280, 1920]}
    sizes="100vw"
  />

  <!-- Warm-earth overlay — image stays clear, text stays legible -->
  <div class="absolute inset-0 bg-gradient-to-b from-earth/55 via-earth/55 to-earth/70 pointer-events-none"></div>

  <!-- Gold hairlines top & bottom -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-2xl mx-auto px-6 text-center py-28">

    <!-- Eyebrow -->
    <div class="flex items-center justify-center gap-4 mb-6 reveal">
      <span class="h-px w-10 bg-white/60"></span>
      <p class="font-sans text-sm tracking-ultra uppercase text-white">Our Fleet</p>
      <span class="h-px w-10 bg-white/60"></span>
    </div>

    <!-- Header -->
    <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl text-white font-light tracking-tight leading-tight mb-7 reveal reveal-delay-1"
      style="text-shadow: 0 2px 28px rgba(0,0,0,0.4);">
      The VEDA <em class="italic text-gold-pale">Dahabiyas</em>
    </h2>

    <!-- Body -->
    <p class="font-sans text-base md:text-xl text-white leading-relaxed mb-10 max-w-xl mx-auto reveal reveal-delay-2">
      Peaceful platforms built for your retreat. Each boat a world unto itself —
      solar-powered, privately chartered, and personally crewed. Choose your scale,
      from an intimate retreat for ten to a grand voyage for twenty-eight.
    </p>

    <!-- CTA -->
    <a
      href="/dahabiyas"
      class="group inline-flex items-center gap-3 bg-gold hover:bg-gold-light text-white font-sans text-xs tracking-ultra uppercase px-8 py-4 rounded-full transition-all duration-300 hover:-translate-y-px hover:shadow-lg hover:shadow-gold/20 reveal reveal-delay-3"
    >
      View All Dahabiyas
      <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
    </a>

  </div>
</section>
