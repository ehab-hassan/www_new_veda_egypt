---
// Hero Section — Fullscreen slider, 3 slides (slide 0 = video), auto-advance + manual controls
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import slide0Img from '../images/hero_1.jpg';
import slide1Img from '../images/hero_2.jpg';
import slide2Img from '../images/green.jpg';

interface Slide {
  type: 'image';
  imageSrc: ImageMetadata;
  eyebrow: string;
  heading: [string, string, string];
  sub: string;
}

const slides: Slide[] = [
  {
    type: 'image',
    imageSrc: slide0Img,
    eyebrow: 'Nile Journeys · Egypt',
    heading: ['Sail the Nile.', 'Experience', 'something real.'],
    sub: 'Private, authentic, and conscious journeys in Egypt.',
  },
  {
    type: 'image',
    imageSrc: slide1Img,
    eyebrow: 'Exclusive Experiences',
    heading: ['Exclusive &', 'authentic', 'experiences.'],
    sub: 'VEDA crew guides you to the most impressive, high-energy places on the Nile.',
  },
  {
    type: 'image',
    imageSrc: slide2Img,
    eyebrow: 'Green & Organic',
    heading: ['Green.', 'Organic.', 'Alive.'],
    sub: 'Solar-powered boats. Local cuisine. The first truly green journey on the Nile.',
  },
];
---

<section id="hero" class="relative w-full h-screen min-h-[640px] overflow-hidden">

  <!-- Slide backgrounds -->
  {slides.map((slide, i) => (
    <div
      class="hero-slide absolute inset-0"
      data-slide={i}
      style={i === 0 ? 'opacity:1;' : 'opacity:0;'}
    >
      <Image
        src={slide.imageSrc}
        alt={slide.eyebrow}
        class="w-full h-full object-cover object-center"
        style="animation: heroScale 22s ease-in-out infinite alternate;"
        loading={i === 0 ? 'eager' : 'lazy'}
        widths={[768, 1280, 1920]}
        sizes="100vw"
        {...(i === 0 ? ({ fetchpriority: 'high' } as any) : {})}
      />
    </div>
  ))}

  <!-- Overall darkening tint so the centered text stays clear -->
  <div class="absolute inset-0 bg-void/35 pointer-events-none"></div>
  <!-- Stronger bottom grounding under the text -->
  <div class="absolute inset-0 bg-gradient-to-t from-void/70 via-void/20 to-transparent pointer-events-none"></div>
  <!-- Subtle top for depth under the navbar -->
  <div class="absolute inset-0 bg-gradient-to-b from-void/30 via-transparent to-transparent pointer-events-none"></div>

  <!-- Slide content -->
  <div class="relative z-10 flex flex-col justify-end h-full max-w-[100rem] mx-auto px-6 lg:px-12 pb-24 lg:pb-32">

    {slides.map((slide, i) => (
      <div
        class="hero-content absolute top-20 bottom-24 lg:bottom-28 left-0 right-0 max-w-[100rem] flex flex-col justify-center items-center text-center overflow-hidden"
        data-content={i}
        style={i === 0 ? 'opacity:1; transform:translateY(0);' : 'opacity:0; transform:translateY(20px); pointer-events:none;'}
      >
        <!-- Gold line -->
        <span class="gold-line mb-8 block mx-auto" style="animation: fadeInUp 1s 0.3s both;"></span>

        <!-- Eyebrow -->
        <p class="font-sans text-sm tracking-mega uppercase text-white mb-6 text-center"
          style="animation: fadeInUp 1s 0.5s both;">
          {slide.eyebrow}
        </p>

        <!-- Heading -->
        <h1 class="font-serif text-5xl md:text-[clamp(2rem,4.8vw,5rem)] md:whitespace-nowrap font-light text-white leading-[1.0] tracking-tight mb-8 text-center"
          style="animation: fadeInUp 1s 0.7s both; text-shadow: 0 2px 28px rgb(0, 0, 0, 0.5);">
          {slide.heading[0]}<br class="md:hidden" /> <em class="italic text-gold-pale">{slide.heading[1]}</em><br class="md:hidden" /> {slide.heading[2]}
        </h1>

        <!-- Subtext -->
        <p class="font-sans text-sm md:text-xl text-white font-light max-w-sm leading-relaxed mb-12 text-center mx-auto"
          style="animation: fadeInUp 1s 0.9s both;">
          {slide.sub}
        </p>

        <!-- CTAs — primary (solid) + secondary (ghost) -->
        <div class="flex flex-wrap gap-4 justify-center" style="animation: fadeInUp 1s 1.1s both;">
          <a href="/plan-your-visit"
            class="group inline-flex items-center gap-3 bg-sage hover:bg-sage-dark text-white font-sans text-xs tracking-ultra uppercase px-7 py-4 rounded-full transition-all duration-300 hover:-translate-y-px hover:shadow-lg hover:shadow-sage/30">
            Plan Your Journey
            <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
          </a>
          <a href="/dahabiyas"
            class="group inline-flex items-center gap-3 border border-white/25 hover:border-white/50 text-white/80 hover:text-white font-sans text-xs tracking-ultra uppercase px-7 py-4 rounded-full transition-all duration-300 hover:bg-white/5 backdrop-blur-sm">
            Explore the Fleet
            <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
          </a>
        </div>
      </div>
    ))}
  </div>

  <!-- Slide indicators — bottom center -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex items-center gap-3">
    {slides.map((_, i) => (
      <button
        class="hero-dot transition-all duration-400 rounded-full"
        data-target={i}
        aria-label={`Go to slide ${i + 1}`}
        style={i === 0
          ? 'width:28px; height:3px; background:rgba(200,168,92,0.9); border-radius:2px;'
          : 'width:8px; height:3px; background:rgba(255,255,255,0.3); border-radius:2px;'}
      ></button>
    ))}
  </div>

  <!-- Prev / Next arrows -->
  <button id="heroPrev"
    class="absolute left-5 lg:left-10 top-1/2 -translate-y-1/2 z-20 w-11 h-11 flex items-center justify-center border border-white/20 hover:border-white/50 text-white/60 hover:text-white transition-all duration-300 hover:bg-white/5 backdrop-blur-sm"
    aria-label="Previous slide">
    ←
  </button>
  <button id="heroNext"
    class="absolute right-5 lg:right-10 top-1/2 -translate-y-1/2 z-20 w-11 h-11 flex items-center justify-center border border-white/20 hover:border-white/50 text-white/60 hover:text-white transition-all duration-300 hover:bg-white/5 backdrop-blur-sm"
    aria-label="Next slide">
    →
  </button>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 right-8 md:right-12 z-10 flex flex-col items-center gap-3"
    style="animation: fadeIn 1s 1.5s both;">
    <span class="font-sans text-xs tracking-ultra uppercase text-white/30 [writing-mode:vertical-lr]">Scroll</span>
    <div class="w-px h-16 bg-gradient-to-b from-gold-light/50 to-transparent relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full bg-gold-light" style="height: 40%; animation: scrollLine 2s ease-in-out infinite;"></div>
    </div>
  </div>
</section>

<style>
  @keyframes heroScale {
    from { transform: scale(1.0); }
    to   { transform: scale(1.08); }
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes scrollLine {
    0%   { top: -40%; }
    100% { top: 140%; }
  }

  /* Short screens — scale down everything so content fits between nav and bottom */
  @media (max-height: 620px) {
    .hero-content h1 { font-size: clamp(1.8rem, 5vh, 3rem) !important; line-height: 1.05 !important; }
    .hero-content p  { font-size: 0.75rem !important; margin-bottom: 0.5rem !important; }
    .hero-content .gold-line { margin-bottom: 0.5rem !important; }
    .hero-content > div { gap: 0 !important; }
    .hero-content a  { padding-top: 0.6rem !important; padding-bottom: 0.6rem !important; font-size: 0.65rem !important; }
  }
</style>

<script>
  const hero = document.getElementById('hero');
  const slides = document.querySelectorAll<HTMLElement>('.hero-slide');
  const contents = document.querySelectorAll<HTMLElement>('.hero-content');
  const dots = document.querySelectorAll<HTMLElement>('.hero-dot');
  let current = 0;
  let timer: ReturnType<typeof setInterval> | null = null;
  let paused = false;

  // Skip auto-advance entirely if the user prefers reduced motion.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function goTo(index: number) {
    // Hide current
    slides[current].style.opacity = '0';
    contents[current].style.opacity = '0';
    contents[current].style.transform = 'translateY(20px)';
    contents[current].style.pointerEvents = 'none';
    dots[current].style.width = '8px';
    dots[current].style.background = 'rgba(255,255,255,0.3)';

    current = (index + slides.length) % slides.length;

    // Show next
    slides[current].style.opacity = '1';
    contents[current].style.opacity = '1';
    contents[current].style.transform = 'translateY(0)';
    contents[current].style.pointerEvents = 'auto';
    dots[current].style.width = '28px';
    dots[current].style.background = 'rgba(200,168,92,0.9)';
  }

  function startTimer() {
    if (reduceMotion || paused) return;
    if (timer) clearInterval(timer);
    timer = setInterval(() => goTo(current + 1), 6000);
  }

  function stopTimer() {
    if (timer) { clearInterval(timer); timer = null; }
  }

  document.getElementById('heroNext')?.addEventListener('click', () => { goTo(current + 1); startTimer(); });
  document.getElementById('heroPrev')?.addEventListener('click', () => { goTo(current - 1); startTimer(); });

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      goTo(parseInt(dot.dataset.target || '0'));
      startTimer();
    });
  });

  // Pause on hover/focus; resume on leave/blur.
  if (hero) {
    hero.addEventListener('mouseenter', () => { paused = true; stopTimer(); });
    hero.addEventListener('mouseleave', () => { paused = false; startTimer(); });
    hero.addEventListener('focusin',  () => { paused = true; stopTimer(); });
    hero.addEventListener('focusout', () => { paused = false; startTimer(); });
  }

  // Pause when the tab is hidden so the carousel doesn't drift in the background.
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) stopTimer(); else startTimer();
  });

  startTimer();

  // Enable transitions only after initial paint — prevents inactive slides from
  // briefly flashing as the browser transitions from CSS default (opacity:1) to
  // the inline opacity:0 set in the HTML template.
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      slides.forEach((s) => {
        s.style.transition = 'opacity 1s ease-in-out';
      });
      contents.forEach((c) => {
        c.style.transition = 'opacity 0.7s ease-in-out, transform 0.7s ease-in-out';
      });
    });
  });
</script>
