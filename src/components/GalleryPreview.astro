---
// GalleryPreview — homepage taster of onboard interiors (VEDA fleet photos).
// Uses public images (plain <img>) shown in a bento grid.

const shots = [
  { src: '/images/veda_2_Indoor_Lounge.jpg',                                    caption: 'Indoor lounge & bar', span: true },
  { src: '/images/veda2_main.jpg',                       caption: 'veda 2' },
  { src: '/images/veda_4_Air-conditioned_Outdoor_Glass-enclosed_Restaurant_1.jpg', caption: 'Glass-enclosed dining' },
  { src: '/images/veda_1_Suite_with_Private_Outdoor_Terrace_1.jpg',             caption: 'A room with a view' },
  { src: '/images/veda_2_Upper_Sundeck_Bar_Outdoor-Lounge.jpg',                 caption: 'Lounge on the water' },
];
---

<section id="gallery-preview" class="bg-linen py-24 lg:py-32">

  <!-- Header -->
  <div class="max-w-7xl mx-auto px-6 lg:px-12 text-center mb-14 reveal">
    <div class="flex items-center justify-center gap-4 mb-6">
      <span class="h-px w-10 bg-gold/50"></span>
      <p class="font-sans text-sm tracking-ultra uppercase text-gold">A Closer Look</p>
      <span class="h-px w-10 bg-gold/50"></span>
    </div>
    <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl text-earth font-light tracking-tight leading-tight">
      Step <em class="italic text-gold">onboard</em>
    </h2>
    <p class="font-sans text-base text-sandstone font-light leading-relaxed max-w-xl mx-auto mt-5">
      Cabins, lounges, and sun-washed decks — every space designed for slow days on the river.
    </p>
  </div>

  <!-- Bento grid — full width, edge to edge -->
  <div class="grid grid-cols-2 md:grid-cols-3 gap-1">
    {shots.map((shot, i) => (
      <figure
        class:list={[
          'group relative overflow-hidden h-60 md:h-80 reveal',
          `reveal-delay-${i + 1}`,
          shot.span ? 'col-span-2' : '',
        ]}
      >
          <img
            src={shot.src}
            alt={shot.caption}
            class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
            loading="lazy"
          />
          <!-- Hover wash + caption -->
          <div class="absolute inset-0 bg-gradient-to-t from-earth/80 via-earth/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-400"></div>
          <figcaption class="absolute bottom-0 left-0 p-5 translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-400">
            <span class="font-serif text-lg text-white font-light">{shot.caption}</span>
          </figcaption>
        </figure>
      ))}
    </div>
</section>
