---
// CTA Section — DARK, emotional impact, new copy
---

<section id="contact" class="relative overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src="/images/photo-2019-06-28-08.47.38-1280x800.jpg"
      alt="Nile at sunset"
      class="w-full h-full object-cover"
      loading="lazy"
    />
    <!-- Strong dark overlay with warm tint -->
    <div class="absolute inset-0 bg-gradient-to-b from-void/90 via-forest/85 to-void/95"></div>
    <!-- Subtle warm amber center glow -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <div class="w-2/3 h-2/3 rounded-full blur-3xl opacity-10" style="background: radial-gradient(ellipse, #c9913a 0%, transparent 65%);"></div>
    </div>
  </div>

  <!-- Gold border lines -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>

  <div class="relative z-10 max-w-3xl mx-auto px-6 lg:px-12 py-32 lg:py-48 text-center">

    <!-- Top ornament -->
    <div class="flex items-center justify-center gap-4 mb-12 reveal">
      <span class="h-px w-10 bg-gold/40"></span>
      <span class="w-1 h-1 rounded-full bg-gold/60"></span>
      <span class="font-sans text-xs tracking-ultra uppercase text-gold-light/70">Begin Here</span>
      <span class="w-1 h-1 rounded-full bg-gold/60"></span>
      <span class="h-px w-10 bg-gold/40"></span>
    </div>

    <!-- New emotional heading -->
    <h2 class="font-serif text-4xl md:text-6xl lg:text-7xl text-white font-light tracking-tight leading-[1.05] mb-6 reveal reveal-delay-1"
      style="text-shadow: 0 2px 40px rgba(0,0,0,0.4);">
      This is more<br />than a trip.
    </h2>

    <!-- Sub-heading -->
    <p class="font-serif text-xl md:text-2xl text-gold-pale/80 font-light italic mb-6 reveal reveal-delay-2">
      It's your moment to disconnect.
    </p>

    <!-- Supporting text -->
    <p class="font-sans text-base text-ivory/50 max-w-sm mx-auto leading-relaxed mb-14 reveal reveal-delay-3">
      Tell us your dream. We will craft a journey that belongs only to you.
    </p>

    <!-- Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center reveal reveal-delay-3">
      <a
        href="mailto:reservation@veda-egypt.com"
        class="group inline-flex items-center justify-center gap-3 bg-gold hover:bg-gold-light text-white font-sans text-xs tracking-ultra uppercase px-8 py-4 transition-all duration-300"
      >
        Request Itinerary
        <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
      </a>
      <a
        href="mailto:info@veda-egypt.com"
        class="group inline-flex items-center justify-center gap-3 border border-white/20 hover:border-white/45 text-white/65 hover:text-white font-sans text-xs tracking-ultra uppercase px-8 py-4 transition-all duration-300 hover:bg-white/5 backdrop-blur-sm"
      >
        Contact Us
        <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
      </a>
    </div>

    <!-- Contact info -->
    <!-- <div class="mt-14 flex flex-col sm:flex-row items-center justify-center gap-6 reveal reveal-delay-4">
      <a href="mailto:reservation@veda-egypt.com"
        class="font-sans text-xs text-warm-gray hover:text-gold-light transition-colors tracking-wide">
        reservation@veda-egypt.com
      </a>
      <span class="hidden sm:block h-px w-5 bg-gold/25"></span>
      <a href="mailto:info@veda-egypt.com"
        class="font-sans text-xs text-warm-gray hover:text-gold-light transition-colors tracking-wide">
        info@veda-egypt.com
      </a>
    </div> -->

    <!-- CNN mention -->
    <!-- <div class="mt-20 pt-12 border-t border-gold/10 reveal">
      <p class="font-sans text-xs tracking-ultra uppercase text-warm-gray/40 mb-3">As Seen On</p>
      <p class="font-serif text-2xl text-white/20 tracking-[0.3em]">CNN</p>
    </div> -->
  </div>
</section>
